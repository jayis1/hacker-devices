    (net "BLE_IRQ"))

  ; U1 → J4 (MicroSD)
  (wire (uuid "w00000012") (pts (xy 140 80) (xy 160 80))  ; PC8/D0 → J4.7
    (net "SD_D0"))
  (wire (uuid "w00000013") (pts (xy 140 85) (xy 160 85))  ; PC9/D1 → J4.8
    (net "SD_D1"))
  (wire (uuid "w00000014") (pts (xy 140 90) (xy 160 90))  ; PC10/D2 → J4.1
    (net "SD_D2"))
  (wire (uuid "w00000015") (pts (xy 140 95) (xy 160 95))  ; PC11/D3 → J4.2
    (net "SD_D3"))
  (wire (uuid "w00000016") (pts (xy 140 100) (xy 160 100)) ; PC12/CLK → J4.5
    (net "SD_CLK"))
  (wire (uuid "w00000017") (pts (xy 140 105) (xy 160 105)) ; PD2/CMD → J4.3
    (net "SD_CMD"))

  ; U1 → J1 (USB-C via ESD protection U5)
  (wire (uuid "w00000018") (pts (xy 30 120) (xy 50 120))  ; PA11/DM → U5.1
    (net "USB_DM"))
  (wire (uuid "w00000019") (pts (xy 30 125) (xy 50 125))  ; PA12/DP → U5.6
    (net "USB_DP"))
  (wire (uuid "w0000001a") (pts (xy 10 110) (xy 30 110))  ; VBUS from J1.A4
    (net "VBUS"))

  ; U1 → Y1 (25MHz crystal)
  (wire (uuid "w0000001b") (pts (xy 20 30) (xy 30 30))   ; PA0/OSC_IN → Y1.1
    )
  (wire (uuid "w0000001c") (pts (xy 20 35) (xy 30 35))   ; PA1/OSC_OUT → Y1.3
    )

  ; U2 → Y2 (32.768kHz crystal)
  (wire (uuid "w0000001d") (pts (xy 80 30) (xy 90 30))   ; XC1 → Y2.1
    )
  (wire (uuid "w0000001e") (pts (xy 80 35) (xy 90 35))   ; XC2 → Y2.2
    )

  ; U2 → L1 (antenna matching)
  (wire (uuid "w0000001f") (pts (xy 100 25) (xy 110 25))  ; ANT1 → L1.1
    )
  (wire (uuid "w00000020") (pts (xy 100 30) (xy 110 30))  ; ANT2 → L1.2
    )

  ; Power: U3 (AMS1117-3.3) — 5V to 3.3V
  (wire (uuid "w00000021") (pts (xy 10 150) (xy 25 150))  ; +5V → U3.3
    (net "+5V"))
  (wire (uuid "w00000022") (pts (xy 40 150) (xy 55 150))  ; U3.2 → +3V3
    (net "+3V3"))
  (wire (uuid "w00000023") (pts (xy 25 160) (xy 25 165))  ; U3.1 → GND
    (net "GND"))

  ; Power: VBUS from USB → +5V via U3
  (wire (uuid "w00000024") (pts (xy 10 110) (xy 10 150))  ; VBUS → +5V
    (net "VBUS"))

  ; Series resistors on LAD lines (RN1 — 100Ω resistor network)
  (wire (uuid "w00000025") (pts (xy 100 90) (xy 110 90))  ; LAD0 via RN1
    (net "LAD0"))
  (wire (uuid "w00000026") (pts (xy 100 95) (xy 110 95))  ; LAD1 via RN1
    (net "LAD1"))
  (wire (uuid "w00000027") (pts (xy 100 100) (xy 110 100)) ; LAD2 via RN1
    (net "LAD2"))
  (wire (uuid "w00000028") (pts (xy 100 105) (xy 110 105)) ; LAD3 via RN1
    (net "LAD3"))

  ; Decoupling caps (placed near each power pin)
  (wire (uuid "w00000029") (pts (xy 15 40) (xy 15 45))   ; C1 on VDD
    (net "+3V3"))
  (wire (uuid "w0000002a") (pts (xy 15 45) (xy 15 50))   ; C1 to GND
    (net "GND"))
  (wire (uuid "w0000002b") (pts (xy 20 40) (xy 20 45))   ; C2 on VDDA
    (net "+3V3"))
  (wire (uuid "w0000002c") (pts (xy 20 45) (xy 20 50))   ; C2 to GND
    (net "GND"))

  ; LEDs (D2-D5) on PE1-PE4
  (wire (uuid "w0000002d") (pts (xy 170 60) (xy 180 60))  ; PE1 → D2.A (LED_STATUS)
    (net "+3V3"))
  (wire (uuid "w0000002e") (pts (xy 170 65) (xy 180 65))  ; PE2 → D3.A (LED_CAPTURE)
    (net "+3V3"))
  (wire (uuid "w0000002f") (pts (xy 170 70) (xy 180 70))  ; PE3 → D4.A (LED_ERROR)
    (net "+3V3"))
  (wire (uuid "w00000030") (pts (xy 170 75) (xy 180 75))  ; PE4 → D5.A (LED_LPC)
    (net "+3V3"))

  ; Button (SW1) on PC13
  (wire (uuid "w00000031") (pts (xy 170 40) (xy 180 40))  ; PC13 → SW1
    (net "+3V3"))
  (wire (uuid "w00000032") (pts (xy 180 40) (xy 190 40))  ; SW1 → GND
    (net "GND"))

