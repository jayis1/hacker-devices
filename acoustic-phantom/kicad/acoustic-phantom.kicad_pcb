    )
    (pad_to_mask_clearance 0.05)
    (solder_mask_margin 0.05)
    (aux_axis_origin 0 0)
    (grid_origin 0 0)
    (plot_setup
      (psnegative no)
      (psa4output no)
      (plotreference yes)
      (plotvalue yes)
      (plotinvisibletext no)
      (padsonsilk no)
      (subtractmaskfromsilk no)
      (outputformat 1)
      (mirror no)
      (drillshape 1)
      (scaleselection 3)
      (outputdirectory "gerbers/"))
