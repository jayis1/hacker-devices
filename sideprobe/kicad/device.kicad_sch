      (pin "2" (type passive) (at 5 0))
    )
  )

  ; ============================================================
  ; COMPONENT INSTANCES
  ; ============================================================
  (symbol_instances
    ; ---- MCU ----
    (path "/U1" (reference "U1") (unit 1) (value "STM32H743VIT6")
      (at 100 100 (angle 0))
      (property "Sheet" "Main")
      (property "Author" "jayis1"))

    ; ---- BLE module ----
    (path "/U2" (reference "U2") (unit 1) (value "NINA-B302")
      (at 200 60 (angle 0))
      (property "Author" "jayis1"))

    ; ---- FPGA ----
    (path "/U3" (reference "U3") (unit 1) (value "iCE40-UP5K-SG48")
      (at 100 180 (angle 0))
      (property "Author" "jayis1"))

    ; ---- ADC ----
    (path "/U4" (reference "U4") (unit 1) (value "ADS8686S")
      (at 40 180 (angle 0))
      (property "Author" "jayis1"))

    ; ---- Power PGA ----
    (path "/U5" (reference "U5") (unit 1) (value "AD8429")
      (at -40 180 (angle 0))
      (property "Author" "jayis1"))

    ; ---- EM VGA stage 1 ----
    (path "/U6" (reference "U6") (unit 1) (value "ADL5205")
      (at -40 120 (angle 0))
      (property "Author" "jayis1"))

    ; ---- USB PHY ----
    (path "/U7" (reference "U7") (unit 1) (value "USB3300")
      (at 200 120 (angle 0))
      (property "Author" "jayis1"))

    ; ---- SDRAM ----
    (path "/U8" (reference "U8") (unit 1) (value "IS42S16160J-6BL")
      (at 300 180 (angle 0))
      (property "Author" "jayis1"))

    ; ---- Fuel gauge ----
    (path "/U9" (reference "U9") (unit 1) (value "MAX17048")
      (at 300 60 (angle 0))
      (property "Author" "jayis1"))

    ; ---- LiPo charger ----
    (path "/U10" (reference "U10") (unit 1) (value "MCP73831")
      (at 300 30 (angle 0))
      (property "Author" "jayis1"))

    ; ---- Level shifter ----
    (path "/U11" (reference "U11") (unit 1) (value "TXS0108E")
      (at -100 100 (angle 0))
      (property "Author" "jayis1"))

    ; ---- OLED ----
    (path "/D1" (reference "D1") (unit 1) (value "SH1106_128x64")
      (at 200 180 (angle 0))
      (property "Author" "jayis1"))

    ; ---- Connectors ----
    (path "/J1" (reference "J1") (unit 1) (value "SMA_EM")
      (at -80 60 (angle 0))
      (property "Author" "jayis1"))
    (path "/J2" (reference "J2") (unit 1) (value "USB-C")
      (at 240 100 (angle 0))
      (property "Author" "jayis1"))
    (path "/J3" (reference "J3") (unit 1) (value "microSD")
      (at 300 120 (angle 0))
      (property "Author" "jayis1"))
    (path "/J4" (reference "J4") (unit 1) (value "LiPo")
      (at 300 0 (angle 0))
      (property "Author" "jayis1"))
    (path "/J5" (reference "J5") (unit 1) (value "Target")
      (at -120 100 (angle 0))
      (property "Author" "jayis1"))

    ; ---- Buttons (5) ----
    (path "/SW1" (reference "SW1") (unit 1) (value "SW_Push")
      (at 80 40 (angle 0)) (property "Author" "jayis1"))
    (path "/SW2" (reference "SW2") (unit 1) (value "SW_Push")
      (at 90 40 (angle 0)) (property "Author" "jayis1"))
    (path "/SW3" (reference "SW3") (unit 1) (value "SW_Push")
      (at 100 40 (angle 0)) (property "Author" "jayis1"))
    (path "/SW4" (reference "SW4") (unit 1) (value "SW_Push")
      (at 110 40 (angle 0)) (property "Author" "jayis1"))
    (path "/SW5" (reference "SW5") (unit 1) (value "SW_Push")
      (at 120 40 (angle 0)) (property "Author" "jayis1"))
  )

  ; ============================================================
  ; NETLIST
  ; ============================================================
  (nets
    (net "VCC_3V3"  (connections ("U1.VDD" "U2.VCC" "U3.VCC" "U3.VCCIO_0" "U3.VCCIO_1"
                                  "U4.DVDD" "U7.VCC" "U8.VDD" "U9.VDD" "U11.VCCA"
                                  "D1.VCC")))
    (net "VCC_5V"   (connections ("U4.AVDD" "U11.VCCB")))
    (net "GND"      (connections ("U1.VSS" "U2.GND" "U3.GND" "U4.AVSS" "U4.DGND"
                                  "U5.V-" "U6.GND" "U7.GND" "U8.VSS" "U9.GND"
                                  "U10.VSS" "U11.GND" "D1.GND"
                                  "J1.GND" "J2.GND" "J3.GND" "J4.-" "SW1.2" "SW2.2"
                                  "SW3.2" "SW4.2" "SW5.2")))
    (net "VBAT"     (connections ("J4.+" "U10.VBAT" "U9.CELL+")))
    (net "VBUS_USB" (connections ("J2.VBUS" "U10.VDD" "U7.VBUS")))
    (net "VBAT_SENSE" (connections ("U9.CELL-" "R20.1")))

    ; ---- Power shunt path ----
    (net "SHUNT_P"  (connections ("J5.1" "U5.+IN")))
    (net "SHUNT_N"  (connections ("J5.2" "U5.-IN")))
    (net "PGA_OUT"  (connections ("U5.OUT" "U4.AIN0_P")))
    (net "PGA_REF"  (connections ("U5.REF" "U4.AIN0_N" "R_REF.1")))
    (net "PGA_GAIN" (connections ("U5.RG1" "R_GAIN.1" "U5.RG2" "R_GAIN.2")))

    ; ---- EM path ----
    (net "EM_PROBE_IN" (connections ("J1.SIG" "U6.IN_P")))
    (net "EM_LNA_OUT"  (connections ("U6.OUT_P" "U4.AIN1_P")))
    (net "EM_LNA_OUT_N" (connections ("U6.OUT_N" "U4.AIN1_N")))
    (net "VGA_GAIN_SPI_CLK" (connections ("U6.SCLK" "U1.PB13")))
    (net "VGA_GAIN_SPI_DIO" (connections ("U6.SDIO" "U1.PB3")))
    (net "VGA_GAIN_SPI_CSN" (connections ("U6.CSN" "U1.PB4")))

    ; ---- ADC SPI to MCU/FPGA ----
    (net "ADC_SCLK"  (connections ("U4.SCLK" "U1.PB10")))
    (net "ADC_DOUT"  (connections ("U4.DOUT" "U1.PB13")))
    (net "ADC_DIN"   (connections ("U4.DIN"  "U1.PB3")))
    (net "ADC_CS"    (connections ("U4.CS"   "U1.PB8")))
    (net "ADC_BUSY"  (connections ("U4.BUSY" "U3.IO_0")))
    (net "ADC_CONV"  (connections ("U4.CONVSTA" "U3.IO_1")))

    ; ---- FPGA config (MCU -> FPGA) ----
    (net "FPGA_SCK"  (connections ("U1.PB3"  "U3.SPI_SCK")))
    (net "FPGA_SDI"  (connections ("U1.PB4"  "U3.SPI_SDI")))
    (net "FPGA_CSN"  (connections ("U1.PB8"  "U3.SPI_CSN")))
    (net "FPGA_CRST" (connections ("U1.PB6"  "U3.CRESET")))
    (net "FPGA_CDONE" (connections ("U1.PB7" "U3.CDONE")))

    ; ---- FPGA <-> SDRAM (FMC, abbreviated) ----
    (net "FMC_D0"  (connections ("U1.PD0"  "U8.DQ0")))
    (net "FMC_D15" (connections ("U1.PD15" "U8.DQ15")))
    (net "FMC_A0"  (connections ("U1.PE0"  "U8.A0")))
    (net "FMC_A12" (connections ("U1.PE12" "U8.A12")))
    (net "FMC_NWE" (connections ("U1.PD14" "U8.WE")))
    (net "FMC_CAS" (connections ("U1.PD15" "U8.CAS")))
    (net "FMC_CLK" (connections ("U1.PD3"  "U8.CLK")))

    ; ---- BLE UART ----
    (net "BLE_TX" (connections ("U2.UART_TX" "U1.PA3")))
    (net "BLE_RX" (connections ("U2.UART_RX" "U1.PA2")))

    ; ---- USB ----
    (net "USB_DP" (connections ("J2.DP1" "U7.DP")))
    (net "USB_DM" (connections ("J2.DM1" "U7.DM")))
    (net "ULPI_CLK" (connections ("U7.ULPI_CLK" "U1.PA5")))
    (net "ULPI_DIR" (connections ("U7.ULPI_DIR" "U1.PA11")))
    (net "ULPI_NXT" (connections ("U7.ULPI_NXT" "U1.PA12")))
    (net "ULPI_D0"  (connections ("U7.ULPI_D0"  "U1.PC0")))

    ; ---- I2C fuel gauge ----
    (net "I2C_SDA" (connections ("U9.SDA" "U1.PD9")))
    (net "I2C_SCL" (connections ("U9.SCL" "U1.PD8")))

    ; ---- SD card (SDMMC1) ----
    (net "SD_CMD" (connections ("J3.CMD" "U1.PD2")))
    (net "SD_CLK" (connections ("J3.CLK" "U1.PC12")))
    (net "SD_D0"  (connections ("J3.D0"  "U1.PC8")))
    (net "SD_D3"  (connections ("J3.D3"  "U1.PC11")))

    ; ---- OLED ----
    (net "OLED_SCL" (connections ("D1.SCL" "U1.PD13")))
    (net "OLED_SDA" (connections ("D1.SDA" "U1.PD15")))
    (net "OLED_RES" (connections ("D1.RES" "U1.PD11")))
    (net "OLED_DC"  (connections ("D1.DC"  "U1.PD12")))
    (net "OLED_CS"  (connections ("D1.CS"  "U1.PD14")))

    ; ---- Target I/O via level shifter ----
    (net "TGT_TRIG_IN"  (connections ("J5.3" "U11.B1")))
    (net "TGT_TRIG_OUT" (connections ("U11.A1" "U1.PC14")))
    (net "TGT_TX"       (connections ("J5.4" "U11.B2" "U1.PA9")))
    (net "TGT_RX"       (connections ("J5.5" "U11.B3" "U1.PA10")))
    (net "TGT_RST"      (connections ("J5.6" "U11.B4" "U1.PC15")))
    (net "TGT_CLK"      (connections ("J5.7" "U11.B5" "U1.PC13")))
    (net "TGT_GND"      (connections ("J5.10" "GND")))

    ; ---- Buttons ----
    (net "BTN_MODALITY" (connections ("SW1.1" "U1.PA0")))
    (net "BTN_GAINUP"   (connections ("SW2.1" "U1.PA1")))
    (net "BTN_GAINDOWN" (connections ("SW3.1" "U1.PA2")))
    (net "BTN_ARM"      (connections ("SW4.1" "U1.PA3")))
    (net "BTN_ATTACK"   (connections ("SW5.1" "U1.PA4")))
  )

  ; ============================================================
  ; POWER RAILS / DECOUPLING (representative)
  ; ============================================================
  (power_rails
    (rail "VCC_3V3" (voltage 3.3) (decoupling
      ("C1" "100nF" "U1") ("C2" "100nF" "U1") ("C3" "4.7uF" "U1")
      ("C4" "100nF" "U2") ("C5" "100nF" "U3") ("C6" "100nF" "U3")
      ("C7" "100nF" "U4") ("C8" "100nF" "U9")))
    (rail "VCC_5V" (voltage 5.0) (decoupling
      ("C9" "100nF" "U4") ("C10" "4.7uF" "U4")))
    (rail "VCC_1V2_FPGA" (voltage 1.2) (decoupling ("C11" "100nF" "U3") ("C12" "4.7uF" "U3")))
    (rail "VCC_2V5_FPGA" (voltage 2.5) (decoupling ("C13" "100nF" "U3") ("C14" "4.7uF" "U3")))
  )

  ; Ferrite bead on AVDD to isolate analog from digital
  (components_passive
    ("L1" "Ferrite_Bead" "AVDD_isolation" (pins "VCC_5V" "AVDD_FILT"))
    ("L2" "Ferrite_Bead" "EM_LNA_isolation" (pins "VCC_3V3" "VCC_EM"))
  )

  ; ============================================================
  ; SHEET NOTES
  ; ============================================================
  (sheetnotes
    (text "SideProbe — Power & EM side-channel analysis platform")
    (text "Author: jayis1 — CERN-OHL-S v2 hardware, GPL-2.0 firmware")
    (text "Power path: shunt -> AD8429 PGA -> ADS8686S ch0")
    (text "EM path: SMA probe -> BPF -> ADL5205 VGA x2 -> ADS8686S ch1")
    (text "FPGA iCE40-UP5K: trigger + trace alignment + per-trace sum/sq")
    (text "STM32H743: CPA correlation engine, BLE/USB backhaul, SD log")
    (text "LEGAL: authorized security research only. See README.")
  )
)