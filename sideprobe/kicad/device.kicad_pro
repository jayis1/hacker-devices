{
  "board": {
    "design": {
      "last_author": "jayis1",
      "settings": {
        "copper_edge_clearance": 0.15,
        "rule_severities": {
          "lib_symbol_issues": "warning",
          "same_local_global": "error",
          "track_dangling": "warning",
          "via_dangling": "warning",
          "unconnected_items": "error"
        }
      },
      "track_widths": [0.0, 0.15, 0.18, 0.2, 0.25, 0.3, 0.5, 0.8],
      "via_dimensions": [
        {"diameter": 0.5, "drill": 0.25},
        {"diameter": 0.6, "drill": 0.3},
        {"diameter": 0.8, "drill": 0.4}
      ],
      "diff_pair_dimensions": [
        {"width": 0.18, "gap": 0.12, "via_gap": 0.2}
      ],
      "layer_presets": [],
      "view": {
        "coords": {"x": 50, "y": 31},
        "zoom": 1.5
      }
    },
    "ipc2581": {
      "dist": "",
      "mfg": "",
      "mpn": "",
      "internal_id": "SideProbe-v1.0"
    },
    "metadata": {
      "filename": "device.kicad_pcb",
      "version": 1,
      "date": "2026-06-26",
      "author": "jayis1"
    },
    "setup": {
      "stackup": {
        "layers": [
          {"name": "F.Cu", "type": "copper", "thickness": 0.035},
          {"name": "F.Paste", "type": "solder-paste"},
          {"name": "F.SilkS", "type": "silk-screen"},
          {"name": "F.Mask", "type": "solder-mask"},
          {"name": "Dielectric.1", "type": "dielectric", "thickness": 0.1},
          {"name": "In1.Cu", "type": "copper", "thickness": 0.035},
          {"name": "Dielectric.2", "type": "dielectric", "thickness": 0.2},
          {"name": "In2.Cu", "type": "copper", "thickness": 0.035},
          {"name": "Dielectric.3", "type": "dielectric", "thickness": 0.4},
          {"name": "In3.Cu", "type": "copper", "thickness": 0.035},
          {"name": "Dielectric.4", "type": "dielectric", "thickness": 0.1},
          {"name": "In4.Cu", "type": "copper", "thickness": 0.035},
          {"name": "Dielectric.5", "type": "dielectric", "thickness": 0.2},
          {"name": "B.Mask", "type": "solder-mask"},
          {"name": "B.SilkS", "type": "silk-screen"},
          {"name": "B.Cu", "type": "copper", "thickness": 0.035}
        ]
      },
      "pad_to_mask_clearance": 0.05,
      "solder_mask_min_width": 0.05,
      "grid_origin": {"x": 0, "y": 0},
      "defaults": {
        "track_width": 0.2,
        "via_diameter": 0.6,
        "via_drill": 0.3,
        "copper_line_width": 0.1
      },
      "erc": {
        "enabled": true,
        "severity": {
          "unconnected_pin": "warning",
          "power_pin_not_driven": "error",
          "different_net_in_same_pin": "error"
        }
      },
      "drc": {
        "enabled": true,
        "rules": {
          "min_track_width": 0.15,
          "min_via_diameter": 0.5,
          "min_via_drill": 0.25,
          "min_clearance": 0.15,
          "min_copper_clearance": 0.15,
          "copper_edge_clearance": 0.2,
          "hole_to_hole_clearance": 0.25
        }
      }
    },
    "teardrops": {
      "enabled": true,
      "max_width": 0.5,
      "max_length": 0.5
    },
    "rules": {
      "impedance_controlled": true,
      "usb_90ohm_diff": {
        "width": 0.18,
        "gap": 0.12,
        "layer": "F.Cu",
        "target_impedance": 90
      }
    },
    "notes": [
      "SideProbe v1.0 — 6-layer board, 100x62mm",
      "Author: jayis1 — CERN-OHL-S v2",
      "Analog section (left 20mm) isolated with split ground (AGND)",
      "ULPI USB diff pairs 90-ohm controlled impedance"
    ]
  },
  "schematic": {
    "last_author": "jayis1",
    "metadata": {
      "filename": "device.kicad_sch",
      "date": "2026-06-26",
      "author": "jayis1"
    },
    "erc": {
      "enabled": true,
      "severity": {
        "pin_not_connected": "warning",
        "power_pin_not_driven": "error",
        "hierarchical_label_unmatched": "error"
      }
    },
    "annotation": {
      "method": "X-Y",
      "start": 1
    }
  },
  "libraries": {
    "paths": {
