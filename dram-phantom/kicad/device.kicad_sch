    (path "/U5" (reference "U5") (unit 1) (value "TPS62110")
      (at -100 100 (angle 0)) (property "Author" "jayis1"))
    (path "/U6" (reference "U6") (unit 1) (value "MAX17048")
      (at -100 20 (angle 0)) (property "Author" "jayis1"))
    (path "/U7" (reference "U7") (unit 1) (value "IS25LP032D")
      (at 180 160 (angle 0)) (property "Author" "jayis1"))
    (path "/U8" (reference "U8") (unit 1) (value "DDR4-SODIMM-260")
      (at 280 120 (angle 0)) (property "Author" "jayis1"))
    (path "/J1" (reference "J1") (unit 1) (value "DDR4-EDGE-260")
      (at 280 60 (angle 0)) (property "Author" "jayis1"))
    (path "/J2" (reference "J2") (unit 1) (value "USB-C")
      (at -40 80 (angle 0)) (property "Author" "jayis1"))
    (path "/J3" (reference "J3") (unit 1) (value "microSD")
      (at 220 120 (angle 0)) (property "Author" "jayis1"))
    (path "/J4" (reference "J4") (unit 1) (value "LiPo")
      (at -120 20 (angle 0)) (property "Author" "jayis1"))
    (path "/D1" (reference "D1") (unit 1) (value "SSD1306-128x64")
      (at 220 80 (angle 0)) (property "Author" "jayis1"))
    (path "/Q1" (reference "Q1") (unit 1) (value "2N7002K")
      (at 250 60 (angle 0)) (property "Author" "jayis1"))
    (path "/SW1" (reference "SW1") (unit 1) (value "SW_Push")
      (at 40 60 (angle 0)) (property "Author" "jayis1"))
    ; Decoupling caps (representative)
    (path "/C1" (reference "C1") (unit 1) (value "100nF") (at 60 40 (angle 0)))
    (path "/C2" (reference "C2") (unit 1) (value "100nF") (at 70 40 (angle 0)))
    (path "/C3" (reference "C3") (unit 1) (value "10uF") (at 80 40 (angle 0)))
    (path "/C4" (reference "C4") (unit 1) (value "4.7uF") (at 90 40 (angle 0)))
    (path "/C5" (reference "C5") (unit 1) (value "100nF") (at 100 40 (angle 0)))
    ; Series-R taps on DDR4 CA bus
    (path "/R1" (reference "R1") (unit 1) (value "22R") (at 320 80 (angle 0)))
    (path "/R2" (reference "R2") (unit 1) (value "22R") (at 320 85 (angle 0)))
    (path "/R3" (reference "R3") (unit 1) (value "33R") (at 320 90 (angle 0)))
    (path "/R4" (reference "R4") (unit 1) (value "33R") (at 320 95 (angle 0)))
    (path "/R5" (reference "R5") (unit 1) (value "33R") (at 320 100 (angle 0)))
  )

  ; ============================================================
  ; NETLIST
  ; ============================================================
  (nets
    ; ---- Power rails ----
    (net "VDD_1V2" (connections ("J1.VDD_0" "U8.VDD_0" "U8.VDDQ_0"
                                  "U1.VCCO_BANK14" "U1.VCCO_BANK15" "U1.VCCO_BANK16"
                                  "C1.1" "C2.1")))
    (net "VPP_2V5" (connections ("J1.VPP_0" "U8.VPP_0")))
    (net "VCC_1V0" (connections ("U5.VOUT" "U1.VCCINT_0" "U1.VCCINT_1"
                                  "U1.VCCAUX" "C3.1")))
    (net "VCC_3V3" (connections ("U4.VOUT" "U2.VDD" "U2.VBAT" "U2.VDDA"
                                  "U3.VDD" "U6.VDD" "U7.VCC" "D1.VCC"
                                  "J3.VDD" "C4.1" "C5.1")))
    (net "VBAT_RAW" (connections ("J4.+" "U4.VIN" "U5.VIN" "U6.CELL+")))
    (net "GND" (connections ("J1.GND_0" "U8.GND_0" "U1.GND_0" "U1.GND_1"
                              "U2.VSS" "U3.GND" "U4.GND" "U5.GND" "U6.GND"
                              "U6.CELL-" "U7.GND" "D1.GND" "J3.GND" "J2.GND"
                              "J4.-" "SW1.2" "Q1.S" "C1.2" "C2.2" "C3.2" "C4.2" "C5.2")))
    (net "VBUS_USB" (connections ("J2.VBUS" "U4.VIN" "R_CHARGE.1")))

    ; ---- DDR4 passthrough (edge J1 <-> socket U8) with taps to FPGA ----
    ; CA bus passes through, series-R taps feed FPGA inputs.
    (net "DDR4_A0" (connections ("J1.A0" "R1.1" "U8.A0")))
    (net "DDR4_A0_TAP" (connections ("R1.2" "U1.IO_CA0")))
    (net "DDR4_A1" (connections ("J1.A1" "R2.1" "U8.A1")))
    (net "DDR4_A1_TAP" (connections ("R2.2" "U1.IO_CA1")))
    (net "DDR4_CK_T" (connections ("J1.CK_t" "R3.1" "U8.CK_t")))
    (net "DDR4_CK_T_TAP" (connections ("R3.2" "U1.IO_CK_T")))
    (net "DDR4_CK_C" (connections ("J1.CK_c" "R4.1" "U8.CK_c")))
    (net "DDR4_CK_C_TAP" (connections ("R4.2" "U1.IO_CK_C")))
    (net "DDR4_DQS0_T" (connections ("J1.DQS0_t" "R5.1" "U8.DQS0_t")))
    (net "DDR4_DQS0_T_TAP" (connections ("R5.2" "U1.IO_DQS_T")))
    (net "DDR4_DQ0" (connections ("J1.DQ0" "U1.IO_DQ0" "U8.DQ0")))
    (net "DDR4_DQ7" (connections ("J1.DQ7" "U1.IO_DQ7" "U8.DQ7")))
    (net "DDR4_DQ8" (connections ("J1.DQ8" "U1.IO_DQ8" "U8.DQ8")))
    (net "DDR4_DQ15" (connections ("J1.DQ15" "U1.IO_DQ15" "U8.DQ15")))

    ; ---- Host RESET# gating (MCU PA15 -> FET gate -> open-drain on RESET# line) ----
    (net "HOST_RESET_GATE" (connections ("U2.PA15" "Q1.G")))
    (net "DDR4_RESET" (connections ("J1.RESET#" "Q1.D" "U8.RESET#")))

    ; ---- FPGA <-> MCU SPI ----
    (net "SPI_SCK" (connections ("U2.PA5" "U1.SPI_SCK")))
    (net "SPI_MISO" (connections ("U2.PA6" "U1.SPI_MISO")))
    (net "SPI_MOSI" (connections ("U2.PA7" "U1.SPI_MOSI")))
    (net "SPI_CSN" (connections ("U2.PA4" "U1.SPI_CSN")))
    (net "FPGA_INTR_N" (connections ("U2.PB2" "U1.INTR_N")))
    (net "FPGA_PROG_N" (connections ("U2.PC5" "U1.PROG_B")))
    (net "FPGA_DONE" (connections ("U2.PC4" "U1.DONE")))
    (net "FPGA_INIT_N" (connections ("U2.PB6" "U1.INIT_B")))
    (net "FPGA_CCLK" (connections ("U2.PB7" "U1.CCLK")))
    (net "FPGA_DIN" (connections ("U2.PB4" "U1.DIN")))

    ; ---- FPGA bitstream flash (QSPI) ----
    (net "QSPI_CS" (connections ("U1.IO_CA2" "U7.CS#")))
    (net "QSPI_SCK" (connections ("U1.IO_CA3" "U7.SCK")))
    (net "QSPI_SI" (connections ("U1.IO_DQS_C" "U7.SI")))
    (net "QSPI_SO" (connections ("U7.SO" "U1.IO_DQ0")))

    ; ---- BLE UART ----
    (net "BLE_TX" (connections ("U3.UART_TX" "U2.PB9")))
    (net "BLE_RX" (connections ("U3.UART_RX" "U2.PB8")))

    ; ---- USB CDC ----
    (net "USB_DP" (connections ("J2.DP1" "U2.PA10")))
    (net "USB_DM" (connections ("J2.DM1" "U2.PA9")))

    ; ---- I2C (OLED + fuel gauge) ----
    (net "I2C_SCL" (connections ("U2.PB6" "U6.SCL" "D1.SCL")))
    (net "I2C_SDA" (connections ("U2.PB7" "U6.SDA" "D1.SDA")))
    (net "FUEL_ALRT" (connections ("U6.ALRT" "U2.PA2")))

    ; ---- SDIO ----
    (net "SD_CMD" (connections ("J3.CMD" "U2.PB4")))
    (net "SD_CLK" (connections ("J3.CLK" "U2.PB2")))
    (net "SD_D0" (connections ("J3.D0" "U2.PB14")))
    (net "SD_D1" (connections ("J3.D1" "U2.PB15")))
    (net "SD_D2" (connections ("J3.D2" "U2.PB10")))
    (net "SD_D3" (connections ("J3.D3" "U2.PB11")))

    ; ---- OLED reset ----
    (net "OLED_RES" (connections ("D1.RES" "U2.PA1")))

    ; ---- Mode button ----
    (net "BTN_MODE" (connections ("SW1.1" "U2.PA0")))

    ; ---- VDD sense ----
    (net "HOST_VDD_SENSE" (connections ("U2.PA3" "R_SENSE.1")))
  )

  ; ============================================================
  ; POWER RAILS / DECOUPLING (representative)
  ; ============================================================
  (power_rails
    (rail "VDD_1V2"  (voltage 1.2) (source "host DDR4 VDD passthrough"))
    (rail "VPP_2V5"  (voltage 2.5) (source "host DDR4 VPP passthrough"))
    (rail "VCC_1V0"  (voltage 1.0) (source "U5 TPS62110 from host VDD or battery"))
    (rail "VCC_3V3"  (voltage 3.3) (source "U4 TPS63020 from battery or USB"))
    (rail "VBAT_RAW" (voltage 3.7) (source "LiPo 500mAh"))
    (rail "VBUS_USB" (voltage 5.0) (source "USB-C"))
  )

  ; ============================================================
  ; NOTES
  ; ============================================================
  (notes
    "DRAM-Phantom v1.0 — DDR4 SO-DIMM interposer, 6-layer 0.8mm, 69.6x30mm + tail"
    "Author: jayis1 — CERN-OHL-S v2 / GPL-2.0"
    "CA/DQS taps via 22-33R series resistors; DQ taps direct (FPGA high-Z snoop)."
    "Master-mode CA drive gated by MCU holding host RESET# via Q1 (2N7002K open-drain)."
    "FPGA VCCO banks 14/15/16 at 1.2 V (DDR4 VDDQ). VCCINT 1.0 V from local buck."
    "Refresh watchdog (FPGA) re-arms REF command every tREFI autonomously."
  )
)