{
  "board": {
    "design": {
      "last_author": "jayis1",
      "settings": {
        "copper_edge_clearance": 0.12,
        "rule_severities": {
          "lib_symbol_issues": "warning",
          "same_local_global": "error",
          "track_dangling": "warning",
          "via_dangling": "warning",
          "unconnected_items": "error"
        }
      },
      "track_widths": [0.0, 0.08, 0.1, 0.12, 0.15, 0.2, 0.3, 0.5],
      "via_dimensions": [
        {"diameter": 0.45, "drill": 0.2},
        {"diameter": 0.5, "drill": 0.25},
        {"diameter": 0.6, "drill": 0.3}
      ],
      "diff_pair_dimensions": [
        {"width": 0.1, "gap": 0.08, "via_gap": 0.12}
      ],
      "layer_presets": [],
      "view": {
        "coords": {"x": 44, "y": 15},
        "zoom": 2.0
      }
    },
    "ipc2581": {
      "dist": "",
      "mfg": "",
      "mpn": "",
      "internal_id": "DRAM-Phantom-v1.0"
    },
    "metadata": {
      "filename": "device.kicad_pcb",
      "version": 1,
      "date": "2026-07-05",
      "author": "jayis1"
    },
    "setup": {
      "stackup": {
        "layers": [
          {"name": "F.Cu", "type": "copper", "thickness": 0.018},
          {"name": "F.Paste", "type": "solder-paste"},
          {"name": "F.SilkS", "type": "silk-screen"},
          {"name": "F.Mask", "type": "solder-mask"},
          {"name": "Dielectric.1", "type": "dielectric", "thickness": 0.1},
          {"name": "In1.Cu", "type": "copper", "thickness": 0.018},
          {"name": "Dielectric.2", "type": "dielectric", "thickness": 0.1},
          {"name": "In2.Cu", "type": "copper", "thickness": 0.018},
          {"name": "Dielectric.3", "type": "dielectric", "thickness": 0.2},
          {"name": "In3.Cu", "type": "copper", "thickness": 0.018},
          {"name": "Dielectric.4", "type": "dielectric", "thickness": 0.1},
          {"name": "In4.Cu", "type": "copper", "thickness": 0.018},
          {"name": "Dielectric.5", "type": "dielectric", "thickness": 0.08},
          {"name": "B.Mask", "type": "solder-mask"},
          {"name": "B.SilkS", "type": "silk-screen"},
          {"name": "B.Cu", "type": "copper", "thickness": 0.018}
        ]
      },
      "pad_to_mask_clearance": 0.05,
      "solder_mask_min_width": 0.05,
      "grid_origin": {"x": 0, "y": 0},
      "defaults": {
        "track_width": 0.1,
        "via_diameter": 0.45,
        "via_drill": 0.2,
        "copper_line_width": 0.08
      },
      "erc": {
        "enabled": true,
        "severity": {
          "unconnected_pin": "warning",
          "power_pin_not_driven": "error",
          "different_net_in_same_pin": "error"
        }
      },
      "drc": {
        "enabled": true,
        "rules": {
          "min_track_width": 0.08,
          "min_via_diameter": 0.4,
          "min_via_drill": 0.18,
          "min_clearance": 0.1,
          "min_copper_clearance": 0.1,
          "copper_edge_clearance": 0.15,
          "hole_to_hole_clearance": 0.2
        }
      }
    },
    "teardrops": {
      "enabled": true,
      "max_width": 0.4,
      "max_length": 0.4
    },
    "rules": {
      "impedance_controlled": true,
      "ddr4_ca_stub": {
        "max_stub_mm": 2.0,
        "series_resistor": "22-33R",
        "note": "CA/DQS taps via series-R to keep stub reflections within DDR4 budget at 3200 MT/s"
      }
    },
    "notes": [
      "DRAM-Phantom v1.0 — 6-layer 0.8mm board, 69.6x30mm SO-DIMM envelope + 20mm tail",
      "Author: jayis1 — CERN-OHL-S v2 / GPL-2.0",
      "In1.Cu = GND plane; In2.Cu = VDD_1V2 (DDR4 VDD passthrough);",
      "In3.Cu = VCC_3V3; In4.Cu = VCC_1V0 (FPGA core)",
      "DDR4 CA/DQS tapped via 22-33R series resistors; DQ direct-tap (FPGA high-Z snoop).",
      "Master-mode CA drive gated by MCU holding host RESET# via Q1 (2N7002K).",
      "FPGA VCCO banks 14/15/16 at 1.2 V (DDR4 VDDQ). VCCINT 1.0 V from local TPS62110."
    ]
  },
  "schematic": {
    "last_author": "jayis1",
    "metadata": {
      "filename": "device.kicad_sch",
      "date": "2026-07-05",
      "author": "jayis1"
    },
    "erc": {
      "enabled": true,
      "severity": {
        "pin_not_connected": "warning",
        "power_pin_not_driven": "error",
        "hierarchical_label_unmatched": "error"
      }
    },
    "annotation": {
      "method": "X-Y",
      "start": 1
    }
  },
  "libraries": {
    "paths": {
      "system": ["${KISYSMOD}", "${KISYS3DMOD}"],
      "project": ["symbols/dram-phantom.kicad_sym"]
    },
    "footprints": [
