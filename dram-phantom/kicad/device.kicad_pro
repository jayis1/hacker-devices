      {"name": "VQFN-16-1EP_3x3mm_P0.5mm", "lib": "Package_SON"},
      {"name": "TDFN-8-1EP_2x2mm_P0.5mm", "lib": "Package_DFN_QFN"},
      {"name": "SOIC-8_3.9x4.9mm_P1.27mm", "lib": "Package_SO"},
      {"name": "SO-DIMM-260-DDR4-Socket", "lib": "Connector_SODIMM"},
      {"name": "SO-DIMM-260-DDR4-Edge", "lib": "Connector_SODIMM"},
      {"name": "USB_C_Receptacle_HRO_TYPE-C-31-M-12", "lib": "Connector_USB"},
      {"name": "microSD_HC_Hirose_DM3D-SF", "lib": "Connector_Card"},
      {"name": "OLED_128x64_0.96in_I2C", "lib": "Display"},
      {"name": "SOT-23", "lib": "Package_TO_SOT_SMD"},
      {"name": "SW_SPST_B3SN-6_6x6mm", "lib": "Button_Switch_SMD"},
      {"name": "C_0402_1005Metric", "lib": "Capacitor_SMD"},
      {"name": "R_0402_1005Metric", "lib": "Resistor_SMD"}
    ]
