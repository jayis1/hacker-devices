  (footprint "RF_Module:Fanstel_BT840F"
    (layer "F.Cu")
    (at 80 8 0)
    (attr smd)
    (property "Reference" "U3" (at -7 -5))
    (property "Value" "BT840F" (at 0 6))
    (property "Author" "jayis1")
    (pad "1" smd rect (at -7 -4) (size 1 0.6) (layers "F.Cu" "F.Paste" "F.Mask"))
  )

  ; ---- U4: TPS63020 (VSON-14, 4x4mm) ----
  (footprint "Package_SON:VSON-14-1EP_4x4mm_P0.5mm"
