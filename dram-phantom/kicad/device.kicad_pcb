(kicad_pcb
  (version 20240108)
  (generator "kicad-pcb-tools")
  (generator_version "7.0")
  (general
    (thickness 0.8)
    (legacy_teardrops no)
  )
  (paper "A4")
  (title_block
    (title "DRAM-Phantom — DDR4 SO-DIMM Interposer for Memory Bus Security Research")
    (date "2026-07-05")
    (rev "1.0")
    (company "jayis1")
    (comment 1 "Author: jayis1")
    (comment 2 "License: CERN-OHL-S v2")
    (comment 3 "69.6 x 30 mm SO-DIMM envelope + 20mm tail, 6-layer, 0.8mm")
  )

  (layers
    (0 "F.Cu" signal)
    (1 "In1.Cu" signal "GND")
    (2 "In2.Cu" signal "VDD_1V2")
    (3 "In3.Cu" signal "VCC_3V3")
    (4 "In4.Cu" signal "VCC_1V0")
    (31 "B.Cu" signal)
    (32 "B.Adhes" user "B.Adhesive")
    (33 "F.Adhes" user "F.Adhesive")
    (34 "B.Paste" user)
    (35 "F.Paste" user)
    (36 "B.SilkS" user "B.Silkscreen")
    (37 "F.SilkS" user "F.Silkscreen")
    (38 "B.Mask" user)
    (39 "F.Mask" user)
    (40 "Dwgs.User" user "User.Drawings")
    (41 "Cmts.User" user "User.Comments")
    (42 "Eco1.User" user "User.Eco1")
    (43 "Eco2.User" user "User.Eco2")
    (44 "Edge.Cuts" user)
    (45 "Margin" user)
    (46 "B.CrtYd" user "B.Courtyard")
    (47 "F.CrtYd" user "F.Courtyard")
    (48 "B.Fab" user)
    (49 "F.Fab" user)
  )

  (setup
    (pad_to_mask_clearance 0.05)
    (solder_mask_min_width 0.05)
    (grid_origin (at 0 0))
    (stackup
      (layer "F.Cu" (type copper) (thickness 0.018))
      (layer "F.Paste" (type solder-paste))
      (layer "F.SilkS" (type silk-screen))
      (layer "F.Mask" (type solder-mask))
      (layer "Dielectric.1" (type dielectric) (thickness 0.1))
      (layer "In1.Cu" (type copper) (thickness 0.018))
      (layer "Dielectric.2" (type dielectric) (thickness 0.1))
      (layer "In2.Cu" (type copper) (thickness 0.018))
      (layer "Dielectric.3" (type dielectric) (thickness 0.2))
      (layer "In3.Cu" (type copper) (thickness 0.018))
      (layer "Dielectric.4" (type dielectric) (thickness 0.1))
      (layer "In4.Cu" (type copper) (thickness 0.018))
      (layer "Dielectric.5" (type dielectric) (thickness 0.08))
      (layer "B.Mask" (type solder-mask))
      (layer "B.SilkS" (type silk-screen))
      (layer "B.Cu" (type copper) (thickness 0.018))
    )
    (defaults
      (via (diameter 0.45) (drill 0.2))
      (track (width 0.1))
    )
  )

  ; ============================================================
  ; BOARD OUTLINE — DDR4 SO-DIMM envelope 69.6 x 30 mm + 20 mm tail
  ; The SO-DIMM edge fingers occupy the bottom 50mm of the left edge; the tail
  ; extends right for the FPGA/MCU cluster and connectors.
  ; ============================================================
  (gr_line (start 0 0) (end 89.6 0) (layer "Edge.Cuts") (width 0.12))
  (gr_line (start 89.6 0) (end 89.6 30) (layer "Edge.Cuts") (width 0.12))
  (gr_line (start 89.6 30) (end 0 30) (layer "Edge.Cuts") (width 0.12))
  (gr_line (start 0 30) (end 0 0) (layer "Edge.Cuts") (width 0.12))
  ; SO-DIMM notch (keying cutout at ~25mm and ~48mm from bottom edge)
  (gr_line (start 0 25) (end 2 25) (layer "Edge.Cuts") (width 0.12))
  (gr_line (start 2 25) (end 2 23) (layer "Edge.Cuts") (width 0.12))
  (gr_line (start 2 23) (end 0 23) (layer "Edge.Cuts") (width 0.12))
  (gr_line (start 0 48) (end 2 48) (layer "Edge.Cuts") (width 0.12))
  (gr_line (start 2 48) (end 2 46) (layer "Edge.Cuts") (width 0.12))
  (gr_line (start 2 46) (end 0 46) (layer "Edge.Cuts") (width 0.12))

  ; ============================================================
  ; FOOTPRINTS / PLACEMENT
  ; ============================================================

  ; ---- U1: Artix-7 XC7A100T (FGG484, 22x22mm, 1.0mm pitch) ----
  (footprint "Package_BGA:Xilinx_FGG484"
    (layer "F.Cu")
    (at 65 15 0)
    (attr smd)
    (property "Reference" "U1" (at -12 -12))
    (property "Value" "XC7A100T-FGG484I" (at 0 13))
    (property "Author" "jayis1")
    (pad "A1" smd circle (at -10.5 -10.5) (size 0.45 0.45) (layers "F.Cu" "F.Paste" "F.Mask"))
    (pad "A2" smd circle (at -9.5 -10.5) (size 0.45 0.45) (layers "F.Cu" "F.Paste" "F.Mask"))
    (pad "V22" smd circle (at 10.5 10.5) (size 0.45 0.45) (layers "F.Cu" "F.Paste" "F.Mask"))
    (model ":${KISYS3DMOD}/Package_BGA.3dshapes/Xilinx_FGG484.wrl")
  )

  ; ---- U2: STM32G474CEU6 (UFQFPN-48, 7x7mm) ----
  (footprint "Package_DFN_QFN:UFQFPN-48_7x7mm_P0.5mm"
