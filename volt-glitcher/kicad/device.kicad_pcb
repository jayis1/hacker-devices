  (setup
    (stack_remove_layer_range 1 31)
    (stack_add_layer In1.Cu signal)
    (stack_add_layer In2.Cu signal)
    (copper_trace_width 0.15)
    (copper_trace_width_min 0.1)
    (copper_trace_width_max 2.0)
    (clearance 0.15)
    (clearance_min 0.1)
    (zone_clearance 0.3)
    (pad_size 0.6 0.6)
    (pad_size_min 0.4 0.4)
    (solder_mask_margin 0.05)
    (solder_paste_margin 0.02)
    (via_size 0.6)
    (via_drill 0.3)
    (via_min_size 0.4)
    (via_min_drill 0.2)
    (blind_via_ratio 0.5)
    (micro_via_size 0.3)
    (micro_via_drill 0.1)
  )

  (net_class "Power" ""
    (trace_width 0.4)
    (via_dia 0.8)
    (via_drill 0.4)
    (clearance 0.2)
  )

  (net_class "Signal" ""
    (trace_width 0.15)
    (via_dia 0.6)
    (via_drill 0.3)
    (clearance 0.15)
