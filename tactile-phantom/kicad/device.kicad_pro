(kicad_pro
  (version 20230121)
  (generator "tactile-phantom")
  (generator_version "7.0")
  (general
    (name "Tactile-Phantom")
    (company "jayis1")
    (author "jayis1")
    (license "GPL-2.0")
    (comment "Touch-Controller Bus MITM Implant")
  )
  (board
    (layers
      (0 "F.Cu" signal "Top copper — components and high-speed traces")
      (1 "In1.Cu" signal "Inner 1 — GND plane")
      (2 "In2.Cu" signal "Inner 2 — VCC_3V3 plane")
      (31 "B.Cu" signal "Bottom copper — passive components and routing")
      (32 "B.Adhes" user "B.Adhesive")
      (33 "F.Adhes" user "F.Adhesive")
      (34 "B.Paste" user "B.Solder paste")
      (35 "F.Paste" user "F.Solder paste")
      (36 "B.SilkS" user "B.Silkscreen")
      (37 "F.SilkS" user "F.Silkscreen")
      (38 "B.Mask" user "B.Solder mask")
      (39 "F.Mask" user "F.Solder mask")
      (40 "Dwgs.User" user "User.Drawings")
      (41 "Cmts.User" user "User.Comments")
      (42 "Eco1.User" user "User.Eco1")
      (43 "Eco2.User" user "User.Eco2")
      (44 "Edge.Cuts" user "Board outline")
      (45 "Margin" user "Board margin")
      (46 "B.CrtYd" user "B.Courtyard")
      (47 "F.CrtYd" user "F.Courtyard")
      (48 "B.Fab" user "B.Fabrication")
      (49 "F.Fab" user "F.Fabrication")
    )
    (design_settings
      (defaults
        (board_outline_line_width 0.15)
        (board_outline_line_style "solid")
        (board_outline_line_color "#000000")
        (copper_line_width 0.1)
        (copper_line_style "solid")
        (copper_line_color "#000000")
        (via_drill 0.2)
        (via_size 0.45)
        (pad_drill 0.0)
        (pad_size 0.0)
        (solder_mask_clearance 0.05)
        (solder_paste_clearance 0.0)
        (solder_paste_ratio -0.05)
      )
      (rules
        (min_track_width 0.1)
        (min_via_diameter 0.3)
        (min_via_drill 0.2)
        (min_clearance 0.1)
        (min_hole_to_hole 0.2)
      )
      (trace_width
        (default 0.15)
        (power 0.3)
        (high_speed 0.12)
      )
      (via
        (default 0.45 0.2)
        (power 0.6 0.3)
      )
    )
    (setup
      (pcb_thickness 1.6)
      (copper_layers 4)
      (dielectric_layers 3)
      (dielectric_thickness 0.2 0.1 0.2)
    )
  )
  (schematic
    (default_line_width 0.15)
    (default_text_size 1.27)
    (default_text_color "#000000")
    (field_names
      ("Reference" "Ref")
      ("Value" "Val")
      ("Footprint" "FP")
      ("Datasheet" "DS")
      ("Author" "jayis1")
    )
  )
  (libraries
    (lib (name "MCU_RaspberryPi") (type "KiCad") (uri "${KICAD7_SYMBOL_DIR}/MCU_RaspberryPi.kicad_sym"))
    (lib (name "RF_Module") (type "KiCad") (uri "${KICAD7_SYMBOL_DIR}/RF_Module.kicad_sym"))
    (lib (name "Logic_LevelTranslator") (type "KiCad") (uri "${KICAD7_SYMBOL_DIR}/Logic_LevelTranslator.kicad_sym"))
    (lib (name "Connector") (type "KiCad") (uri "${KICAD7_SYMBOL_DIR}/Connector.kicad_sym"))
    (lib (name "Connector_Card") (type "KiCad") (uri "${KICAD7_SYMBOL_DIR}/Connector_Card.kicad_sym"))
    (lib (name "Connector_USB") (type "KiCad") (uri "${KICAD7_SYMBOL_DIR}/Connector_USB.kicad_sym"))
    (lib (name "Connector_FFC-FPC") (type "KiCad") (uri "${KICAD7_SYMBOL_DIR}/Connector_FFC-FPC.kicad_sym"))
    (lib (name "Display") (type "KiCad") (uri "${KICAD7_SYMBOL_DIR}/Display.kicad_sym"))
    (lib (name "Battery_Management") (type "KiCad") (uri "${KICAD7_SYMBOL_DIR}/Battery_Management.kicad_sym"))
    (lib (name "Sensor_Voltage") (type "KiCad") (uri "${KICAD7_SYMBOL_DIR}/Sensor_Voltage.kicad_sym"))
    (lib (name "LED_SMD") (type "KiCad") (uri "${KICAD7_SYMBOL_DIR}/LED_SMD.kicad_sym"))
    (lib (name "Capacitor_SMD") (type "KiCad") (uri "${KICAD7_SYMBOL_DIR}/Capacitor_SMD.kicad_sym"))
    (lib (name "Resistor_SMD") (type "KiCad") (uri "${KICAD7_SYMBOL_DIR}/Resistor_SMD.kicad_sym"))
    (lib (name "Button_Switch_SMD") (type "KiCad") (uri "${KICAD7_SYMBOL_DIR}/Button_Switch_SMD.kicad_sym"))
    (lib (name "Crystal") (type "KiCad") (uri "${KICAD7_SYMBOL_DIR}/Crystal.kicad_sym"))
    (lib (name "Package_DFN_QFN") (type "KiCad") (uri "${KICAD7_SYMBOL_DIR}/Package_DFN_QFN.kicad_sym"))
    (lib (name "Package_SO") (type "KiCad") (uri "${KICAD7_SYMBOL_DIR}/Package_SO.kicad_sym"))
    (lib (name "Package_TO_SOT_SMD") (type "KiCad") (uri "${KICAD7_SYMBOL_DIR}/Package_TO_SOT_SMD.kicad_sym"))
  )
  (meta
    (filename "tactile-phantom.kicad_pro")
    (title "Tactile-Phantom")
    (author "jayis1")
    (company "jayis1")
    (revision "1.0")
    (date "2026-06-27")
    (source "https://github.com/jayis1/hacker-devices")
    (license "GPL-2.0")
  )
)