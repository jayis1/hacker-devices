    (pad "7" smd roundrect (at -3.2 -0.2 0) (size 0.2 0.8) (layers "F.Cu" "F.Paste" "F.Mask") (net 7 "I2C_TGT_SCL"))
    (pad "8" smd roundrect (at -3.2 0.2 0) (size 0.2 0.8) (layers "F.Cu" "F.Paste" "F.Mask") (net 8 "I2C_HOST_SDA"))
    (pad "9" smd roundrect (at -3.2 0.6 0) (size 0.2 0.8) (layers "F.Cu" "F.Paste" "F.Mask") (net 9 "I2C_HOST_SCL"))
    (pad "10" smd roundrect (at -3.2 1.0 0) (size 0.2 0.8) (layers "F.Cu" "F.Paste" "F.Mask") (net 32 "INJ_SDA"))
    (pad "11" smd roundrect (at -3.2 1.4 0) (size 0.2 0.8) (layers "F.Cu" "F.Paste" "F.Mask") (net 33 "INJ_SCL"))
    (pad "12" smd roundrect (at -3.2 1.8 0) (size 0.2 0.8) (layers "F.Cu" "F.Paste" "F.Mask") (net 14 "SD_SPI_MISO"))
    (pad "13" smd roundrect (at -3.2 2.2 0) (size 0.2 0.8) (layers "F.Cu" "F.Paste" "F.Mask") (net 15 "SD_SPI_CS"))
    (pad "14" smd roundrect (at -3.2 2.6 0) (size 0.2 0.8) (layers "F.Cu" "F.Paste" "F.Mask") (net 12 "SD_SPI_CLK"))
    (pad "15" smd roundrect (at -3.2 3.0 0) (size 0.2 0.8) (layers "F.Cu" "F.Paste" "F.Mask") (net 13 "SD_SPI_MOSI"))
    ; Right side
    (pad "17" smd roundrect (at 3.2 -2.6 180) (size 0.2 0.8) (layers "F.Cu" "F.Paste" "F.Mask") (net 21 "LED_STATUS"))
    (pad "18" smd roundrect (at 3.2 -2.2 180) (size 0.2 0.8) (layers "F.Cu" "F.Paste" "F.Mask") (net 16 "OLED_SDA"))
    (pad "19" smd roundrect (at 3.2 -1.8 180) (size 0.2 0.8) (layers "F.Cu" "F.Paste" "F.Mask") (net 17 "OLED_SCL"))
    (pad "20" smd roundrect (at 3.2 -1.4 180) (size 0.2 0.8) (layers "F.Cu" "F.Paste" "F.Mask") (net 24 "ADC_TARGET"))
    (pad "21" smd roundrect (at 3.2 -1.0 180) (size 0.2 0.8) (layers "F.Cu" "F.Paste" "F.Mask") (net 25 "ADC_BATT"))
    (pad "22" smd roundrect (at 3.2 -0.6 180) (size 0.2 0.8) (layers "F.Cu" "F.Paste" "F.Mask") (net 31 "BUS_MODE"))
    (pad "23" smd roundrect (at 3.2 -0.2 180) (size 0.2 0.8) (layers "F.Cu" "F.Paste" "F.Mask") (net 20 "TXB_OE"))
    (pad "24" smd roundrect (at 3.2 0.2 180) (size 0.2 0.8) (layers "F.Cu" "F.Paste" "F.Mask") (net 30 "BOOT_BTN"))
    (pad "25" smd roundrect (at 3.2 0.6 180) (size 0.2 0.8) (layers "F.Cu" "F.Paste" "F.Mask") (net 23 "LED_USB"))
    (pad "26" smd roundrect (at 3.2 1.0 180) (size 0.2 0.8) (layers "F.Cu" "F.Paste" "F.Mask") (net 24 "ADC_TARGET"))
    (pad "27" smd roundrect (at 3.2 1.4 180) (size 0.2 0.8) (layers "F.Cu" "F.Paste" "F.Mask") (net 25 "ADC_BATT"))
    (pad "28" smd roundrect (at 3.2 1.8 180) (size 0.2 0.8) (layers "F.Cu" "F.Paste" "F.Mask") (net 1 "GND"))
    (pad "44" smd roundrect (at 3.2 2.6 180) (size 0.2 0.8) (layers "F.Cu" "F.Paste" "F.Mask") (net 2 "VCC_3V3"))
    (pad "45" smd roundrect (at 3.2 3.0 180) (size 0.2 0.8) (layers "F.Cu" "F.Paste" "F.Mask") (net 3 "VCC_1V1"))
    ; Thermal pad (exposed pad)
    (pad "57" smd roundrect (at 0 0 0) (size 5.6 5.6) (layers "F.Cu" "F.Paste" "F.Mask") (net 1 "GND"))
