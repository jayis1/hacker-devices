(kicad_pcb
  (version 20230121)
  (generator "tactile-phantom")
  (generator_version "7.0")
  (general
    (thickness 1.6)
    (legacy_teardrops no)
  )
  (paper "A4")
  (title_block
    (title "Tactile-Phantom — Touch-Controller Bus MITM Implant")
    (date "2026-06-27")
    (rev "1.0")
    (company "jayis1")
    (comment 1 "Author: jayis1")
    (comment 2 "License: GPL-2.0")
    (comment 3 "25mm x 35mm 4-layer PCB")
  )

  ; --- Layer stack ---
  (layers
    (0 "F.Cu" signal)
    (1 "In1.Cu" signal)
    (2 "In2.Cu" signal)
    (31 "B.Cu" signal)
    (32 "B.Adhes" user "B.Adhesive")
    (33 "F.Adhes" user "F.Adhesive")
    (34 "B.Paste" user)
    (35 "F.Paste" user)
    (36 "B.SilkS" user "B.Silkscreen")
    (37 "F.SilkS" user "F.Silkscreen")
    (38 "B.Mask" user)
    (39 "F.Mask" user)
    (40 "Dwgs.User" user "User.Drawings")
    (41 "Cmts.User" user "User.Comments")
    (42 "Eco1.User" user "User.Eco1")
    (43 "Eco2.User" user "User.Eco2")
    (44 "Edge.Cuts" user)
    (45 "Margin" user)
    (46 "B.CrtYd" user "B.Courtyard")
    (47 "F.CrtYd" user "F.Courtyard")
    (48 "B.Fab" user)
    (49 "F.Fab" user)
  )

  ; --- Board setup ---
  (setup
    (pad_to_mask_clearance 0.05)
    (pcbplotparams
      (layerselection 0x00010fc_ffffffff)
      (plot_on_all_layers_selection 0x0000000_00000000)
      (disableapertmacros no)
      (usegerberextensions no)
      (usegerberattributes yes)
      (usegerberadvancedattributes yes)
      (creategerberjobfile yes)
      (dashed_line_dash_ratio 12.000000)
      (dashed_line_gap_ratio 3.000000)
      (svgprecision 4)
      (plotframeref no)
      (mode 1)
      (useauxorigin no)
      (hpglpennumber 1)
      (hpglpenspeed 20)
      (hpglpendiameter 15.000000)
      (dxfpolygonmode yes)
      (dxfimperialunits no)
      (dxfusepcbnewfont yes)
      (psnegative no)
      (psa4output no)
      (plotreference yes)
      (plotvalue yes)
      (plotinvisibletext no)
      (sketchpadsonfab no)
      (subtractmaskfromsilk no)
      (outputformat 1)
      (mirror no)
      (drillshape 0)
      (scaleselection 1)
      (outputdirectory "gerbers/")
    )
  )

  ; --- Net definitions ---
  (net 0 "")
  (net 1 "GND")
  (net 2 "VCC_3V3")
  (net 3 "VCC_1V1")
  (net 4 "VBUS")
  (net 5 "VBAT")
  (net 6 "I2C_TGT_SDA")
  (net 7 "I2C_TGT_SCL")
  (net 8 "I2C_HOST_SDA")
  (net 9 "I2C_HOST_SCL")
  (net 10 "ESP_UART_TX")
  (net 11 "ESP_UART_RX")
  (net 12 "SD_SPI_CLK")
  (net 13 "SD_SPI_MOSI")
  (net 14 "SD_SPI_MISO")
  (net 15 "SD_SPI_CS")
  (net 16 "OLED_SDA")
  (net 17 "OLED_SCL")
  (net 18 "USB_D+")
  (net 19 "USB_D-")
  (net 20 "TXB_OE")
  (net 21 "LED_STATUS")
  (net 22 "LED_INJECT")
  (net 23 "LED_USB")
  (net 24 "ADC_TARGET")
  (net 25 "ADC_BATT")
  (net 26 "FPC_SDA")
  (net 27 "FPC_SCL")
  (net 28 "FPC_INT")
  (net 29 "FPC_RST")
  (net 30 "BOOT_BTN")
  (net 31 "BUS_MODE")
  (net 32 "INJ_SDA")
  (net 33 "INJ_SCL")

  ; --- Board outline: 25mm x 35mm ---
  ; Origin at (0,0), board extends to (25.0, 35.0) in mm
  (gr_line (start 0 0) (end 25 0)
    (stroke (width 0.15) (type default))
    (layer "Edge.Cuts")
  )
  (gr_line (start 25 0) (end 25 35)
    (stroke (width 0.15) (type default))
    (layer "Edge.Cuts")
  )
  (gr_line (start 25 35) (end 0 35)
    (stroke (width 0.15) (type default))
    (layer "Edge.Cuts")
  )
  (gr_line (start 0 35) (end 0 0)
    (stroke (width 0.15) (type default))
    (layer "Edge.Cuts")
  )

  ; --- FPC flex tail outline (12mm x 40mm, extending from top edge) ---
  (gr_line (start 6.5 0) (end 6.5 -40)
    (stroke (width 0.15) (type default))
    (layer "Edge.Cuts")
  )
  (gr_line (start 6.5 -40) (end 18.5 -40)
    (stroke (width 0.15) (type default))
    (layer "Edge.Cuts")
  )
  (gr_line (start 18.5 -40) (end 18.5 0)
    (stroke (width 0.15) (type default))
    (layer "Edge.Cuts")
  )

  ; --- Author / version silkscreen ---
  (gr_text "Tactile-Phantom v1.0\nAuthor: jayis1\nGPL-2.0"
    (at 12.5 32 0)
    (layer "B.SilkS")
    (effects (font (size 1.0 1.0) (thickness 0.15)))
  )

  ; --- Footprints ---

  ; RP2040 (QFN-56) at center of board
