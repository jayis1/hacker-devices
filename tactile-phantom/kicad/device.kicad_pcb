    (layer "F.Cu")
    (at 12.5 17.5 0)
    (property "Reference" "U1")
    (property "Value" "RP2040")
    (property "Author" "jayis1")
    ; Pads: 56 perimeter + 1 EP
    (pad "1" smd roundrect (at -3.2 -2.6 0) (size 0.2 0.8) (layers "F.Cu" "F.Paste" "F.Mask") (net 1 "GND"))
    (pad "2" smd roundrect (at -3.2 -2.2 0) (size 0.2 0.8) (layers "F.Cu" "F.Paste" "F.Mask") (net 10 "ESP_UART_TX"))
    (pad "3" smd roundrect (at -3.2 -1.8 0) (size 0.2 0.8) (layers "F.Cu" "F.Paste" "F.Mask") (net 11 "ESP_UART_RX"))
    (pad "4" smd roundrect (at -3.2 -1.4 0) (size 0.2 0.8) (layers "F.Cu" "F.Paste" "F.Mask") (net 10 "ESP_UART_TX"))
    (pad "5" smd roundrect (at -3.2 -1.0 0) (size 0.2 0.8) (layers "F.Cu" "F.Paste" "F.Mask") (net 11 "ESP_UART_RX"))
