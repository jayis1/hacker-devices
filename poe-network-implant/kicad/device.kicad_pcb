  )

  ;; Main DC-DC 48V→3.3V
  (module "Footprint:SOT-563-6" (at 12 16) (layer "F.Cu")
    (fp_text reference "U5" (at 0 -2) (layer "F.SilkS"))
    (pad 1 smd rect (at -0.95 -0.65) (size 0.5 0.35) (layers "F.Cu" "F.Paste" "F.Mask")
      (net 71 "VPOE_48V") (class "PoE Power"))
    (pad 2 smd rect (at 0 -0.65) (size 0.5 0.35) (layers "F.Cu" "F.Paste" "F.Mask")
      (net 5 "GND"))
    (pad 3 smd rect (at 0.95 -0.65) (size 0.5 0.35) (layers "F.Cu" "F.Paste" "F.Mask")
      (net 1 "VDD_3V3"))
    (pad 4 smd rect (at -0.95 0.65) (size 0.5 0.35) (layers "F.Cu" "F.Paste" "F.Mask"))
    (pad 5 smd rect (at 0 0.65) (size 0.5 0.35) (layers "F.Cu" "F.Paste" "F.Mask"))
    (pad 6 smd rect (at 0.95 0.65) (size 0.5 0.35) (layers "F.Cu" "F.Paste" "F.Mask")
      (net 5 "GND"))
  )

  ;; 1.2V Buck
  (module "Footprint:SOT-23-5" (at 14 16) (layer "F.Cu")
    (fp_text reference "U6" (at 0 -2) (layer "F.SilkS"))
  )

  ;; 1.8V Buck
  (module "Footprint:SOT-23-5" (at 16 16) (layer "F.Cu")
    (fp_text reference "U7" (at 0 -2) (layer "F.SilkS"))
  )

  ;; 2.5V Buck
  (module "Footprint:SOT-23-5" (at 18 16) (layer "F.Cu")
    (fp_text reference "U8" (at 0 -2) (layer "F.SilkS"))
  )

  ;; TVS Diode
  (module "Footprint:DO-214AA" (at 6 15) (layer "F.Cu")
    (fp_text reference "D1" (at 0 -2) (layer "F.SilkS"))
    (pad 1 smd rect (at -2.1 0) (size 1.5 2.3) (layers "F.Cu" "F.Paste" "F.Mask")
      (net 70 "POE_VIN_RAW") (class "PoE Power"))
    (pad 2 smd rect (at 2.1 0) (size 1.5 2.3) (layers "F.Cu" "F.Paste" "F.Mask")
      (net 5 "GND"))
  )

  ;; ESD protection
  (module "Footprint:SOT-143" (at 25 16) (layer "F.Cu")
    (fp_text reference "D2" (at 0 -2) (layer "F.SilkS"))
  )

  ;; Inductors
  (module "Footprint:3015" (at 10 17) (layer "F.Cu")
    (fp_text reference "L1" (at 0 -2) (layer "F.SilkS"))
    (property "Value" "4.7µH 1.5A"))
  )
  (module "Footprint:3015" (at 12 18) (layer "F.Cu")
    (fp_text reference "L2" (at 0 -2) (layer "F.SilkS"))
  )
  (module "Footprint:3015" (at 14 18) (layer "F.Cu")
    (fp_text reference "L3" (at 0 -2) (layer "F.SilkS"))
  )
  (module "Footprint:3015" (at 16 18) (layer "F.Cu")
    (fp_text reference "L4" (at 0 -2) (layer "F.SilkS"))
  )

  ;; Tactile switches
  (module "Footprint:B3U-1000P" (at 30 17) (layer "F.Cu")
    (fp_text reference "SW1" (at 0 -2) (layer "F.SilkS"))
    (pad 1 smd rect (at -1.5 0) (size 0.8 1.0) (layers "F.Cu" "F.Paste" "F.Mask")
      (net 90 "NRST"))
    (pad 2 smd rect (at 1.5 0) (size 0.8 1.0) (layers "F.Cu" "F.Paste" "F.Mask")
      (net 5 "GND"))
  )
  (module "Footprint:B3U-1000P" (at 32 17) (layer "F.Cu")
    (fp_text reference "SW2" (at 0 -2) (layer "F.SilkS"))
    (pad 1 smd rect (at -1.5 0) (size 0.8 1.0) (layers "F.Cu" "F.Paste" "F.Mask")
      (net 91 "BOOT0"))
    (pad 2 smd rect (at 1.5 0) (size 0.8 1.0) (layers "F.Cu" "F.Paste" "F.Mask")
      (net 5 "GND"))
  )

  ;; Crystals
  (module "Footprint:Crystal_SMD_ABM8" (at 17.5 7) (layer "F.Cu")
    (fp_text reference "Y1" (at 0 -2) (layer "F.SilkS"))
    (property "Value" "48.000MHz")
    (pad 1 smd rect (at -1.25 0) (size 1.0 1.8) (layers "F.Cu" "F.Paste" "F.Mask")
      (net "Y1_XI"))
    (pad 2 smd rect (at 1.25 0) (size 1.0 1.8) (layers "F.Cu" "F.Paste" "F.Mask")
      (net "Y1_XO"))
    (pad 3 smd rect (at -1.25 1.4) (size 1.0 0.4) (layers "F.Cu" "F.Paste" "F.Mask")
      (net 5 "GND"))
    (pad 4 smd rect (at 1.25 1.4) (size 1.0 0.4) (layers "F.Cu" "F.Paste" "F.Mask")
      (net 5 "GND"))
  )

  (module "Footprint:Crystal_SMD_ABM8" (at 20 8) (layer "F.Cu")
    (fp_text reference "Y2" (at 0 -2) (layer "F.SilkS"))
    (property "Value" "25.000MHz")
  )
  (module "Footprint:Crystal_SMD_3215" (at 22 8) (layer "F.Cu")
    (fp_text reference "Y3" (at 0 -2) (layer "F.SilkS"))
    (property "Value" "32.768kHz")
  )
  (module "Footprint:Crystal_SMD_ABM8" (at 29 12) (layer "F.Cu")
    (fp_text reference "Y4" (at 0 -2) (layer "F.SilkS"))
    (property "Value" "32.000MHz")
  )

  ============================================================
  -- Zones (Power Planes)
  ============================================================
  ;; L2 Ground Plane (solid, entire layer)
  (zone (net 5 "GND") (net_name "GND") (layer "In1.Cu")
    (hatch edge 0.5)
    (connect_pads (mode solid))
    (fill (mode solid))
    (polygon (pts (xy 0.5 0.5) (xy 34.5 0.5) (xy 34.5 19.5) (xy 0.5 19.5)))
  )

  ;; L3 Power Plane - VPOE 48V (left section)
  (zone (net 71 "VPOE_48V") (net_name "VPOE_48V") (layer "In2.Cu")
    (hatch edge 0.5)
    (connect_pads (mode solid))
    (fill (mode solid))
    (polygon (pts (xy 0.5 0.5) (xy 15 0.5) (xy 15 19.5) (xy 0.5 19.5)))
  )

  ;; L3 Power Plane - VDD_3V3 (center section)
  (zone (net 1 "VDD_3V3") (net_name "VDD_3V3") (layer "In2.Cu")
    (hatch edge 0.5)
    (connect_pads (mode solid))
    (fill (mode solid))
    (polygon (pts (xy 15.5 0.5) (xy 25 0.5) (xy 25 19.5) (xy 15.5 19.5)))
  )

  ;; L3 Power Plane - VDD_1V2 (right section)
  (zone (net 2 "VDD_1V2") (net_name "VDD_1V2") (layer "In2.Cu")
    (hatch edge 0.5)
    (connect_pads (mode solid))
    (fill (mode solid))
    (polygon (pts (xy 25.5 0.5) (xy 34.5 0.5) (xy 34.5 19.5) (xy 25.5 19.5)))
  )

  ;; Bottom copper pour for BLE antenna keepout clearance
  (zone (net 0 "") (net_name "") (layer "B.Cu")
    (hatch edge 0.5)
    (connect_pads (mode none))
    (fill (mode none))
    (polygon (pts (xy 25 11) (xy 34 11) (xy 34 17) (xy 25 17)))
    (property "keepout" "true")
  )
)