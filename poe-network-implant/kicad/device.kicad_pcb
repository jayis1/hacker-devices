    (pad 44 smd rect (at 2.0 5.5) (size 1.5 0.25) (layers "F.Cu" "F.Paste" "F.Mask")
      (net 20 "ETH_RXD0"))
    (pad 45 smd rect (at 2.5 5.5) (size 1.5 0.25) (layers "F.Cu" "F.Paste" "F.Mask")
      (net 21 "ETH_RXD1"))
    (pad 46 smd rect (at 3.0 5.5) (size 1.5 0.25) (layers "F.Cu" "F.Paste" "F.Mask")
      (net 22 "ETH_RXD2"))
    (pad 47 smd rect (at 3.5 5.5) (size 1.5 0.25) (layers "F.Cu" "F.Paste" "F.Mask")
      (net 23 "ETH_RXD3"))
    (pad 48 smd rect (at 4.0 5.5) (size 1.5 0.25) (layers "F.Cu" "F.Paste" "F.Mask")
      (net 24 "ETH_RXCTL"))
    (pad 49 smd rect (at 4.5 5.5) (size 1.5 0.25) (layers "F.Cu" "F.Paste" "F.Mask")
      (net 25 "ETH_RXCLK"))
    ;; System pins
    (pad 7 smd rect (at -4.5 -5.0) (size 0.25 1.5) (layers "F.Cu" "F.Paste" "F.Mask")
      (net 1 "VDD_3V3"))
    (pad 8 smd rect (at -4.5 -4.5) (size 0.25 1.5) (layers "F.Cu" "F.Paste" "F.Mask")
      (net 5 "GND"))
    (pad 19 smd rect (at -4.5 0.0) (size 0.25 1.5) (layers "F.Cu" "F.Paste" "F.Mask")
      (net 90 "NRST"))
    (pad 20 smd rect (at -4.5 0.5) (size 0.25 1.5) (layers "F.Cu" "F.Paste" "F.Mask")
      (net 91 "BOOT0"))
  )

  ;; SDRAM IS42S32800G
  (module "Footprint:VFBGA-54_8x13mm_P0.8mm" (at 17.5 18) (layer "F.Cu")
    (fp_text reference "U9" (at 0 0) (layer "F.SilkS"))
  )

  ;; SPI Flash W25Q128JVSIQ
  (module "Footprint:SOIC-8_5x6mm_P1.27mm" (at 25 18) (layer "F.Cu")
    (fp_text reference "U10" (at 0 -4) (layer "F.SilkS"))
    (pad 1 smd rect (at -1.905 -2.7) (size 0.6 1.5) (layers "F.Cu" "F.Paste" "F.Mask")
      (net 63 "FLASH_CS#"))
    (pad 2 smd rect (at -0.635 -2.7) (size 0.6 1.5) (layers "F.Cu" "F.Paste" "F.Mask")
      (net 62 "FLASH_MISO"))
    (pad 3 smd rect (at 0.635 -2.7) (size 0.6 1.5) (layers "F.Cu" "F.Paste" "F.Mask")
      (net 5 "GND"))  ;; WP# tied low
    (pad 4 smd rect (at 1.905 -2.7) (size 0.6 1.5) (layers "F.Cu" "F.Paste" "F.Mask")
      (net 5 "GND"))
    (pad 5 smd rect (at 1.905 2.7) (size 0.6 1.5) (layers "F.Cu" "F.Paste" "F.Mask")
      (net 61 "FLASH_MOSI"))
    (pad 6 smd rect (at 0.635 2.7) (size 0.6 1.5) (layers "F.Cu" "F.Paste" "F.Mask")
      (net 60 "FLASH_SCK"))
    (pad 7 smd rect (at -0.635 2.7) (size 0.6 1.5) (layers "F.Cu" "F.Paste" "F.Mask")
      (net 1 "VDD_3V3"))  ;; HOLD# tied high
    (pad 8 smd rect (at -1.905 2.7) (size 0.6 1.5) (layers "F.Cu" "F.Paste" "F.Mask")
      (net 1 "VDD_3V3"))
  )

  ;; BLE Module nRF52832
  (module "Footprint:QFN-48_6x6mm_P0.4mm" (at 28 14) (layer "F.Cu")
