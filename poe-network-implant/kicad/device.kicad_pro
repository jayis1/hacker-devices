(kicad_pro (version 20241128)
  (generator "planner")
  (general
    (thickness 1.6)
  )
  (paper "A4")
  (title_block
    (title "PhantomBridge - PoE Network Implant")
    (date "2026-06-15")
    (rev "1.0")
    (company "Hacker Devices")
  )
  (net_class "default"
    (clearance 0.2)
    (trace_width 0.25)
    (via_dia 0.8)
    (via_drill 0.4)
    (uvia_dia 0.3)
    (uvia_drill 0.1)
  )
  (net_class "100Ω Diff"
    (clearance 0.5)
    (trace_width 0.127)
    (via_dia 0.45)
    (via_drill 0.2)
    (diff_pair_gap 0.178)
    (diff_pair_width 0.127)
  )
  (net_class "50Ω SE"
    (clearance 0.2)
    (trace_width 0.249)
    (via_dia 0.45)
    (via_drill 0.2)
  )
  (net_class "PoE Power"
    (clearance 0.5)
    (trace_width 1.0)
    (via_dia 0.8)
    (via_drill 0.5)
  )
  (net_class "SDRAM"
    (clearance 0.15)
    (trace_width 0.15)
    (via_dia 0.45)
    (via_drill 0.2)
  )
  (design_settings
    (defaults
      (pad_clearance 0.2)
      (pad_paste_margin -0.05)
      (pad_paste_margin_ratio 0)
      (pad_solder_mask_margin 0.05)
    )
    (pad_size 1.5 0.5)
    (solder_paste_clearance -0.05)
    (solder_paste_margin_ratio 0)
  )
  (layers
    (0 "F.Cu" signal)
    (1 "In1.Cu" power)
    (2 "In2.Cu" power)
    (31 "B.Cu" signal)
    (32 "B.Adhes" user)
    (33 "F.Adhes" user)
    (34 "B.Paste" user)
    (35 "F.Paste" user)
    (36 "B.SilkS" user)
    (37 "F.SilkS" user)
    (38 "B.Mask" user)
    (39 "F.Mask" user)
    (40 "Dwgs.User" user)
    (41 "Cmts.User" user)
    (42 "Eco1.User" user)
    (43 "Eco2.User" user)
    (44 "Edge.Cuts" user)
    (45 "Margin" user)
    (46 "B.CrtYd" user)
    (47 "F.CrtYd" user)
    (48 "B.Fab" user)
    (49 "F.Fab" user)
  )
  (setup
    (stackup
      (layer 0 "F.Cu" copper F)
      (layer 1 "Prepreg" dielectric)
      (layer 2 "In1.Cu" copper In1)
      (layer 3 "Core" dielectric)
      (layer 4 "In2.Cu" copper In2)
      (layer 5 "Prepreg" dielectric)
      (layer 6 "B.Cu" copper B)
    )
    (pad_to_mask_clearance 0.05)
    (solder_mask_min_width 0.1)
    (pad_to_paste_clearance -0.05)
    (board_outline_thickness 1.6)
  )
  (rules
    (rule "Ethernet diff pair length match"
      (condition "A.net_class == '100Ω Diff'")
      (constraint length_tolerance)
      (value 0.127)
    )
    (rule "RGMII length match"
      (condition "A.net_class == '50Ω SE' && A.name =~ 'RGMII'")
      (constraint length_tolerance)
      (value 1.27)
    )
  )
  (libraries
    (lib "Symbol:STM32H743ZIT6")
    (lib "Symbol:KSZ9897R")
    (lib "Symbol:TPS2378DDW")
    (lib "Symbol:TPS62A02A")
    (lib "Symbol:IS42S32800G")
    (lib "Symbol:W25Q128JVSIQ")
    (lib "Symbol:nRF52832-QFAA")
    (lib "Symbol:HX6096FNL")
    (lib "Symbol:SJ45520N")
    (lib "Footprint:LQFP-144_10x10mm_P0.5mm")
    (lib "Footprint:QFN-128_12x12mm_P0.4mm")
    (lib "Footprint:TSSOP-20_6.5x6.5mm_P0.65mm")
    (lib "Footprint:VFBGA-54_8x13mm_P0.8mm")
    (lib "Footprint:QFN-48_6x6mm_P0.4mm")
    (lib "Footprint:SOIC-8_5x6mm_P1.27mm")
  )
)