  (symbol (lib_name "LED_RGB_APTD3216") (in_bom yes) (on_board yes)
    (property (name "Reference") "LED1")
    (property (name "Value") "RGB_SMD")
    (property (name "Footprint") "LED_SMD:LED_0603_1608Metric")
    (pin "1" (uuid "p-led-r") (electrical_type passive) (name "R_ANODE"))
    (pin "2" (uuid "p-led-g") (electrical_type passive) (name "G_ANODE"))
    (pin "3" (uuid "p-led-b-c") (electrical_type passive) (name "COMMON_CATHODE"))
    (pin "4" (uuid "p-led-b") (electrical_type passive) (name "B_ANODE"))
  )

  ; User button
  (symbol (lib_name "Switch_Tactile_SMD") (in_bom yes) (on_board yes)
    (property (name "Reference") "SW1")
    (property (name "Value") "USER_BTN")
    (property (name "Footprint") "Button_Switch_SMD:SW_SPST_TL3342")
    (pin "1" (uuid "p-btn-1") (electrical_type passive) (name "1"))
    (pin "2" (uuid "p-btn-2") (electrical_type passive) (name "2"))
  )

  ; ── Nets / Wiring ──────────────────────────────────────────────────────────

  (net (net_id 1) (net_name "VCC_3V3"))
  (net (net_id 2) (net_name "VCC_1V2_FPGA"))
  (net (net_id 3) (net_name "VCC_5V_USB"))
  (net (net_id 4) (net_name "GND"))
  (net (net_id 5) (net_name "JTAG_TCK"))
  (net (net_id 6) (net_name "JTAG_TMS"))
  (net (net_id 7) (net_name "JTAG_TDI"))
  (net (net_id 8) (net_name "JTAG_TDO"))
  (net (net_id 9) (net_name "JTAG_nTRST"))
  (net (net_id 10) (net_name "JTAG_nSRST"))
  (net (net_id 11) (net_name "SWD_SWCLK"))
  (net (net_id 12) (net_name "SWD_SWDIO"))
  (net (net_id 13) (net_name "FPGA_CS"))
  (net (net_id 14) (net_name "FPGA_SCK"))
  (net (net_id 15) (net_name "FPGA_MOSI"))
  (net (net_id 16) (net_name "FPGA_MISO"))
  (net (net_id 17) (net_name "FPGA_CRESET"))
  (net (net_id 18) (net_name "FPGA_CDONE"))
  (net (net_id 19) (net_name "FPGA_IRQ"))
  (net (net_id 20) (net_name "USB_DP"))
  (net (net_id 21) (net_name "USB_DN"))
  (net (net_id 22) (net_name "VBUS"))
  (net (net_id 23) (net_name "SD_CMD"))
  (net (net_id 24) (net_name "SD_CK"))
  (net (net_id 25) (net_name "SD_D0"))
  (net (net_id 26) (net_name "SD_D1"))
  (net (net_id 27) (net_name "SD_D2"))
  (net (net_id 28) (net_name "SD_D3"))
  (net (net_id 29) (net_name "TARGET_VREF"))
  (net (net_id 30) (net_name "TARGET_CURRENT"))
  (net (net_id 31) (net_name "I2C1_SCL"))
  (net (net_id 32) (net_name "I2C1_SDA"))
  (net (net_id 33) (net_name "OSC_IN"))
  (net (net_id 34) (net_name "OSC_OUT"))
  (net (net_id 35) (net_name "LED_R"))
  (net (net_id 36) (net_name "LED_G"))
  (net (net_id 37) (net_name "LED_B"))
  (net (net_id 38) (net_name "USER_BTN"))
  (net (net_id 39) (net_name "MPIO_GROUP_1"))

  ; Power connections
  (wire (net 1) (pts (xy 100 50) (xy 500 50)))
  (wire (net 2) (pts (xy 100 100) (xy 500 100)))
  (wire (net 3) (pts (xy 100 150) (xy 500 150)))
  (wire (net 4) (pts (xy 100 200) (xy 500 200)))

  ; JTAG connections
  (wire (net 5) (pts (xy 600 300) (xy 750 300)))
  (wire (net 6) (pts (xy 600 320) (xy 750 320)))
  (wire (net 7) (pts (xy 600 340) (xy 750 340)))
  (wire (net 8) (pts (xy 600 360) (xy 750 360)))
  (wire (net 9) (pts (xy 600 380) (xy 750 380)))
  (wire (net 10) (pts (xy 600 400) (xy 750 400)))

  ; FPGA bridge connections
  (wire (net 13) (pts (xy 800 300) (xy 950 300)))
  (wire (net 14) (pts (xy 800 320) (xy 950 320)))
  (wire (net 15) (pts (xy 800 340) (xy 950 340)))
  (wire (net 16) (pts (xy 800 360) (xy 950 360)))
  (wire (net 17) (pts (xy 800 380) (xy 950 380)))
  (wire (net 18) (pts (xy 800 400) (xy 950 400)))
  (wire (net 19) (pts (xy 800 420) (xy 950 420)))

  ; USB connections
  (wire (net 20) (pts (xy 100 500) (xy 300 500)))
  (wire (net 21) (pts (xy 100 520) (xy 300 520)))
  (wire (net 22) (pts (xy 100 540) (xy 300 540)))

  ; I2C for current sensor
  (wire (net 31) (pts (xy 400 600) (xy 550 600)))
  (wire (net 32) (pts (xy 400 620) (xy 550 620)))

  ; Hierarchical labels
  (label "VCC_3V3" (at (xy 50 50)) (net 1))
  (label "VCC_1V2_FPGA" (at (xy 50 100)) (net 2))
  (label "VCC_5V_USB" (at (xy 50 150)) (net 3))
  (label "GND" (at (xy 50 200)) (net 4))

  ; Bus for MPIO channels
  (bus (pts (xy 1000 100) (xy 1100 100) (xy 1100 600) (xy 1000 600)))
  (bus_entry (at (xy 1000 100)) (net 39))
)