        {"pin": 13, "signal": "SATA_12V"},
        {"pin": 14, "signal": "SATA_12V"},
        {"pin": 15, "signal": "GND"},
        {"pin": 16, "signal": "SATA_HP_B+"},
        {"pin": 17, "signal": "SATA_HP_B-"},
        {"pin": 18, "signal": "GND"},
