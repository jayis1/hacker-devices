{
  "meta": {
    "author": "jayis1",
    "version": "1.0.0",
    "date": "2025-06-16",
    "description": "SATA Phantom — SATA Bus Interposer for Security Research"
  },
  "project": {
    "name": "sata-phantom",
    "title": "SATA Phantom — SATA Bus Interposer",
    "company": "jayis1",
    "revision": "1.0",
    "board": {
      "width_mm": 48.0,
      "height_mm": 28.0,
      "layers": 4,
      "thickness_mm": 0.8,
      "finish": "ENIG",
      "impedance_ohm": 100
    },
    "design_rules": {
      "min_trace_mm": 0.15,
      "min_via_mm": 0.3,
      "min_clearance_mm": 0.15,
      "min_hole_mm": 0.25
    }
  },
  "design_blocks": [
    {
      "ref": "U1",
      "value": "GW1N-LV1",
      "package": "QFN48",
      "manufacturer": "Gowin Semiconductor",
      "description": "FPGA — SATA PHY and link-layer frame processor",
      "supply_3v3": ["VCCIO", "VCC"],
      "supply_1v2": ["VCCINT", "VCCAUX"],
      "pins": {
        "total": 48,
        "digital_io": 36,
        "special": ["SATA_RX_P", "SATA_RX_N", "SATA_TX_P", "SATA_TX_N", "SPI_MOSI", "SPI_MISO", "SPI_SCLK", "SPI_CS", "IRQ_OUT", "DONE", "RESET_IN"]
      }
    },
    {
      "ref": "U2",
      "value": "ESP32-S3-WROOM-1",
      "package": "SMD-41",
      "manufacturer": "Espressif",
      "description": "MCU — System controller, C2, exfiltration",
      "supply_3v3": ["VDD"],
      "features": ["WiFi 2.4GHz", "BLE 5.0", "2× Xtensa LX7 @ 240 MHz", "16 MB Flash", "512 KB SRAM"],
      "interfaces": ["SPI (FPGA)", "UART (debug)", "I2C (battery)", "GPIO (e-Paper, LEDs, power)"]
    },
    {
      "ref": "U3",
      "value": "SN75LVCP601",
      "package": "WQFN-24",
      "manufacturer": "Texas Instruments",
      "description": "2:1 SATA Redriver/MUX — Host-side differential pair",
      "supply_3v3": ["VDD"],
      "channels": 2,
      "data_rate_gbps": 6.0,
      "pins": {
        "mux_sel": "GPIO from FPGA",
        "sata_in_p": "SATA_HSIP",
        "sata_in_n": "SATA_HSIN",
        "sata_out_p": "SATA_HSOP",
        "sata_out_n": "SATA_HSON"
      }
    },
    {
      "ref": "U4",
      "value": "SN75LVCP601",
      "package": "WQFN-24",
      "manufacturer": "Texas Instruments",
      "description": "2:1 SATA Redriver/MUX — Drive-side differential pair",
      "supply_3v3": ["VDD"],
      "channels": 2,
      "data_rate_gbps": 6.0,
      "pins": {
        "mux_sel": "GPIO from FPGA",
        "sata_in_p": "SATA_DSIP",
        "sata_in_n": "SATA_DSIN",
        "sata_out_p": "SATA_DSOP",
        "sata_out_n": "SATA_DSON"
      }
    },
    {
      "ref": "U5",
      "value": "TPS62065",
      "package": "VSON-8",
      "manufacturer": "Texas Instruments",
      "description": "3.3V Buck Converter — SATA 5V/12V to 3.3V rail",
      "input": "SATA_5V or SATA_12V",
      "output": "3.3V @ 2A",
      "efficiency_pct": 95,
      "switching_freq_khz": 3000,
      "passives": ["L1=2.2µH", "C1=22µF input", "C2=22µF output", "R1=10kΩ FB top", "R2=10kΩ FB bot"]
    },
    {
      "ref": "U6",
      "value": "TPS74801T",
      "package": "WSON-8",
      "manufacturer": "Texas Instruments",
      "description": "1.2V LDO — FPGA core voltage",
      "input": "3.3V",
      "output": "1.2V @ 1.5A",
      "dropout_mv": 130,
      "passives": ["C1=10µF input", "C2=10µF output", "R1=10kΩ FB top", "R2=4.99kΩ FB bot"]
    },
    {
      "ref": "U7",
      "value": "MAX17048",
      "package": "8-WLP",
      "manufacturer": "Maxim Integrated",
      "description": "Battery fuel gauge — LiPo monitor",
      "i2c_addr": "0x36",
      "interface": "I2C (SDA, SCL)",
      "alert_pin": "GPIO to ESP32 (INTERRUPT)"
    },
    {
      "ref": "U8",
      "value": "W25Q64JV",
      "package": "SOIC-8",
      "manufacturer": "Winbond",
      "description": "64 Mbit SPI Flash — FPGA configuration + firmware storage",
      "interface": "SPI (CLK, MOSI, MISO, CS)",
      "connected_to": "FPGA (primary), ESP32 (secondary, for firmware OTA)"
    },
    {
      "ref": "U9",
      "value": "CP2102N",
      "package": "QFN-28",
      "manufacturer": "Silicon Labs",
      "description": "USB-to-UART Bridge — Debug console",
      "interface": "USB-C ↔ UART (TX/RX to ESP32)",
      "features": ["USB 2.0 Full Speed", "Hardware flow control", "Baud up to 3 Mbps"]
    },
    {
      "ref": "U10",
      "value": "SiT9120",
      "package": "QFN-6",
      "manufacturer": "SiTime",
      "description": "25.000 MHz MEMS Oscillator — Reference clock for SATA PLL",
      "frequency_mhz": 25.0,
      "stability_ppm": 10,
      "output_type": "LVCMOS",
      "connected_to": "FPGA clock input"
    },
    {
      "ref": "U11",
      "value": "SiT9120",
      "package": "QFN-6",
      "manufacturer": "SiTime",
      "description": "40.000 MHz MEMS Oscillator — ESP32 external clock",
      "frequency_mhz": 40.0,
      "stability_ppm": 10,
      "connected_to": "ESP32-S3 XTAL input"
    },
    {
      "ref": "U12",
      "value": "GDEH0154D67",
      "package": "FPC-24",
      "manufacturer": "Waveshare / Goodisplay",
      "description": "1.54\" e-Paper Display — Status output",
      "resolution": "200×200",
      "interface": "SPI (MOSI, SCLK, CS, DC, BUSY, RESET)"
    },
    {
      "ref": "J1",
      "value": "SATA 22-pin Receptacle (Host)",
      "description": "SATA connector — connects to host motherboard/controller",
      "pins": [
        {"pin": 1, "signal": "GND"},
        {"pin": 2, "signal": "SATA_HP_A+"},
        {"pin": 3, "signal": "SATA_HP_A-"},
        {"pin": 4, "signal": "GND"},
        {"pin": 5, "signal": "SATA_HP_B-"},
        {"pin": 6, "signal": "SATA_HP_B+"},
        {"pin": 7, "signal": "GND"},
        {"pin": 8, "signal": "SATA_5V"},
        {"pin": 9, "signal": "SATA_5V"},
