  "netlist": [
    {"net": "GND", "type": "power", "connections": ["J1.GND", "J2.GND", "U1.GND", "U2.GND", "U3.GND", "U4.GND", "U5.GND", "U6.GND", "U7.GND", "U8.GND", "U9.GND", "U10.GND", "U11.GND", "U12.GND", "BAT1.GND", "LED1.GND", "C1-C30.GND"]},
    {"net": "VCC_3V3", "type": "power", "connections": ["U5.OUT", "U1.VCCIO", "U2.VDD", "U3.VDD", "U4.VDD", "U7.VDD", "U8.VCC", "U9.VDD", "U10.VDD", "U11.VDD", "LED1.VCC", "R1-R20.PULLUP"]},
    {"net": "VCC_1V2", "type": "power", "connections": ["U6.OUT", "U1.VCCINT", "U1.VCCAUX"]},
    {"net": "SATA_5V", "type": "power", "connections": ["J1.8", "J1.9", "J2.8", "J2.9", "U5.IN"]},
    {"net": "SATA_12V", "type": "power", "connections": ["J1.13", "J1.14", "J2.13", "J2.14", "U5.IN (via UVLO)"]},
    {"net": "VBUS_USB", "type": "power", "connections": ["J3.VBUS", "U9.VBUS", "U5.IN (via OR-ing)"]},
    {"net": "BAT_PLUS", "type": "power", "connections": ["BAT1.POS", "U7.BAT", "U5.IN (via boost)"]},
    {"net": "SATA_HP_A+", "type": "high_speed_diff", "impedance": 100, "connections": ["J1.2", "U3.SATA_IN_P"]},
    {"net": "SATA_HP_A-", "type": "high_speed_diff", "impedance": 100, "connections": ["J1.3", "U3.SATA_IN_N"]},
    {"net": "SATA_HP_B+", "type": "high_speed_diff", "impedance": 100, "connections": ["J1.6", "J1.16", "U3.SATA_IN_P"]},
    {"net": "SATA_HP_B-", "type": "high_speed_diff", "impedance": 100, "connections": ["J1.5", "J1.17", "U3.SATA_IN_N"]},
    {"net": "SATA_DP_A+", "type": "high_speed_diff", "impedance": 100, "connections": ["J2.2", "U4.SATA_OUT_P"]},
    {"net": "SATA_DP_A-", "type": "high_speed_diff", "impedance": 100, "connections": ["J2.3", "U4.SATA_OUT_N"]},
    {"net": "SATA_DP_B+", "type": "high_speed_diff", "impedance": 100, "connections": ["J2.6", "J2.16", "U4.SATA_OUT_P"]},
    {"net": "SATA_DP_B-", "type": "high_speed_diff", "impedance": 100, "connections": ["J2.5", "J2.17", "U4.SATA_OUT_N"]},
    {"net": "FPGA_SATA_TX+", "type": "high_speed_diff", "impedance": 100, "connections": ["U1.SATA_TX_P", "U3.SATA_OUT_P"]},
    {"net": "FPGA_SATA_TX-", "type": "high_speed_diff", "impedance": 100, "connections": ["U1.SATA_TX_N", "U3.SATA_OUT_N"]},
    {"net": "FPGA_SATA_RX+", "type": "high_speed_diff", "impedance": 100, "connections": ["U1.SATA_RX_P", "U4.SATA_IN_P"]},
    {"net": "FPGA_SATA_RX-", "type": "high_speed_diff", "impedance": 100, "connections": ["U1.SATA_RX_N", "U4.SATA_IN_N"]},
    {"net": "SPI_MOSI", "type": "digital", "connections": ["U2.GPIO11", "U1.SPI_MOSI", "U8.MOSI"]},
    {"net": "SPI_MISO", "type": "digital", "connections": ["U2.GPIO12", "U1.SPI_MISO", "U8.MISO"]},
    {"net": "SPI_SCLK", "type": "digital", "connections": ["U2.GPIO13", "U1.SPI_SCLK", "U8.CLK"]},
    {"net": "SPI_CS_FPGA", "type": "digital", "connections": ["U2.GPIO10", "U1.SPI_CS"]},
    {"net": "SPI_CS_FLASH", "type": "digital", "connections": ["U2.GPIO4", "U8.CS"]},
    {"net": "FPGA_IRQ", "type": "digital", "connections": ["U1.IRQ_OUT", "U2.GPIO14"]},
    {"net": "FPGA_RESET", "type": "digital", "connections": ["U2.GPIO15", "U1.RESET_IN"]},
    {"net": "FPGA_DONE", "type": "digital", "connections": ["U1.DONE", "U2.GPIO17"]},
    {"net": "EPD_MOSI", "type": "digital", "connections": ["U2.GPIO46", "U12.MOSI"]},
    {"net": "EPD_SCLK", "type": "digital", "connections": ["U2.GPIO3", "U12.SCLK"]},
    {"net": "EPD_CS", "type": "digital", "connections": ["U2.GPIO9", "U12.CS"]},
    {"net": "EPD_DC", "type": "digital", "connections": ["U2.GPIO18", "U12.DC"]},
    {"net": "EPD_RESET", "type": "digital", "connections": ["U2.GPIO8", "U12.RESET"]},
    {"net": "EPD_BUSY", "type": "digital", "connections": ["U2.GPIO7", "U12.BUSY"]},
    {"net": "I2C_SDA", "type": "digital", "connections": ["U2.GPIO1", "U7.SDA"]},
    {"net": "I2C_SCL", "type": "digital", "connections": ["U2.GPIO2", "U7.SCL"]},
    {"net": "BAT_ALERT", "type": "digital", "connections": ["U7.ALRT", "U2.GPIO5"]},
    {"net": "UART_TX", "type": "digital", "connections": ["U2.GPIO43", "U9.RXD"]},
    {"net": "UART_RX", "type": "digital", "connections": ["U2.GPIO44", "U9.TXD"]},
    {"net": "USB_D+", "type": "usb_diff", "connections": ["J3.D+", "U9.D+"]},
    {"net": "USB_D-", "type": "usb_diff", "connections": ["J3.D-", "U9.D-"]},
    {"net": "LED_DATA", "type": "digital", "connections": ["U2.GPIO48", "LED1.DIN"]},
    {"net": "SATA_DAS", "type": "digital", "connections": ["J1.11", "J2.11", "U2.GPIO39"]},
    {"net": "BTN_CONFIG", "type": "digital", "connections": ["SW1.OUT", "U2.GPIO0", "R1=10kΩ pull-up to VCC_3V3"]},
    {"net": "PWR_SATA_DET", "type": "analog", "connections": ["J1.8", "U2.GPIO38 (voltage divider: 10k+10k)"]},
    {"net": "PWR_USB_DET", "type": "digital", "connections": ["J3.VBUS", "U2.GPIO40"]},
    {"net": "CLK_25MHZ", "type": "clock", "connections": ["U10.OUT", "U1.CLK_IN"]},
    {"net": "CLK_40MHZ", "type": "clock", "connections": ["U11.OUT", "U2.XTAL_IN"]}
  ],
  "notes": [
    "All SATA differential pairs must be length-matched (±5 mils) and have 100Ω ± 10% differential impedance.",
    "FPGA core 1.2V rail must be sequenced before 3.3V IO rail per Gowin datasheet.",
    "SATA signal path: Host TX → Redriver#1 → FPGA RX (inspect path) → FPGA TX → Redriver#2 → Drive RX. Reverse for drive→host.",
    "ESP32 antenna is on-board printed inverted-F (no external antenna needed).",
    "Battery charging is handled by a dedicated TP4056 charging module on the battery PCB.",
    "All high-speed traces must be on top layer with contiguous ground plane on layer 2.",
    "Keep SPI clock traces short (< 50mm) for 40 MHz operation.",
    "Crystal oscillators must have ground plane cut-out beneath them to reduce parasitic capacitance.",
    "Firmware can be updated via USB-C (CP2102N → ESP32 UART bootloader) or OTA via WiFi."
  ]
}
