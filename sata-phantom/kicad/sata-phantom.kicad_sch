        {"pin": 7, "signal": "GND"},
        {"pin": 8, "signal": "SATA_5V (passthrough)"},
        {"pin": 9, "signal": "SATA_5V (passthrough)"},
        {"pin": 10, "signal": "GND"},
        {"pin": 11, "signal": "SATA_DAS (passthrough)"},
        {"pin": 12, "signal": "GND"},
        {"pin": 13, "signal": "SATA_12V (passthrough)"},
        {"pin": 14, "signal": "SATA_12V (passthrough)"},
        {"pin": 15, "signal": "GND"},
        {"pin": 16, "signal": "SATA_DP_B+"},
        {"pin": 17, "signal": "SATA_DP_B-"},
        {"pin": 18, "signal": "GND"},
        {"pin": 19, "signal": "SATA_DP_A-"},
        {"pin": 20, "signal": "SATA_DP_A+"},
        {"pin": 21, "signal": "GND"},
        {"pin": 22, "signal": "GND"}
      ],
      "staggered": true
