    },
    {
      "ref": "BAT1",
      "value": "CP-402035",
      "description": "100 mAh LiPo Battery (3.7V)",
      "dimensions": "40×20×3.5 mm",
      "protection": "Built-in overcharge/overdischarge protection PCB",
      "connector": "JST-PH 2-pin",
      "connection": "TPS62065 (boost mode) + MAX17048 voltage monitor"
    },
    {
      "ref": "LED1",
      "value": "WS2812B",
      "package": "LED-5050",
      "description": "RGB Status LED — Mode indication",
      "pins": {"VCC": "3.3V", "GND": "GND", "DIN": "GPIO48 from ESP32"},
