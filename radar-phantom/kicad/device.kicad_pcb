  ; ============================================================
  ; DESIGN RULES
  ; ============================================================
  (design_rules
    (rule (min_track_width 0.1) (min_via_diameter 0.45) (min_via_drill 0.2))
    (rule (min_clearance 0.1) (min_copper_clearance 0.1))
    (rule (impedance_controlled yes) (diff_pair_width 0.18) (diff_pair_gap 0.12))
    (note "JESD204B 100-ohm diff pairs; 77 GHz RF on In6.Cu (Rogers RO4350B)"))
    (note "8-layer stackup for RF + digital isolation. Author: jayis1")
  )

  ; ============================================================
  ; NETCLASS ASSIGNMENTS
  ; ============================================================
  (net_classes
    (net_class "default" (track_width 0.2) (via_diameter 0.6) (via_drill 0.3)
      (nets "VCC_3V3" "GND" "VBAT_7V4" "VBUS_USB" "BAT_SENSE"
            "FPGA_SCK" "FPGA_SDI" "FPGA_CSN" "FPGA_CRST" "FPGA_CDONE"
            "SRAM_DQ0" "SRAM_DQ7" "SRAM_A18" "SRAM_CLK" "SRAM_CS"
            "PLL_CLK" "PLL_DATA" "PLL_LE" "PLL_MUX" "PLL_RF_EN"
            "BLE_TX" "BLE_RX" "USB_DP" "USB_DM" "USB_TX" "USB_RX"
            "SD_CMD" "SD_CLK" "SD_D0" "SD_CS"
            "OLED_SCL" "OLED_SDA" "OLED_RES" "OLED_DC" "OLED_CS"
            "EN_5V" "EN_RF" "JOY_WIPER" "JOY_PRESS"
            "LED_STATUS" "LED_ARM" "LED_FAULT"
            "ADC_SPI_SCK" "ADC_SPI_CS" "DAC_SPI_SCK" "DAC_SPI_CS"))
    (net_class "JESD204B" (track_width 0.18) (via_diameter 0.5) (via_drill 0.25)
      (diff_pair_gap 0.12) (nets "JTX_P0" "JTX_N0" "JTX_P1" "JTX_N1"
                                 "JRX_P0" "JRX_N0" "JRX_P1" "JRX_N1"
                                 "ADC_DEV_CLK"))
    (net_class "RF_77G" (track_width 0.15) (via_diameter 0.45) (via_drill 0.2)
      (nets "RX_HORN_RF" "RX_LNA_OUT" "TX_PA_IN" "TX_PA_OUT"
            "LO_OUT_P" "LO_OUT_N" "LO_REF"))
    (net_class "IF" (track_width 0.18) (via_diameter 0.5) (via_drill 0.25)
      (diff_pair_gap 0.12) (nets "RX_IF" "RX_IF_N" "TX_IF" "TX_IF_N"))
  )
)