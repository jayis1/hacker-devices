  (layers
    (0 "F.Cu" signal)
    (1 "In1.Cu" signal "GND")
    (2 "In2.Cu" signal "PWR")
    (3 "In3.Cu" signal "AGND")
    (4 "In4.Cu" signal "AVCC")
