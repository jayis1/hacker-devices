      (layer "Dielectric.7" (type dielectric) (thickness 0.2))
      (layer "B.Mask" (type solder-mask))
      (layer "B.SilkS" (type silk-screen))
      (layer "B.Cu" (type copper) (thickness 0.035))
    )
    (defaults
      (via (diameter 0.6) (drill 0.3))
      (track (width 0.2))
    )
  )

  ; ============================================================
  ; BOARD OUTLINE — 210 x 55 mm wand, origin at (0,0)
  ; ============================================================
  (gr_line (start 0 0) (end 210 0) (layer "Edge.Cuts") (width 0.15))
  (gr_line (start 210 0) (end 210 55) (layer "Edge.Cuts") (width 0.15))
  (gr_line (start 210 55) (end 0 55) (layer "Edge.Cuts") (width 0.15))
  (gr_line (start 0 55) (end 0 0) (layer "Edge.Cuts") (width 0.15))

  ; Mounting holes (M2)
  (gr_circle (center 4 4) (end 5 4) (layer "Edge.Cuts") (width 0.15))
  (gr_circle (center 206 4) (end 207 4) (layer "Edge.Cuts") (width 0.15))
  (gr_circle (center 4 51) (end 5 51) (layer "Edge.Cuts") (width 0.15))
  (gr_circle (center 206 51) (end 207 51) (layer "Edge.Cuts") (width 0.15))

  ; Antenna-end keepout (WR12 horns occupy the first 30 mm)
  (gr_text "ANTENNA END — KEEP CLEAR" (at 15 52) (layer "F.SilkS") (effects (size 1 1)))
  (gr_line (start 30 8) (end 30 47) (layer "F.Fab") (width 0.1))

