      (pin "2" (type passive) (at 5 0))
    )
    (symbol "Switch:SW_5Way"
      (pin_numbers (hide yes))
      (pin_names (offset 0.254))
      (in_bom yes) (on_board yes)
      (property "Reference" "SW1" (at 0 8 (angle 0)))
      (property "Value" "SW_5Way" (at 0 4 (angle 0))
      (property "Footprint" "Button_Switch_SMD:SW_5Way_Tactile_6x6mm")
      (property "Author" "jayis1" (at 0 0))))
      (pin "WIPER" (type passive) (at -10 0))
      (pin "PRESS" (type passive) (at 10 0))
      (pin "GND" (type passive) (at 0 -8))
    )
  )

  ; ============================================================
  ; COMPONENT INSTANCES
  ; ============================================================
  (symbol_instances
    (path "/U1" (reference "U1") (unit 1) (value "STM32H743VIT6")
      (at 100 100 (angle 0)) (property "Sheet" "Main") (property "Author" "jayis1"))
    (path "/U2" (reference "U2") (unit 1) (value "NINA-B302")
      (at 220 60 (angle 0)) (property "Author" "jayis1"))
    (path "/U3" (reference "U3") (unit 1) (value "iCE40-UP5K-SG48")
      (at 60 200 (angle 0)) (property "Author" "jayis1"))
    (path "/U4" (reference "U4") (unit 1) (value "ADF41520")
      (at -40 160 (angle 0)) (property "Author" "jayis1"))
    (path "/U5" (reference "U5") (unit 1) (value "AD9213")
      (at 20 200 (angle 0)) (property "Author" "jayis1"))
    (path "/U6" (reference "U6") (unit 1) (value "AD9789")
      (at 100 200 (angle 0)) (property "Author" "jayis1"))
    (path "/U7" (reference "U7") (unit 1) (value "HMC1043")
      (at -80 200 (angle 0)) (property "Author" "jayis1"))
    (path "/U8" (reference "U8") (unit 1) (value "HMC998")
      (at 160 200 (angle 0)) (property "Author" "jayis1"))
    (path "/U9A" (reference "U9A") (unit 1) (value "SHM-77G-RX")
      (at -60 200 (angle 0)) (property "Author" "jayis1"))
    (path "/U9B" (reference "U9B") (unit 1) (value "SHM-77G-TX")
      (at 140 200 (angle 0)) (property "Author" "jayis1"))
    (path "/U10" (reference "U10") (unit 1) (value "IS66WVH32M8")
      (at 60 240 (angle 0)) (property "Author" "jayis1"))
    (path "/U11" (reference "U11") (unit 1) (value "CP2102N")
      (at 220 120 (angle 0)) (property "Author" "jayis1"))
    (path "/D1" (reference "D1") (unit 1) (value "SH1107_128x96")
      (at 220 200 (angle 0)) (property "Author" "jayis1"))
    (path "/J1" (reference "J1") (unit 1) (value "WR12_Horn_RX")
      (at -120 200 (angle 0)) (property "Author" "jayis1"))
    (path "/J2" (reference "J2") (unit 1) (value "WR12_Horn_TX")
      (at 200 200 (angle 0)) (property "Author" "jayis1"))
    (path "/J3" (reference "J3") (unit 1) (value "USB-C")
      (at 260 100 (angle 0)) (property "Author" "jayis1"))
    (path "/J4" (reference "J4") (unit 1) (value "microSD")
      (at 260 140 (angle 0)) (property "Author" "jayis1"))
    (path "/J5" (reference "J5") (unit 1) (value "2x18650")
      (at -120 100 (angle 0)) (property "Author" "jayis1"))
    (path "/SW1" (reference "SW1") (unit 1) (value "SW_5Way")
      (at 180 60 (angle 0)) (property "Author" "jayis1"))
  )

  ; ============================================================
  ; NETLIST
  ; ============================================================
  (nets
    (net "VCC_3V3"  (connections ("U1.VDD" "U2.VCC" "U3.VCC" "U3.VCCIO_0" "U3.VCCIO_1"
                                  "U5.DVDD" "U6.DVDD" "U10.VDD" "U11.VDD"
                                  "D1.VCC" "U4.VCC")))
    (net "VCC_5V"   (connections ("U5.AVDD" "U6.AVDD" "U7.VDD" "U8.VDD")))
    (net "VCC_RF"   (connections ("U4.RF_EN")))
    (net "GND"      (connections ("U1.VSS" "U2.GND" "U3.GND" "U5.AVSS" "U5.DGND"
                                  "U6.AVSS" "U6.DGND" "U7.GND" "U8.GND"
                                  "U9A.GND" "U9B.GND" "U10.VSS" "U11.GND"
                                  "D1.GND" "J1.GND" "J2.GND" "J3.GND" "J4.GND"
                                  "J5.-" "SW1.GND")))

    ; ---- Battery / power ----
    (net "VBAT_7V4" (connections ("J5.+" "U5.AVDD")))
    (net "VBUS_USB" (connections ("J3.VBUS" "U11.VBUS")))
    (net "BAT_SENSE" (connections ("U1.PF9" "R_DIV.1")))

    ; ---- 77 GHz RX chain: horn -> LNA -> mixer ----
    (net "RX_HORN_RF" (connections ("J1.RF" "U7.RF_IN")))
    (net "RX_LNA_OUT" (connections ("U7.RF_OUT" "U9A.RF")))
    (net "RX_IF"      (connections ("U9A.IF" "U5.VIN_P")))
    (net "RX_IF_N"    (connections ("U5.VIN_N" "R_IF.1" "GND")))

    ; ---- 77 GHz TX chain: DAC -> mixer -> PA -> horn ----
    (net "TX_IF"      (connections ("U6.IOUT_P" "U9B.IF")))
    (net "TX_IF_N"    (connections ("U6.IOUT_N" "R_TXIF.1" "GND")))
    (net "TX_PA_IN"   (connections ("U9B.RF" "U8.RF_IN")))
    (net "TX_PA_OUT"  (connections ("U8.RF_OUT" "J2.RF")))

    ; ---- LO distribution ----
    (net "LO_OUT_P"  (connections ("U4.RF_OUT_P" "U9A.LO" "U9B.LO")))
    (net "LO_OUT_N"  (connections ("U4.RF_OUT_N" "R_LO.1" "GND")))
    (net "LO_REF"    (connections ("X50MHZ.1" "U4.REF_IN")))

    ; ---- JESD204B ADC -> FPGA ----
    (net "JTX_P0" (connections ("U5.JTX_P0" "U3.ADC_DATA_P")))
    (net "JTX_N0" (connections ("U5.JTX_N0" "U3.ADC_DATA_N")))
    (net "JTX_P1" (connections ("U5.JTX_P1" "U3.SRAM_A0")))
    (net "JTX_N1" (connections ("U5.JTX_N1" "U3.SRAM_A18")))
    (net "ADC_SYNC" (connections ("U5.SYNC" "U3.IO_0")))
    (net "ADC_DEV_CLK" (connections ("U5.CLK_P" "U3.ADC_CLK")))
    (net "ADC_SPI_SCK" (connections ("U5.SPI_SCK" "U1.PB13")))
    (net "ADC_SPI_CS"  (connections ("U5.SPI_CS"  "U1.PB12")))

    ; ---- JESD204B FPGA -> DAC ----
    (net "JRX_P0" (connections ("U3.DAC_DATA_P" "U6.JRX_P0")))
    (net "JRX_N0" (connections ("U3.DAC_DATA_N" "U6.JRX_N0")))
    (net "DAC_SPI_SCK" (connections ("U6.SPI_SCK" "U1.PB14")))
    (net "DAC_SPI_CS"  (connections ("U6.SPI_CS"  "U1.PB15")))

    ; ---- FPGA config (MCU -> FPGA) ----
    (net "FPGA_SCK"  (connections ("U1.PB13" "U3.SPI_SCK")))
    (net "FPGA_SDI"  (connections ("U1.PB15" "U3.SPI_SDI")))
    (net "FPGA_CSN"  (connections ("U1.PB12" "U3.SPI_CSN")))
    (net "FPGA_CRST" (connections ("U1.PC7"  "U3.CRESET")))
    (net "FPGA_CDONE" (connections ("U1.PC6" "U3.CDONE")))

    ; ---- FPGA <-> SRAM (delay buffer) ----
    (net "SRAM_DQ0" (connections ("U3.SRAM_DQ0" "U10.DQ0")))
    (net "SRAM_DQ7" (connections ("U3.SRAM_DQ7" "U10.DQ7")))
    (net "SRAM_A18" (connections ("U3.SRAM_A18" "U10.A18")))
    (net "SRAM_CLK" (connections ("U3.SRAM_CLK" "U10.CLK")))
    (net "SRAM_CS"  (connections ("U3.SRAM_A0" "U10.CS")))

    ; ---- LO PLL SPI ----
    (net "PLL_CLK" (connections ("U4.CLK" "U1.PC11")))
    (net "PLL_DATA" (connections ("U4.DATA" "U1.PC12")))
    (net "PLL_LE"  (connections ("U4.LE"   "U1.PC10")))
    (net "PLL_MUX" (connections ("U4.MUXOUT" "U1.PA12")))
    (net "PLL_RF_EN" (connections ("U4.RF_EN" "U1.PD2")))

    ; ---- BLE UART ----
    (net "BLE_TX" (connections ("U2.UART_TX" "U1.PD9")))
    (net "BLE_RX" (connections ("U2.UART_RX" "U1.PD8")))

    ; ---- USB-C CDC ----
    (net "USB_DP" (connections ("J3.DP1" "U11.D+")))
    (net "USB_DM" (connections ("J3.DM1" "U11.D-")))
    (net "USB_TX" (connections ("U11.TXD" "U1.PD5")))
    (net "USB_RX" (connections ("U11.RXD" "U1.PD6")))

    ; ---- SD card (SPI4) ----
    (net "SD_CMD" (connections ("J4.CMD" "U1.PE6")))
    (net "SD_CLK" (connections ("J4.CLK" "U1.PE2")))
    (net "SD_D0"  (connections ("J4.D0"  "U1.PE5")))
    (net "SD_CS"  (connections ("J4.D3"  "U1.PE4")))

    ; ---- OLED (SPI1) ----
    (net "OLED_SCL" (connections ("D1.SCL" "U1.PB3")))
    (net "OLED_SDA" (connections ("D1.SDA" "U1.PB5")))
    (net "OLED_RES" (connections ("D1.RES" "U1.PA6")))
    (net "OLED_DC"  (connections ("D1.DC"  "U1.PA5")))
    (net "OLED_CS"  (connections ("D1.CS"  "U1.PA4")))

    ; ---- Power enables ----
    (net "EN_5V" (connections ("U1.PG7" "U7.VDD" "U8.VDD")))
    (net "EN_RF" (connections ("U1.PG8" "U4.RF_EN")))

    ; ---- 5-way joystick ----
    (net "JOY_WIPER" (connections ("SW1.WIPER" "U1.PA0")))
    (net "JOY_PRESS" (connections ("SW1.PRESS" "U1.PC13")))

    ; ---- LEDs ----
    (net "LED_STATUS" (connections ("U1.PB0" "R_LED1.1")))
    (net "LED_ARM"    (connections ("U1.PB1" "R_LED2.1")))
    (net "LED_FAULT"   (connections ("U1.PB2" "R_LED3.1")))
  )

  ; ============================================================
  ; POWER RAILS / DECOUPLING (representative)
  ; ============================================================
  (power_rails
    (rail "VCC_3V3" (voltage 3.3) (decoupling
      ("C1" "100nF" "U1") ("C2" "100nF" "U1") ("C3" "4.7uF" "U1")
      ("C4" "100nF" "U2") ("C5" "100nF" "U3") ("C6" "100nF" "U3")
      ("C7" "100nF" "U4") ("C8" "100nF" "U11") ("C9" "4.7uF" "U10")))
    (rail "VCC_5V" (voltage 5.0) (decoupling
      ("C10" "100nF" "U5") ("C11" "4.7uF" "U5") ("C12" "100nF" "U6") ("C13" "4.7uF" "U6")))
    (rail "VCC_1V2_FPGA" (voltage 1.2) (decoupling ("C14" "100nF" "U3") ("C15" "4.7uF" "U3")))
    (rail "VCC_2V5_FPGA" (voltage 2.5) (decoupling ("C16" "100nF" "U3") ("C17" "4.7uF" "U3")))
    (rail "VCC_RF" (voltage 5.0) (decoupling ("C18" "100nF" "U7") ("C19" "100nF" "U8")))
  )

  ; Ferrite beads for analog isolation
  (components_passive
    ("L1" "Ferrite_Bead" "AVDD_isolation" (pins "VCC_5V" "AVDD_FILT"))
    ("L2" "Ferrite_Bead" "RF_isolation" (pins "VCC_5V" "VCC_RF"))
    ("L3" "Ferrite_Bead" "LO_isolation" (pins "VCC_5V" "VCC_LO"))
  )

  ; ============================================================
  ; SHEET NOTES
  ; ============================================================
  (sheetnotes
    (text "RadarPhantom — Portable mmWave FMCW radar phantom-target injector")
    (text "Author: jayis1 — CERN-OHL-S v2 hardware, GPL-2.0 firmware")
    (text "RX path: WR12 horn -> HMC1043 LNA -> sub-harm mixer -> AD9213 ADC")
    (text "TX path: AD9789 DAC -> sub-harm mixer -> HMC998 PA -> WR12 horn")
    (text "DRFM core: iCE40-UP5K + IS66WVH32M8 SRAM delay buffer")
    (text "LO: ADF41520 PLL @ 38 GHz sub-harmonic, 50 MHz reference")
    (text "Control: STM32H743 + nRF52840 BLE + CP2102N USB-C CDC")
    (text "LEGAL: authorized security research only. See README.")
  )
)