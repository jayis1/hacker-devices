      "solder_mask_min_width": 0.05,
      "grid_origin": {"x": 0, "y": 0},
      "defaults": {
        "via": {"diameter": 0.6, "drill": 0.3},
        "track": {"width": 0.2}
      }
    },
    "design_rules": {
      "min_track_width": 0.1,
      "min_via_diameter": 0.45,
      "min_via_drill": 0.2,
      "min_clearance": 0.1,
      "impedance_controlled": true,
      "diff_pair_width": 0.18,
      "diff_pair_gap": 0.12,
      "notes": [
        "JESD204B 100-ohm diff pairs on In2.Cu",
        "77 GHz RF on In6.Cu (Rogers RO4350B stripline)",
        "8-layer stackup for RF + digital isolation",
        "Author: jayis1"
      ]
    },
