  ; ═══════════════════════════════════════════════════════════════
  ; Track segments (key connections)
  ; ═══════════════════════════════════════════════════════════════

  ; SPI1: MCU PA5/PA6/PA7 → FPGA SCK/MISO/MOSI
  (segment (start 25 19) (end 56.5 26.2) (width 0.15) (layer "F.Cu") (net 11))
  (segment (start 25 19.5) (end 56.5 25.7) (width 0.15) (layer "F.Cu") (net 12))
  (segment (start 25 20) (end 56.5 25.2) (width 0.15) (layer "F.Cu") (net 13))

  ; FPGA CS → MCU PB0
  (segment (start 24 19) (end 63.5 26.7) (width 0.15) (layer "F.Cu") (net 14))

  ; USART3: MCU PD8/PD9 → BLE TX/RX
  (segment (start 26.5 31) (end 67 25.8) (width 0.15) (layer "F.Cu") (net 35))
  (segment (start 26.5 31.5) (end 67 26.6) (width 0.15) (layer "F.Cu") (net 36))

  ; AD7606 SPI2: MCU → ADC
  (segment (start 25 21) (end 61.5 40.5) (width 0.15) (layer "F.Cu") (net 24))
  (segment (start 61.5 40.5) (end 62 40.5) (width 0.15) (layer "F.Cu") (net 24))

  ; DRV425 output → AD8331 input (analog)
  (segment (start 68.75 59) (end 55.6 55.6) (width 0.2) (layer "F.Cu") (net 90))

  ; VGA output → LTC1564 filter input
  (segment (start 57.7 55.6) (end 57.7 64.4) (width 0.2) (layer "F.Cu") (net 91))

  ; Marx trigger: FPGA pin 21 → Q1 base
  (segment (start 63.5 24.2) (end 53.73 50) (width 0.3) (layer "F.Cu") (net 104))

  ; HV rail: Q1 collector → Marx bank → J3 pin1
  (segment (start 56.27 50) (end 75 48.73) (width 0.5) (layer "F.Cu") (net 9))

  ; Ground plane fill (B.Cu)
  (zone (net 1) (net_name "GND") (layer "B.Cu") (tstamp 0)
    (hatch edge 0.5)
    (connect_pads (clearance 0.3))
    (min_thickness 0.2)
    (fill yes (thermal_gap 0.3) (thermal_bridge_width 0.3))
    (polygon
      (pts (xy 0 0) (xy 80 0) (xy 80 55) (xy 0 55))
    )
  )

  ; +3V3 plane fill (partial, F.Cu where not used)
