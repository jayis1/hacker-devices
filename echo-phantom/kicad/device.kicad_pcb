    (pad "5" smd roundrect (at -0.95 1.0) (size 0.6 0.5) (layers "F.Cu" "F.Paste" "F.Mask")
      (roundrect_rratio 0.25) (net 2 "VCC_3V3"))
  )

  ; --- D1: Red LED ---
  (footprint "LED_SMD:LED_0402_1005Metric"
    (layer "F.Cu")
    (at 15.5 10.5 0)
    (property "Reference" "D1" (at 0 -1.0 0)
      (effects (font (size 0.4 0.4))))
    (property "Value" "Red" (at 0 1.0 0)
      (effects (font (size 0.4 0.4))))
    (pad "1" smd roundrect (at -0.5 0) (size 0.5 0.5) (layers "F.Cu" "F.Paste" "F.Mask")
      (roundrect_rratio 0.25) (net 17 "LED_RED"))
    (pad "2" smd roundrect (at 0.5 0) (size 0.5 0.5) (layers "F.Cu" "F.Paste" "F.Mask")
      (roundrect_rratio 0.25) (net 1 "GND"))
  )

  ; --- D2: Blue LED ---
  (footprint "LED_SMD:LED_0402_1005Metric"
    (layer "F.Cu")
    (at 16.5 10.5 0)
    (property "Reference" "D2" (at 0 -1.0 0)
      (effects (font (size 0.4 0.4))))
    (property "Value" "Blue" (at 0 1.0 0)
      (effects (font (size 0.4 0.4))))
    (pad "1" smd roundrect (at -0.5 0) (size 0.5 0.5) (layers "F.Cu" "F.Paste" "F.Mask")
      (roundrect_rratio 0.25) (net 18 "LED_BLUE"))
    (pad "2" smd roundrect (at 0.5 0) (size 0.5 0.5) (layers "F.Cu" "F.Paste" "F.Mask")
      (roundrect_rratio 0.25) (net 1 "GND"))
  )

  ; --- Y1: 25 MHz Crystal ---
  (footprint "Crystal:Crystal_SMD_3225-4Pin_3.2x2.5mm"
    (layer "F.Cu")
    (at 8.0 2.0 0)
    (property "Reference" "Y1" (at 0 -2.0 0)
      (effects (font (size 0.5 0.5))))
    (property "Value" "25 MHz" (at 0 2.0 0)
      (effects (font (size 0.5 0.5))))
    (pad "1" smd roundrect (at -1.1 -0.85) (size 1.0 1.0) (layers "F.Cu" "F.Paste" "F.Mask")
      (roundrect_rratio 0.25))
    (pad "2" smd roundrect (at 1.1 -0.85) (size 1.0 1.0) (layers "F.Cu" "F.Paste" "F.Mask")
      (roundrect_rratio 0.25))
    (pad "3" smd roundrect (at 1.1 0.85) (size 1.0 1.0) (layers "F.Cu" "F.Paste" "F.Mask")
      (roundrect_rratio 0.25) (net 1 "GND"))
    (pad "4" smd roundrect (at -1.1 0.85) (size 1.0 1.0) (layers "F.Cu" "F.Paste" "F.Mask")
      (roundrect_rratio 0.25))
  )

  ; --- Decoupling capacitors ---
  (footprint "Capacitor_SMD:C_0402_1005Metric"
    (layer "F.Cu")
    (at 12.0 5.0 0)
    (property "Reference" "C1" (at 0 -1.0 0)
      (effects (font (size 0.4 0.4))))
    (property "Value" "100nF" (at 0 1.0 0)
      (effects (font (size 0.4 0.4))))
    (pad "1" smd roundrect (at -0.5 0) (size 0.5 0.5) (layers "F.Cu" "F.Paste" "F.Mask")
      (roundrect_rratio 0.25) (net 2 "VCC_3V3"))
    (pad "2" smd roundrect (at 0.5 0) (size 0.5 0.5) (layers "F.Cu" "F.Paste" "F.Mask")
      (roundrect_rratio 0.25) (net 1 "GND"))
  )

  (footprint "Capacitor_SMD:C_0603_1608Metric"
    (layer "F.Cu")
    (at 13.0 5.0 0)
    (property "Reference" "C2" (at 0 -1.0 0)
      (effects (font (size 0.4 0.4))))
    (property "Value" "10uF" (at 0 1.0 0)
      (effects (font (size 0.4 0.4))))
    (pad "1" smd roundrect (at -0.8 0) (size 0.8 0.8) (layers "F.Cu" "F.Paste" "F.Mask")
      (roundrect_rratio 0.25) (net 2 "VCC_3V3"))
    (pad "2" smd roundrect (at 0.8 0) (size 0.8 0.8) (layers "F.Cu" "F.Paste" "F.Mask")
      (roundrect_rratio 0.25) (net 1 "GND"))
  )

  ; --- Vias for GND stitching ---
  (via (at 2.0 2.0) (size 0.3) (drill 0.15) (layers "F.Cu" "B.Cu") (net 1 "GND"))
  (via (at 2.0 10.0) (size 0.3) (drill 0.15) (layers "F.Cu" "B.Cu") (net 1 "GND"))
  (via (at 16.0 2.0) (size 0.3) (drill 0.15) (layers "F.Cu" "B.Cu") (net 1 "GND"))
  (via (at 16.0 10.0) (size 0.3) (drill 0.15) (layers "F.Cu" "B.Cu") (net 1 "GND"))
  (via (at 9.0 2.0) (size 0.3) (drill 0.15) (layers "F.Cu" "B.Cu") (net 1 "GND"))
  (via (at 9.0 10.0) (size 0.3) (drill 0.15) (layers "F.Cu" "B.Cu") (net 1 "GND"))
  (via (at 6.0 6.0) (size 0.3) (drill 0.15) (layers "F.Cu" "B.Cu") (net 1 "GND"))
  (via (at 12.0 6.0) (size 0.3) (drill 0.15) (layers "F.Cu" "B.Cu") (net 1 "GND"))

  ; ========================================================================
  ;  Copper zones
  ; ========================================================================

  (zone (net 1) (net_name "GND") (layer "B.Cu") (tstamp 0)
    (hatch edge 0.5)
    (connect_pads (clearance 0.2))
    (min_thickness 0.15)
    (fill yes (thermal_gap 0.2) (thermal_bridge_width 0.2))
    (polygon
      (pts (xy 0.2 0.2) (xy 17.8 0.2) (xy 17.8 11.8) (xy 0.2 11.8))
    )
  )

  (zone (net 1) (net_name "GND") (layer "In1.Cu") (tstamp 1)
    (hatch edge 0.5)
    (connect_pads (clearance 0.2))
    (min_thickness 0.15)
    (fill yes (thermal_gap 0.2) (thermal_bridge_width 0.2))
    (polygon
      (pts (xy 0.2 0.2) (xy 17.8 0.2) (xy 17.8 11.8) (xy 0.2 11.8))
    )
  )

  (zone (net 2) (net_name "VCC_3V3") (layer "In2.Cu") (tstamp 2)
    (hatch edge 0.5)
    (connect_pads (clearance 0.2))
    (min_thickness 0.15)
    (fill yes (thermal_gap 0.2) (thermal_bridge_width 0.2))
