(kicad_pro (version 20231014)
  (generators)
  (general
    (project "Infrared Phantom - IR Security Research Toolkit")
    (company "Hacker Devices")
    (license "CERN-OHL-S v2")
  )
  (net_class "Default" ""
    (clearance 0.2)
    (trace_width 0.2)
    (via_dia 0.4)
    (via_drill 0.2)
    (diff_pair_width 0.2)
    (diff_pair_gap 0.15)
  )
  (net_class "Power" ""
    (clearance 0.2)
    (trace_width 0.4)
    (via_dia 0.6)
    (via_drill 0.3)
    (diff_pair_width 0.4)
    (diff_pair_gap 0.2)
  )
  (net_class "High_Current" ""
    (clearance 0.3)
    (trace_width 1.0)
    (via_dia 0.6)
    (via_drill 0.3)
  )
  (net_class "USB_HS" ""
    (clearance 0.2)
    (trace_width 0.2)
    (via_dia 0.4)
    (via_drill 0.2)
    (diff_pair_width 0.2)
    (diff_pair_gap 0.15)
  )
  (net_class "ULPI" ""
    (clearance 0.2)
    (trace_width 0.2)
    (via_dia 0.4)
    (via_drill 0.2)
  )
  (net_class "Analog" ""
    (clearance 0.3)
    (trace_width 0.25)
    (via_dia 0.4)
    (via_drill 0.2)
  )
  (design_settings
    (layer_setup
      (layer "F.Cu" type "signal")
      (layer "In1.Cu" type "ground")
      (layer "In2.Cu" type "power")
      (layer "B.Cu" type "signal")
    )
    (stackup
      (layer "F.Cu" thickness 0.035)
      (layer "Prepreg" thickness 0.1 material "FR-4 1705")
      (layer "In1.Cu" thickness 0.035)
      (layer "Core" thickness 0.2 material "FR-4")
      (layer "In2.Cu" thickness 0.035)
      (layer "Prepreg" thickness 0.1 material "FR-4 1705")
      (layer "B.Cu" thickness 0.035)
    )
    (board_thickness 1.0)
    (copper_finish "ENIG")
    (solder_mask "Green")
    (silk_screen "White")
  )
)