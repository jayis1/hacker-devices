  ;; ==========================================
  ;; Power Tree Connections (Textual)
  ;; ==========================================
  ;; VBUS_5V → FB1 → BQ25896.VBUS
  ;; BQ25896.SYS → TPS62840.VIN → VREG_3V3 (main 3.3V rail)
  ;; BQ25896.BAT → LiPo connector J3
  ;; VREG_3V3 → TLV70033.VIN → VREG_3V3_NRF (isolated NRF52 supply)
  ;; VREG_3V3 → STM32L4 VDD pins, PN5180 VDD, W25Q128 VDD, SSD1306 VDD
  ;; VREG_3V3_NRF → NRF52832 VDD pins

  ;; ==========================================
  ;; Signal Tree Connections (Textual)
  ;; ==========================================
  ;; STM32L4 SPI1 → PN5180 (NSS, SCK, MISO, MOSI, BUSY, RST)
  ;; STM32L4 SPI2 → W25Q128 (NSS, SCK, MISO, MOSI, WP, HOLD)
  ;; STM32L4 UART4 ↔ NRF52832 (TX→RX, RX←TX, RST, IRQ)
  ;; STM32L4 UART1 ↔ EM4095 (TX→MOD, RX←DEMOD_OUT, SHD)
  ;; STM32L4 I2C1 → SSD1306 + BQ25896 (SCL, SDA)
  ;; STM32L4 USB → USB-C J1 (DM, DP)
  ;; PN5180 ANT1/ANT2 → 13.56 MHz PCB antenna
  ;; EM4095 ANT1/ANT2 → 125 kHz PCB antenna

)