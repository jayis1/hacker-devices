(kicad_pro
  (version 0.3)
  (general
    (thickness 0.8)
  )
  (setup
    (pad_drill 0.3)
    (pad_size 0.6 0.6)
    (grid_origin 0 0)
  )
  (net_class "Default" ""
    (clearance 0.15)
    (trace_width 0.15)
    (via_dia 0.6)
    (via_drill 0.3)
  )
  (net_class "Power" ""
    (clearance 0.2)
    (trace_width 0.5)
    (via_dia 0.8)
    (via_drill 0.4)
  )
  (net_class "USB" ""
    (clearance 0.2)
    (trace_width 0.2)
    (via_dia 0.6)
    (via_drill 0.3)
    (diff_pair_gap 0.15)
    (diff_pair_width 0.2)
  )
  (net_class "SPI_HS" ""
    (clearance 0.15)
    (trace_width 0.15)
    (via_dia 0.5)
    (via_drill 0.25)
  )
  (net_class "RF_13M56" ""
    (clearance 0.5)
    (trace_width 1.0)
    (via_dia 0.5)
    (via_drill 0.25)
  )
  (net_class "RF_125K" ""
    (clearance 0.3)
    (trace_width 0.5)
    (via_dia 0.8)
    (via_drill 0.4)
  )
  (net_class "I2C" ""
    (clearance 0.15)
    (trace_width 0.2)
    (via_dia 0.6)
    (via_drill 0.3)
  )
  (design_rules
    (min_clearance 0.1)
    (min_track_width 0.1)
    (min_via_annular 0.075)
    (min_via_diameter 0.5)
    (min_via_drill 0.25)
    (min_microvia_diameter 0.2)
    (min_microvia_drill 0.1)
  )
  (layers
    (0 "F.Cu" signal)
    (1 "In1.Cu" signal)
    (2 "In2.Cu" signal)
    (31 "B.Cu" signal)
    (32 "B.Adhes" user)
    (33 "F.Adhes" user)
    (34 "B.Paste" user)
    (35 "F.Paste" user)
    (36 "B.SilkS" user)
    (37 "F.SilkS" user)
    (38 "B.Mask" user)
    (39 "F.Mask" user)
    (40 "Dwgs.User" user)
    (41 "Cmts.User" user)
    (44 "Edge.Cuts" user)
    (45 "Margin" user)
    (46 "B.CrtYd" user)
    (47 "F.CrtYd" user)
    (48 "B.Fab" user)
    (49 "F.Fab" user)
  )
)