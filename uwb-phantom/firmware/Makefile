# Makefile — UWB-PHANTOM firmware build wrapper.
#
# Author: jayis1
# SPDX-License-Identifier: GPL-3.0-or-later
#
# This Makefile wraps ESP-IDF's `idf.py` for convenience.  It assumes
# ESP-IDF v5.2 (or compatible) is installed and the IDF_PATH
# environment variable is set.  Source files live alongside this
# Makefile and are listed in the `SRCS` variable below.
#
# Usage:
#   make set-target   # one-time, picks esp32s3
#   make build
#   make flash
#   make monitor
#   make clean
#   make menuconfig
#
# The full build is driven by the CMakeLists.txt that ESP-IDF expects
# in the same directory (generated by `idf.py create-project`).

IDF_PATH ?= $(HOME)/esp/esp-idf
IDF_PY   ?= idf.py
TARGET   ?= esp32s3

SRCS = main.c dw3110.c uwb_sniffer.c relay.c sts_audit.c display.c \
       ble_comms.c fuel_gauge.c

HDRS = board.h registers.h dw3110.h uwb_sniffer.h relay.h sts_audit.h \
       display.h ble_comms.h fuel_gauge.h

# ---- convenience targets ----

.PHONY: all build flash monitor clean menuconfig set-target size erase

all: build

set-target:
	$(IDF_PY) set-target $(TARGET)

build:
	$(IDF_PY) build

flash:
	$(IDF_PY) -p /dev/ttyACM0 flash

monitor:
	$(IDF_PY) -p /dev/ttyACM0 monitor

flash-monitor: flash monitor

clean:
	$(IDF_PY) clean

menuconfig:
	$(IDF_PY) menuconfig

size:
	$(IDF_PY) size

erase:
	$(IDF_PY) -p /dev/ttyACM0 erase-flash

# ---- lint / format ----

.PHONY: check format

check:
	@echo "==> cppcheck (best-effort)"
	cppcheck --enable=all --suppress=missingIncludeSystem \
		--inline-suppr $(SRCS) $(HDRS) 2>&1 | grep -v "^cppcheck: " || true

format:
	@echo "==> clang-format"
	clang-format -i $(SRCS) $(HDRS)

# ---- counts (used by the repo quality bar) ----

.PHONY: loc
loc:
	@wc -l $(SRCS) $(HDRS) | tail -1