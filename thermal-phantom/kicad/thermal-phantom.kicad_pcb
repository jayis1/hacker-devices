(kicad_pcb
  (version 20211123)
  (generator "kicad")
  (generator_version "6.0")
  (general
    (thickness 1.6)
    (legacy_teardrops no)
  )
  (paper "A4")
  (layers
    (0 "F.Cu" signal)
    (1 "In1.Cu" signal "GND")
    (2 "In2.Cu" signal "PWR")
    (31 "B.Cu" signal)
    (32 "B.Mask" mask)
    (33 "F.Mask" mask)
    (34 "B.Paste" paste)
    (35 "F.Paste" paste)
    (36 "B.SilkS" silk "B.Silkscreen")
    (37 "F.SilkS" silk "F.Silkscreen")
    (38 "B.Fab" fab)
    (39 "F.Fab" fab)
    (40 "Dwgs.User" user "User.Drawings")
    (41 "Cmts.User" user "User.Comments")
    (42 "Eco1.User" user "User.Eco1")
    (43 "Eco2.User" user "User.Eco2")
    (44 "Edge.Cuts" user)
    (45 "Margin" user)
    (46 "B.CrtYd" user "B.Courtyard")
    (47 "F.CrtYd" user "F.Courtyard")
  )
  (setup
    (stackup
      (layer "F.Cu" (type "copper") (thickness 0.035))
      (layer "dielectric 1" (type "core") (thickness 0.48) (material "FR4"))
      (layer "In1.Cu" (type "copper") (thickness 0.035))
      (layer "dielectric 2" (type "prepreg") (thickness 0.48) (material "FR4"))
      (layer "In2.Cu" (type "copper") (thickness 0.035))
      (layer "dielectric 3" (type "core") (thickness 0.48) (material "FR4"))
      (layer "B.Cu" (type "copper") (thickness 0.035))
    )
    (pad_to_mask_clearance 0.05)
    (pcbplotparams
      (layerselection 0x00010f0_ffffffff)
      (plotinvisibletext no)
      (useauxorigin no)
      (hpglpenwidth 0.15)
      (psnegative no)
      (psa4output yes)
      (plotoresson no)
      (plotoressifthick no)
      (plotoresslinewidth 0.1)
      (plotoressdashed no)
      (plotoresscolors no)
      (svgprecision 4)
      (plotoressframe no)
      (plotoressframetextyes no)
      (excludeedgelayer yes)
      (plotframeref no)
      (viasonly no)
      (viaminwidth 0.4)
      (viaminwidths no)
      (viaminsize 0.4)
      (viamaxsize 1.0)
      (viasdrill 0.2)
      (viasminsize 0.3)
      (uviaresolution no)
    )
  )
  (net 0 "")
  (net 1 "VCC_3V3")
  (net 2 "GND")
  (net 3 "VCC_12V")
  (net 4 "VCC_14V8")
  (net 5 "I2C1_SCL")
  (net 6 "I2C1_SDA")
  (net 7 "TEC_IN1")
  (net 8 "TEC_IN2")
  (net 9 "TEC_NSLEEP")
  (net 10 "TEC_NFAULT")
  (net 11 "TEC_OUT1")
  (net 12 "TEC_OUT2")
  (net 13 "TEC_IPROPI")
  (net 14 "LASER_EN")
  (net 15 "LASER_OUT")
  (net 16 "LASER_SHUTTER")
  (net 17 "LASER_INTERLOCK")
  (net 18 "TRIG_IN")
  (net 19 "TRIG_OUT")
  (net 20 "USART3_TX")
  (net 21 "USART3_RX")
  (net 22 "BLE_TX")
  (net 23 "BLE_RX")
  (net 24 "DS18B20_DQ")
  (net 25 "ESTOP")
  (net 26 "LED_STATUS")
  (net 27 "LED_ARM")
  (net 28 "LED_BLE")
  (net 29 "BAT_SENSE")
  (net 30 "USB_D+")
  (net 31 "USB_D-")
  (net 32 "SWCLK")
  (net 33 "SWDIO")

  (footprint "Package_BGA:ST_BGA-100_10x10mm_8.0x8.0mm"
    (layer "F.Cu")
    (attr (type "smd"))
    (tedit 0)
    (at 50 50)
    (descr "STM32H743 BGA-100, 10x10 grid, 8x8mm body")
    (property "Author" "jayis1")
    (property "Reference" "U1" (at 0 -6 0))
    (property "Value" "STM32H743VIT6" (at 0 6 0))
  )

  (footprint "Package_SO:TI_SOIC-8_3.9x4.9mm_P1.27mm"
    (layer "F.Cu")
    (attr (type "smd"))
    (tedit 0)
    (at 80 30)
    (descr "DRV8873 H-bridge SOIC-8")
    (property "Author" "jayis1")
    (property "Reference" "U4" (at 0 -4 0))
    (property "Value" "DRV8873DDAR" (at 0 4 0))
  )

  (footprint "Package_TO_SOT_THT:TO-39-4"
    (layer "F.Cu")
    (attr through_hole)
    (tedit 0)
    (at 20 70)
    (descr "MLX90614 IR temp sensor TO-39-4")
    (property "Author" "jayis1")
    (property "Reference" "U3" (at 0 -5 0))
    (property "Value" "MLX90614ESF-DCI" (at 0 5 0))
  )

  (footprint "Package_TO_SOT_THT:TO-92_Inline"
    (layer "F.Cu")
    (attr through_hole)
    (tedit 0)
    (at 20 85)
    (descr "DS18B20 contact temp sensor TO-92")
    (property "Author" "jayis1")
    (property "Reference" "U6" (at 0 -4 0))
    (property "Value" "DS18B20" (at 0 4 0))
  )

  (footprint "Package_QFP:LQFP-64_10x10mm_P0.5mm"
    (layer "F.Cu")
    (attr (type "smd"))
    (tedit 0)
    (at 80 70)
    (descr "FT4232H USB interface LQFP-64")
    (property "Author" "jayis1")
    (property "Reference" "U5" (at 0 -7 0))
    (property "Value" "FT4232HL" (at 0 7 0))
  )

  (footprint "Package_DIP:DIP-14_W7.62mm"
    (layer "F.Cu")
    (attr through_hole)
    (tedit 0)
    (at 50 85)
    (descr "LM359 laser driver DIP-14")
    (property "Author" "jayis1")
    (property "Reference" "U7" (at 0 -8 0))
    (property "Value" "LM359N" (at 0 8 0))
  )

  (footprint "Connector_USB:USB_A_Vertical"
    (layer "F.Cu")
    (attr through_hole)
    (tedit 0)
    (at 80 90)
    (descr "nRF52840 USB dongle interface")
    (property "Author" "jayis1")
    (property "Reference" "U2" (at 0 -6 0))
    (property "Value" "nRF52840_USB_Dongle" (at 0 6 0))
  )

  (footprint "Connector:FanPinHeader_1x02_P2.54mm_Vertical"
    (layer "F.Cu")
    (attr through_hole)
    (tedit 0)
    (at 30 50)
    (descr "TEC1-12706 Peltier module connector")
    (property "Author" "jayis1")
    (property "Reference" "TEC1" (at 0 -3 0))
    (property "Value" "TEC1-12706" (at 0 3 0))
  )

  (footprint "Package_TO_SOT_THT:TO-18_3Pin"
    (layer "F.Cu")
    (attr through_hole)
    (tedit 0)
    (at 65 85)
    (descr "450nm 1W laser diode TO-18")
    (property "Author" "jayis1")
    (property "Reference" "LD1" (at 0 -4 0))
    (property "Value" "Laser_Diode_450nm_1W" (at 0 4 0))
  )

  (footprint "Connector_PinHeader_2.54mm:PinHeader_1x04_P2.54mm_Vertical"
    (layer "F.Cu")
    (attr through_hole)
    (tedit 0)
    (at 80 50)
    (descr "SSD1306 OLED display header")
    (property "Author" "jayis1")
    (property "Reference" "DISP1" (at 0 -3 0))
    (property "Value" "SSD1306_128x64_OLED" (at 0 3 0))
  )

  (footprint "Package_SO:TI_SOIC-8_3.9x4.9mm_P1.27mm"
    (layer "F.Cu")
    (attr (type "smd"))
    (tedit 0)
    (at 50 20)
    (descr "TPS54360 buck converter")
    (property "Author" "jayis1")
    (property "Reference" "PWR1" (at 0 -4 0))
    (property "Value" "TPS54360DDAR" (at 0 4 0))
  )

  (footprint "Connector_Coax:U.FL_Hirose_U.FL-R-SMT-1_Vertical"
    (layer "F.Cu")
    (attr (type "smd"))
    (tedit 0)
    (at 15 30)
    (descr "SMA trigger input connector")
    (property "Author" "jayis1")
    (property "Reference" "J1" (at 0 -3 0))
    (property "Value" "SMA" (at 0 3 0))
  )

  (footprint "Connector_Coax:U.FL_Hirose_U.FL-R-SMT-1_Vertical"
    (layer "F.Cu")
    (attr (type "smd"))
    (tedit 0)
    (at 15 40)
    (descr "SMA trigger output connector")
    (property "Author" "jayis1")
    (property "Reference" "J2" (at 0 -3 0))
    (property "Value" "SMA" (at 0 3 0))
  )

  ; --- Board edge ---
  (gr_line (start 0 0) (end 100 0) (layer "Edge.Cuts") (width 0.1))
  (gr_line (start 100 0) (end 100 60) (layer "Edge.Cuts") (width 0.1))
  (gr_line (start 100 60) (end 0 60) (layer "Edge.Cuts") (width 0.1))
  (gr_line (start 0 60) (end 0 0) (layer "Edge.Cuts") (width 0.1))

  ; --- Copper zones ---
  (zone (net 2) (net_name "GND") (layer "In1.Cu") (tstamp 0)
    (connect_pads (clearance 0.3))
    (min_thickness 0.2)
    (fill (thermal_gap 0.3) (thermal_bridge_width 0.3))
    (polygon (pts (xy 1 1) (xy 99 1) (xy 99 59) (xy 1 59)))
  )
  (zone (net 1) (net_name "VCC_3V3") (layer "In2.Cu") (tstamp 1)
    (connect_pads (clearance 0.3))
    (min_thickness 0.2)
    (fill (thermal_gap 0.3) (thermal_bridge_width 0.3))
    (polygon (pts (xy 1 1) (xy 99 1) (xy 99 59) (xy 1 59)))
  )

  ; --- Trace definitions ---
  ; I2C bus: SCL and SDA from U1 to U3 and DISP1
  (segment (start 45 48) (end 25 68) (width 0.2) (layer "F.Cu") (net 5))
  (segment (start 25 68) (end 22 72) (width 0.2) (layer "F.Cu") (net 5))
  (segment (start 45 50) (end 80 50) (width 0.2) (layer "F.Cu") (net 6))
  (segment (start 80 50) (end 82 48) (width 0.2) (layer "F.Cu") (net 6))

  ; TEC driver connections
  (segment (start 55 45) (end 78 28) (width 0.5) (layer "F.Cu") (net 7))
  (segment (start 57 45) (end 82 28) (width 0.5) (layer "F.Cu") (net 8))
  (segment (start 35 50) (end 30 50) (width 1.0) (layer "F.Cu") (net 11))
  (segment (start 35 52) (end 30 52) (width 1.0) (layer "F.Cu") (net 12))

  ; Laser driver connections
  (segment (start 55 55) (end 52 83) (width 0.3) (layer "F.Cu") (net 14))
  (segment (start 60 85) (end 65 85) (width 0.5) (layer "F.Cu") (net 15))

  ; Trigger I/O
  (segment (start 45 40) (end 15 30) (width 0.3) (layer "F.Cu") (net 18))
  (segment (start 45 42) (end 15 40) (width 0.3) (layer "F.Cu") (net 19))

  ; USB differential pair
  (segment (start 85 75) (end 90 80) (width 0.2) (layer "F.Cu") (net 30))
  (segment (start 85 73) (end 92 80) (width 0.2) (layer "F.Cu") (net 31))

  ; UART to FT4232H
  (segment (start 55 35) (end 78 68) (width 0.2) (layer "F.Cu") (net 20))
  (segment (start 57 35) (end 80 68) (width 0.2) (layer "F.Cu") (net 21))

  ; Vias for layer transitions
  (via (at 48 50) (size 0.6) (drill 0.3) (net 2))
  (via (at 52 50) (size 0.6) (drill 0.3) (net 1))
  (via (at 50 48) (size 0.6) (drill 0.3) (net 5))
  (via (at 52 48) (size 0.6) (drill 0.3) (net 6))
  (via (at 30 30) (size 0.6) (drill 0.3) (net 2))
  (via (at 70 30) (size 0.6) (drill 0.3) (net 2))
  (via (at 70 70) (size 0.6) (drill 0.3) (net 2))
  (via (at 30 70) (size 0.6) (drill 0.3) (net 2))

  ; --- Silkscreen ---
  (gr_text "Thermal Phantom v1.0" (at 50 5) (layer "F.SilkS") (tstamp 10))
  (gr_text "Author: jayis1" (at 50 8) (layer "F.SilkS") (tstamp 11))
  (gr_text "WARNING: Class 4 Laser" (at 50 55) (layer "F.SilkS") (tstamp 12))
  (gr_text "Authorized use only" (at 50 57) (layer "F.SilkS") (tstamp 13))

  ; --- Design rules ---
  (dimension (type orthogonal) (layer "Dwgs.User")
    (gr_text "100mm" (at 50 -2) (layer "Dwgs.User"))
    (pts (xy 0 0) (xy 100 0)))
  (dimension (type orthogonal) (layer "Dwgs.User")
    (gr_text "60mm" (at -2 30) (layer "Dwgs.User") (angle 90))
    (pts (xy 0 0) (xy 0 60)))
)
