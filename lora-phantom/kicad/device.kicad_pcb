  (footprint "Capacitor_SMD:C_0402_1005Metric" (layer "F.Cu")
    (fp_text reference "C2" (at 0 -1) (layer "F.SilkS"))
    (fp_text value "100nF" (at 0 1) (layer "F.Fab"))
