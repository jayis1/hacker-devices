  ; ============================================================
  ; LAYER SETUP
  ; ============================================================
  (layers
    (0 "F.Cu" signal "top copper — RF + signals")
    (1 "In1.Cu" signal "inner 1 — GND plane")
    (2 "In2.Cu" signal "inner 2 — PWR plane (3V3)")
    (31 "B.Cu" signal "bottom copper — signals + passives")
    (32 "B.Adhes" user "B.Adhes")
    (33 "F.Adhes" user "F.Adhes")
    (34 "B.Paste" user "B.Paste")
    (35 "F.Paste" user "F.Paste")
