    (pad "3" smd rect (at 1.1 0.8) (size 1 1) (layers "F.Cu" "F.Paste" "F.Mask") (net 37))
    (pad "4" smd rect (at -1.1 0.8) (size 1 1) (layers "F.Cu" "F.Paste" "F.Mask") (net 2)))

  ; ---- Y2: 32 MHz TCXO ----
