  ; ============================================================
  (zone (net 2) (net_name "GND") (layer "In1.Cu") (tstamp 1000)
    (hatch edge 0.5)
    (connect_pads (clearance 0.3))
    (min_thickness 0.2)
    (fill yes (thermal_gap 0.3) (thermal_bridge_width 0.3))
