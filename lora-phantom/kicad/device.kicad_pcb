  (gr_text "jayis1 2026" (at 42.5 52) (layer "F.SilkS") (size 1 1))
  (gr_text "v1.0" (at 80 52) (layer "F.SilkS") (size 1 1))

  ; ---- Dimensions ----
  (dimension (type orthogonal) (layer "Dwgs.User")
    (pts (xy 0 0) (xy 85 0)) (height -3)
