(kicad_pro
  (version 20240101)
  (generator "kicad")
  
  (general
    (thickness 1.6)
  )
  
  (paper "A4")
  
  (title_block
    (title "Substation - Sub-GHz IoT Gateway Implant")
    (date "2026-06-14")
    (rev "1.0")
    (company "Hacker Devices")
    (comment 1 "CC1352P Multi-Protocol Sub-GHz Attack Platform")
    (comment 2 "BOM < $85 | 85mm x 54mm")
  )
  
  (layers
    (0 "F.Cu" signal)
    (1 "In1.Cu" signal)
    (2 "In2.Cu" signal)
    (3 "In3.Cu" signal)
    (4 "In4.Cu" signal)
    (31 "B.Cu" signal)
    (32 "B.Adhes" user)
    (33 "F.Adhes" user)
    (34 "B.Paste" user)
    (35 "F.Paste" user)
    (36 "B.SilkS" user)
    (37 "F.SilkS" user)
    (38 "B.Mask" user)
    (39 "F.Mask" user)
    (40 "Dwgs.User" user)
    (41 "Cmts.User" user)
    (42 "Eco1.User" user)
    (43 "Eco2.User" user)
    (44 "Edge.Cuts" user)
    (45 "Margin" user)
    (46 "B.CrtYd" user)
    (47 "F.CrtYd" user)
    (48 "B.Fab" user)
    (49 "F.Fab" user)
  )
  
  (setup
    (stackup
      (layer "F.Cu" (type "copper") (thickness 0.035))
      (layer "F.Paste" (type "dielectric") (thickness 0.1) (material "Prepreg 1080") (epsilon_r 4.4))
      (layer "In1.Cu" (type "copper") (thickness 0.035))
      (layer "In2.Cu" (type "dielectric") (thickness 0.5) (material "FR4") (epsilon_r 4.4))
      (layer "In3.Cu" (type "copper") (thickness 0.035))
      (layer "In3.Paste" (type "dielectric") (thickness 0.12) (material "Prepreg 2116") (epsilon_r 4.4))
      (layer "In4.Cu" (type "copper") (thickness 0.035))
      (layer "In4.Cu" (type "dielectric") (thickness 0.5) (material "FR4") (epsilon_r 4.4))
      (layer "B.Cu" (type "copper") (thickness 0.035))
    )
    (pad_size 0.5 0.5)
    (pad_drill 0.2)
    (pad_to_mask_clearance 0.05)
    (grid_origin 0 0)
    (pcbplotparams
      (layerselection 0x00010fc_ffffffff)
      (plot_on_all_layers_selection 0x0000000_00000000)
      (disable_apert_macros false)
      (use_gerber_extensions true)
      (use_gerber_attributes true)
      (use_gerber_advanced_attributes true)
      (create_gerber_job_file true)
      (dashed_line_dash_ratio 12.0)
      (dashed_line_gap_ratio 3.0)
      (svgprecision 4)
      (aux_origin 0 0)
      (plotmode 1)
      (excludeedgelayer true)
      (plotframeref false)
      (viasonmask false)
      (creategerberjobfile false)
      (svguseinch false)
      (svgroundcorder false)
    )
  )
  
  (netclass ""
    (clearance 0.15)
    (trace_width 0.15)
    (via_dia 0.4)
    (via_drill 0.2)
    (uvia_dia 0.4)
    (uvia_drill 0.2)
    (diff_pair_gap 0.12)
    (diff_pair_width 0.18)
  )
  
  (netclass "Power"
    (clearance 0.2)
    (trace_width 0.4)
    (via_dia 0.6)
    (via_drill 0.3)
  )
  
  (netclass "RF"
    (clearance 0.3)
    (trace_width 0.3)
    (via_dia 0.4)
    (via_drill 0.2)
  )
  
  (netclass "HighSpeed"
    (clearance 0.15)
    (trace_width 0.15)
    (via_dia 0.4)
    (via_drill 0.2)
    (diff_pair_gap 0.12)
    (diff_pair_width 0.18)
  )
  
  (netclass "USB"
    (clearance 0.2)
    (trace_width 0.18)
    (via_dia 0.4)
    (via_drill 0.2)
    (diff_pair_gap 0.12)
    (diff_pair_width 0.18)
  )
  
  (nets
    ; Power nets
    "VBUS_5V" "VDD_MAIN" "VDD_CORE" "VDD_RF" "VDD_PA" "BAT+"
    "GND"
    
    ; SDRAM interface
    "SDRAM_CLK" "SDRAM_CS" "SDRAM_DQS"
    "SDRAM_DQ0" "SDRAM_DQ1" "SDRAM_DQ2" "SDRAM_DQ3"
    "SDRAM_DQ4" "SDRAM_DQ5" "SDRAM_DQ6" "SDRAM_DQ7"
    "SDRAM_DQ8" "SDRAM_DQ9" "SDRAM_DQ10" "SDRAM_DQ11"
    "SDRAM_DQ12" "SDRAM_DQ13" "SDRAM_DQ14" "SDRAM_DQ15"
    
    ; SPI Flash
    "FLASH_CLK" "FLASH_MOSI" "FLASH_MISO" "FLASH_CS"
    
    ; I2C (ATECC608A)
    "I2C_SDA" "I2C_SCL"
    
    ; MicroSD
    "SD_CLK" "SD_MOSI" "SD_MISO" "SD_CS" "SD_CD"
    
    ; USB
    "USB_DP" "USB_DM"
    
    ; UART
    "UART0_TX" "UART0_RX" "UART1_TX" "UART1_RX"
    
    ; RF
    "SUB_GHZ_PA" "SUB_GHZ_LNA" "BLE_RF" "SUB_GHZ_ANT" "BLE_ANT"
    
    ; Misc
    "WS2812B_DATA" "BTN_MODE" "BTN_ACTION" "SWD_CLK" "SWD_IO"
    "SWD_TDI" "SWD_TDO" "RESET"
  )
)