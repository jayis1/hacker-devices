(kicad_pcb
  (version 20240101)
  (generator "kicad")
  
  (general
    (thickness 1.6)
    (drawings 12)
    (tracks 0)
    (zones 0)
    (net_count 45)
  )
  
  (paper "A4")
  
  (title_block
    (title "Substation - Sub-GHz IoT Gateway Implant")
    (date "2026-06-14")
    (rev "1.0")
    (company "Hacker Devices")
  )
  
  ;; ========================================
  ;; LAYER STACKUP
  ;; ========================================
  (setup
    (stackup
      (layer "F.Cu" (type "copper") (thickness 0.035) (material "copper"))
      (layer "F.Paste" (type "paste") (thickness 0.01))
      (layer "F.Mask" (type "mask") (thickness 0.01) (material "soldermask") (color "green"))
      (layer "Dielectric1" (type "dielectric") (thickness 0.1) (material "Prepreg 1080") (epsilon_r 4.4) (loss_tan 0.02))
      (layer "In1.Cu" (type "copper") (thickness 0.035) (material "copper") (name "GND1"))
      (layer "Dielectric2" (type "dielectric") (thickness 0.5) (material "FR4") (epsilon_r 4.4) (loss_tan 0.02))
      (layer "In2.Cu" (type "copper") (thickness 0.035) (material "copper") (name "PWR"))
      (layer "Dielectric3" (type "dielectric") (thickness 0.12) (material "Prepreg 2116") (epsilon_r 4.4) (loss_tan 0.02))
      (layer "In3.Cu" (type "copper") (thickness 0.035) (material "copper") (name "GND2"))
      (layer "Dielectric4" (type "dielectric") (thickness 0.5) (material "FR4") (epsilon_r 4.4) (loss_tan 0.02))
      (layer "In4.Cu" (type "copper") (thickness 0.035) (material "copper") (name "Signal2"))
      (layer "Dielectric5" (type "dielectric") (thickness 0.1) (material "Prepreg 1080") (epsilon_r 4.4) (loss_tan 0.02))
      (layer "B.Cu" (type "copper") (thickness 0.035) (material "copper"))
      (layer "B.Mask" (type "mask") (thickness 0.01) (material "soldermask") (color "green"))
    )
    
    (pad_size 0.5 0.5)
    (pad_drill 0.2)
    (pad_to_mask_clearance 0.05)
    (solder_mask_min_width 0.1)
    (grid_origin 0 0)
    
    (defaults
      (edge_clearance 0.5)
      (courtyard_clearance 0.25)
    )
    
    (pcbplotparams
      (layerselection 0x00010fc_ffffffff)
      (plot_on_all_layers_selection 0x0000000_00000000)
      (disable_apert_macros false)
      (use_gerber_extensions true)
      (use_gerber_attributes true)
      (use_gerber_advanced_attributes true)
      (create_gerber_job_file true)
    )
  )
  
  ;; ========================================
  ;; NET CLASSES
  ;; ========================================
  (net_class "Default"
    (clearance 0.15)
    (trace_width 0.15)
    (via_dia 0.4)
    (via_drill 0.2)
    (uvia_dia 0.4)
    (uvia_drill 0.2)
    (diff_pair_gap 0.12)
    (diff_pair_width 0.18)
  )
  
  (net_class "Power"
    (clearance 0.2)
    (trace_width 0.4)
    (via_dia 0.6)
    (via_drill 0.3)
    (diff_pair_gap 0.2)
    (diff_pair_width 0.4)
  )
  
  (net_class "RF"
    (clearance 0.3)
    (trace_width 0.3)
    (via_dia 0.4)
    (via_drill 0.2)
    (diff_pair_gap 0.3)
    (diff_pair_width 0.3)
  )
  
  (net_class "HighSpeed"
    (clearance 0.15)
    (trace_width 0.15)
    (via_dia 0.4)
    (via_drill 0.2)
    (diff_pair_gap 0.12)
    (diff_pair_width 0.15)
  )
  
  (net_class "USB"
    (clearance 0.2)
    (trace_width 0.18)
    (via_dia 0.4)
    (via_drill 0.2)
    (diff_pair_gap 0.12)
    (diff_pair_width 0.18)
  )
  
  ;; ========================================
  ;; BOARD OUTLINE (85mm x 54mm, rounded corners)
  ;; ========================================
  (gr_rect (start 0 0) (end 85 54) (stroke (width 0.15) (type solid)) (fill none) (layer "Edge.Cuts"))
  ;; Rounded corners using arcs (1.5mm radius)
  (gr_arc (start 1.5 1.5) (mid 0 1.5) (end 0 0) (stroke (width 0.15)) (layer "Edge.Cuts"))
  (gr_arc (start 83.5 1.5) (mid 85 1.5) (end 85 0) (stroke (width 0.15)) (layer "Edge.Cuts"))
  (gr_arc (start 1.5 52.5) (mid 0 52.5) (end 0 54) (stroke (width 0.15)) (layer "Edge.Cuts"))
  (gr_arc (start 83.5 52.5) (mid 85 52.5) (end 85 54) (stroke (width 0.15)) (layer "Edge.Cuts"))
  
  ;; ========================================
  ;; MOUNTING HOLES (M2.5, 4 corners)
  ;; ========================================
  (footprint "MountingHole:MountingHole_2.7mm_M2.5" (at 3.5 3.5) (layer "F.Cu")
    (uuid mount1)
    (pad "" np_thru_hole circle (at 0 0) (size 2.7 2.7) (drill 2.7))
  )
  (footprint "MountingHole:MountingHole_2.7mm_M2.5" (at 81.5 3.5) (layer "F.Cu")
    (uuid mount2)
    (pad "" np_thru_hole circle (at 0 0) (size 2.7 2.7) (drill 2.7))
  )
  (footprint "MountingHole:MountingHole_2.7mm_M2.5" (at 3.5 50.5) (layer "F.Cu")
    (uuid mount3)
    (pad "" np_thru_hole circle (at 0 0) (size 2.7 2.7) (drill 2.7))
  )
  (footprint "MountingHole:MountingHole_2.7mm_M2.5" (at 81.5 50.5) (layer "F.Cu")
    (uuid mount4)
    (pad "" np_thru_hole circle (at 0 0) (size 2.7 2.7) (drill 2.7))
  )
  
  ;; ========================================
  ;; FIDUCIALS
  ;; ========================================
  (footprint "Fiducial:Fiducial_1mm_Mask2mm" (at 5 5) (layer "F.Cu") (uuid fid1))
  (footprint "Fiducial:Fiducial_1mm_Mask2mm" (at 80 5) (layer "F.Cu") (uuid fid2))
  (footprint "Fiducial:Fiducial_1mm_Mask2mm" (at 5 49) (layer "F.Cu") (uuid fid3))
  
  ;; ========================================
  ;; BLE ANTENNA KEEPOUT ZONE (bottom-right)
  ;; ========================================
  (gr_rect (start 45 39) (end 85 54) (stroke (width 0.1) (type dash)) (fill none) (layer "Dwgs.User"))
  (gr_text "BLE ANTENNA KEEPOUT\nNo copper on any layer\n40mm × 15mm" (at 65 46.5) (layer "Dwgs.User")
    (effects (font (size 1 1) (thickness 0.1)))
  )
  
  ;; ========================================
  ;; COMPONENT PLACEMENT
  ;; ========================================
  
  ;; CC1352P SoC (U1) - Center of board
  (footprint "Package_DFN_QFN:QFN-48-1EP_7x7mm_P0.5mm_EP4x4mm" (at 35 42)
