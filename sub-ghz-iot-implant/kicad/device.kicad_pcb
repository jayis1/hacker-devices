  ;; ========================================
  ;; BLE INVERTED-F ANTENNA TRACE (on bottom edge)
  ;; ========================================
  (gr_line (start 45 42) (end 55 42) (stroke (width 0.25) (type solid)) (layer "F.Cu"))
  (gr_line (start 55 42) (end 55 54) (stroke (width 0.25) (type solid)) (layer "F.Cu"))
  (gr_line (start 55 54) (end 83 54) (stroke (width 0.25) (type solid)) (layer "F.Cu"))
