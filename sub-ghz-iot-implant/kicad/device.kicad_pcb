    (connect_pads (clearance 0.2))
    (min_thickness 0.15)
    (fill (thermal_gap 0.3) (thermal_bridge_width 0.3))
    (polygon (pts (xy 1 1) (xy 84 1) (xy 84 53) (xy 1 53)))
  )
  
