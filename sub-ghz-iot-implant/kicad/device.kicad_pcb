    (reference "U1")
    (value "CC1352P1F3RGZ")
    (property "Sheetfile" "device.kicad_sch")
    (property "Sheetname" "SoC")
    ;; Thermal pad: 9 vias (0.3mm drill) to L2 ground
    (pad "" thru_hole circle (at -1.5 -1.5) (size 0.6 0.6) (drill 0.3) (layers "*.Cu") (net "GND"))
    (pad "" thru_hole circle (at -0.5 -1.5) (size 0.6 0.6) (drill 0.3) (layers "*.Cu") (net "GND"))
    (pad "" thru_hole circle (at 0.5 -1.5) (size 0.6 0.6) (drill 0.3) (layers "*.Cu") (net "GND"))
    (pad "" thru_hole circle (at 1.5 -1.5) (size 0.6 0.6) (drill 0.3) (layers "*.Cu") (net "GND"))
    (pad "" thru_hole circle (at -1.5 -0.5) (size 0.6 0.6) (drill 0.3) (layers "*.Cu") (net "GND"))
    (pad "" thru_hole circle (at -0.5 -0.5) (size 0.6 0.6) (drill 0.3) (layers "*.Cu") (net "GND"))
    (pad "" thru_hole circle (at 0.5 -0.5) (size 0.6 0.6) (drill 0.3) (layers "*.Cu") (net "GND"))
    (pad "" thru_hole circle (at 1.5 -0.5) (size 0.6 0.6) (drill 0.3) (layers "*.Cu") (net "GND"))
    (pad "" thru_hole circle (at 0 0.5) (size 0.6 0.6) (drill 0.3) (layers "*.Cu") (net "GND"))
  )
  
  ;; SDRAM #1 (U2)
