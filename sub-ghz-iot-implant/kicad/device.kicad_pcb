    (connect_pads (clearance 0.2))
    (min_thickness 0.15)
    (fill (thermal_gap 0.3) (thermal_bridge_width 0.3))
    (polygon (pts (xy 2 2) (xy 83 2) (xy 83 38) (xy 2 38)))
  )
  
  (zone (net "VDD_CORE") (net_name "VDD_CORE") (layer "In2.Cu")
