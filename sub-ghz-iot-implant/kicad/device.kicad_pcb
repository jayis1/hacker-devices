  (gr_line (start 35 42) (end 3 50) (stroke (width 0.3) (type solid)) (layer "F.Cu"))
  (gr_text "SUB-GHZ 50Ω" (at 15 48) (layer "F.SilkS")
    (effects (font (size 0.8 0.8) (thickness 0.1)))
  )
  
  ;; ========================================
  ;; GROUND PLANE ZONE (on In1.Cu = L2)
  ;; ========================================
  (zone (net "GND") (net_name "GND") (layer "In1.Cu")
