  ; ========== NET CONNECTIONS ==========

  ; ---- Power: VBUS (USB) → MCP73831 → VBAT (LiPo) → LDOs → VCC_3V3 / VCC_1V2 ----

  (net "VBUS"
    (node (ref J1) (pin "VBUS"))
    (node (ref U10) (pin "VDD"))
  )

  (net "VBAT"
    (node (ref U10) (pin "VBAT"))
    (node (ref BAT1) (pin "+"))
    (node (ref U8) (pin "VIN"))
    (node (ref U9) (pin "VIN"))
    (node (ref U12) (pin "VIN"))
  )

  (net "VCC_3V3"
    (node (ref U8) (pin "VOUT"))
    (node (ref U1) (pin "VCC_3V3"))
    (node (ref U2) (pin "VCC_3V3"))
    (node (ref U3) (pin "VCC"))
    (node (ref U4) (pin "VCC_3V3"))
    (node (ref U7) (pin "VCC"))
    (node (ref J2) (pin "VCC"))
  )

  (net "VCC_1V2"
    (node (ref U9) (pin "VOUT"))
    (node (ref U2) (pin "VCC_1V2"))
  )

  (net "VCC_5V"
    (node (ref J1) (pin "VBUS"))
  )

  (net "VAPD_65V"
    (node (ref U12) (pin "VOUT"))
    (node (ref U5) (pin "CATHODE"))
  )

  (net "GND"
    (node (ref J1) (pin "GND"))
    (node (ref U10) (pin "GND"))
    (node (ref U8) (pin "GND"))
    (node (ref U9) (pin "GND"))
    (node (ref U1) (pin "GND"))
    (node (ref U2) (pin "GND"))
    (node (ref U3) (pin "GND"))
    (node (ref U4) (pin "GND"))
    (node (ref U7) (pin "GND"))
    (node (ref U12) (pin "GND"))
    (node (ref J2) (pin "GND"))
    (node (ref J3) (pin "GND"))
    (node (ref BAT1) (pin "-"))
  )

  ; ---- RP2040 ↔ FPGA SPI (SPI0) ----

  (net "FPGA_SCK"
    (node (ref U1) (pin "GPIO2"))
    (node (ref U2) (pin "SCK"))
  )

  (net "FPGA_MOSI"
    (node (ref U1) (pin "GPIO3"))
    (node (ref U2) (pin "SDI"))
  )

  (net "FPGA_MISO"
    (node (ref U1) (pin "GPIO4"))
    (node (ref U2) (pin "SDO"))
  )

  (net "FPGA_CS_N"
    (node (ref U1) (pin "GPIO5"))
    (node (ref U2) (pin "CS_N"))
  )

  (net "FPGA_CDONE"
    (node (ref U1) (pin "GPIO6"))
    (node (ref U2) (pin "CDONE"))
  )

  (net "FPGA_CRESET_N"
    (node (ref U1) (pin "GPIO7"))
    (node (ref U2) (pin "CRESET_N"))
  )

  (net "FPGA_IRQ"
    (node (ref U1) (pin "GPIO8"))
    (node (ref U2) (pin "IO_0"))
  )

  ; ---- RP2040 ↔ SD Card SPI (SPI1) ----

  (net "SD_SCK"
    (node (ref U1) (pin "GPIO10"))
    (node (ref J2) (pin "SCK"))
  )

  (net "SD_MOSI"
    (node (ref U1) (pin "GPIO11"))
    (node (ref J2) (pin "MOSI"))
  )

  (net "SD_MISO"
    (node (ref U1) (pin "GPIO12"))
    (node (ref J2) (pin "MISO"))
  )

  (net "SD_CS_N"
    (node (ref U1) (pin "GPIO13"))
    (node (ref J2) (pin "CS_N"))
  )

  (net "SD_DETECT"
    (node (ref U1) (pin "GPIO14"))
    (node (ref J2) (pin "DET"))
  )

  ; ---- RP2040 ↔ nRF52840 UART ----

  (net "BLE_TX"
    (node (ref U1) (pin "GPIO16"))
    (node (ref U3) (pin "UART_RX"))
  )

  (net "BLE_RX"
    (node (ref U1) (pin "GPIO17"))
    (node (ref U3) (pin "UART_TX"))
  )

  (net "BLE_CTS"
    (node (ref U1) (pin "GPIO18"))
    (node (ref U3) (pin "UART_CTS"))
  )

  (net "BLE_RTS"
    (node (ref U1) (pin "GPIO19"))
    (node (ref U3) (pin "UART_RTS"))
  )

  (net "BLE_NRESET"
    (node (ref U1) (pin "GPIO20"))
    (node (ref U3) (pin "RESET_N"))
  )

  ; ---- APD bias control ----

  (net "APD_BIAS_DAC"
    (node (ref U1) (pin "GPIO22"))
  )

  (net "APD_BOOST_EN"
    (node (ref U1) (pin "GPIO23"))
    (node (ref U12) (pin "EN"))
  )

  (net "APD_LEVEL_ADC"
