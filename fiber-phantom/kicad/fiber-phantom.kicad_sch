    (node (ref U4) (pin "MONITOR"))
  )

  (net "APD_BIAS_FB"
    (node (ref U12) (pin "FB"))
  )

  ; ---- Optical signal path ----

  (net "APD_ANODE"
    (node (ref U5) (pin "ANODE"))
    (node (ref U4) (pin "IN_P"))
  )

  (net "TIA_OUT_P"
    (node (ref U4) (pin "OUT_P"))
    (node (ref U2) (pin "DATA_RX_P"))
  )

  (net "TIA_OUT_N"
    (node (ref U4) (pin "OUT_N"))
    (node (ref U2) (pin "DATA_RX_N"))
  )

  ; ---- VCSEL modulation ----

  (net "VCSEL_EN"
    (node (ref U1) (pin "GPIO24"))
  )

  (net "VCSEL_MOD_P"
    (node (ref U1) (pin "GPIO25"))
    (node (ref U2) (pin "DATA_TX_P"))
  )

  (net "VCSEL_MOD_N"
    (node (ref U1) (pin "GPIO15"))
    (node (ref U2) (pin "DATA_TX_N"))
  )

  ; ---- Optical coupler ----

  (net "COUPLER_TAP_OUT"
    (node (ref OPT1) (pin "PORT4_OUT"))
    (node (ref U5) (pin "CATHODE"))
  )

  ; ---- Mode straps ----

  (net "MODE_STRAP0"
    (node (ref U1) (pin "GPIO27"))
  )

  (net "MODE_STRAP1"
    (node (ref U1) (pin "GPIO28"))
  )

  ; ---- LEDs ----

  (net "LED_R"
    (node (ref U1) (pin "GPIO9"))
  )

  (net "LED_G"
    (node (ref U1) (pin "GPIO29"))
  )

  ; ---- USB ----

  (net "USB_DP"
    (node (ref J1) (pin "DP1"))
    (node (ref U1) (pin "USB_DP"))
  )

  (net "USB_DM"
    (node (ref J1) (pin "DN1"))
    (node (ref U1) (pin "USB_DM"))
  )

  ; ---- Crystal ----

  (net "XIN"
    (node (ref U1) (pin "XIN"))
    (node (ref Y1) (pin "1"))
  )

  (net "XOUT"
    (node (ref U1) (pin "XOUT"))
    (node (ref Y1) (pin "2"))
  )

  ; ---- FPGA config flash ----

  (net "FLASH_CS_N"
    (node (ref U2) (pin "IO_1"))
    (node (ref U7) (pin "CS_N"))
  )

  (net "FLASH_DO"
    (node (ref U7) (pin "DO"))
    (node (ref U2) (pin "IO_2"))
  )

  (net "FLASH_DI"
    (node (ref U7) (pin "DI"))
    (node (ref U2) (pin "IO_3"))
  )

  (net "FLASH_CLK"
    (node (ref U7) (pin "CLK"))
    (node (ref U2) (pin "IO_4"))
  )

  ; ---- SFP+ signals (pass-through mode) ----

  (net "SFP_RX_P"
    (node (ref J3) (pin "RD_P"))
    (node (ref U2) (pin "IO_5"))
  )

  (net "SFP_RX_N"
    (node (ref J3) (pin "RD_N"))
    (node (ref U2) (pin "IO_6"))
  )

  (net "SFP_TX_P"
    (node (ref U2) (pin "IO_7"))
    (node (ref J3) (pin "TD_P"))
  )

  (net "SFP_SDA"
    (node (ref U1) (pin "GPIO21"))
    (node (ref J3) (pin "SDA"))
  )

  ; ---- VCSEL drive ----

  (net "VCSEL_ANODE"
    (node (ref U6) (pin "ANODE"))
    (node (ref U2) (pin "DATA_TX_P"))
  )

  (net "VCSEL_CATHODE"
    (node (ref U6) (pin "CATHODE"))
    (node (ref U2) (pin "DATA_TX_N"))
  )

  ; ---- Coupler injection ----

  (net "COUPLER_INJECT"
    (node (ref U6) (pin "ANODE"))
    (node (ref OPT1) (pin "PORT2_IN"))
  )

)