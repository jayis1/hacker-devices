    (property "Value" "100nF")
    (pad "1" smd roundrect (at -0.5 0 0) (size 0.5 0.6) (layers "F.Cu" "F.Paste" "F.Mask") (net 2))
    (pad "2" smd roundrect (at 0.5 0 0) (size 0.5 0.6) (layers "F.Cu" "F.Paste" "F.Mask") (net 1))
  )

  (footprint "Capacitor_SMD:C_0402"
    (layer "F.Cu")
    (at 26 10)
    (property "Reference" "C2")
    (property "Value" "100nF")
    (pad "1" smd roundrect (at -0.5 0 0) (size 0.5 0.6) (layers "F.Cu" "F.Paste" "F.Mask") (net 2))
    (pad "2" smd roundrect (at 0.5 0 0) (size 0.5 0.6) (layers "F.Cu" "F.Paste" "F.Mask") (net 1))
  )

  (footprint "Resistor_SMD:R_0402"
    (layer "F.Cu")
    (at 5 38)
    (property "Reference" "R1")
    (property "Value" "1k")
    (pad "1" smd roundrect (at -0.5 0 0) (size 0.5 0.6) (layers "F.Cu" "F.Paste" "F.Mask") (net 30))
    (pad "2" smd roundrect (at 0.5 0 0) (size 0.5 0.6) (layers "F.Cu" "F.Paste" "F.Mask") (net 2))
  )

  ;; Zones
  (zone (net 1) (net_name "GND") (layer "In1.Cu") (tstamp 0)
    (hatch edge 0.508)
    (connect_pads (clearance 0.3))
    (min_thickness 0.2)
    (fill yes (thermal_gap 0.3) (thermal_bridge_width 0.3))
    (polygon
      (pts (xy 0 0) (xy 70 0) (xy 70 45) (xy 0 45))
    )
  )

  (zone (net 2) (net_name "+3V3") (layer "In2.Cu") (tstamp 1)
    (hatch edge 0.508)
    (connect_pads (clearance 0.3))
    (min_thickness 0.2)
    (fill yes (thermal_gap 0.3) (thermal_bridge_width 0.3))
    (polygon
      (pts (xy 5 5) (xy 65 5) (xy 65 40) (xy 5 40))
    )
  )

  (zone (net 1) (net_name "GND") (layer "B.Cu") (tstamp 2)
    (hatch edge 0.508)
    (connect_pads (clearance 0.3))
    (min_thickness 0.2)
    (fill yes (thermal_gap 0.3) (thermal_bridge_width 0.3))
    (polygon
      (pts (xy 0 0) (xy 70 0) (xy 70 45) (xy 0 45))
    )
  )

  (segment (start 20 11.4) (end 25 11.4) (width 0.2) (layer "F.Cu") (net 2))
  (segment (start 25 11.4) (end 25 10.5) (width 0.2) (layer "F.Cu") (net 2))
  (segment (start 20 15) (end 37.8 15) (width 0.2) (layer "F.Cu") (net 10))
