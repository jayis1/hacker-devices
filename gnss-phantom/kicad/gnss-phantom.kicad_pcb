    (property "Value" "LED_Blue")
    (pad "1" smd roundrect (at -0.8 0 0) (size 0.8 0.8) (layers "F.Cu" "F.Paste" "F.Mask") (net 30))
    (pad "2" smd roundrect (at 0.8 0 0) (size 0.8 0.8) (layers "F.Cu" "F.Paste" "F.Mask") (net 1))
