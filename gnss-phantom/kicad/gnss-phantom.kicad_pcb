(kicad_pcb
  (version 20240108)
  (generator "kicad-pcb")
  (generator_version "8.0")
  (general
    (thickness 1.6)
    (legacy_teardrops no)
  )
  (paper "A4")
  (title_block
    (title "GNSS-Phantom GPX-1 PCB")
    (date "2026-06-18")
    (rev "1.0")
    (company "jayis1")
    (comment 1 "Author: jayis1")
    (comment 2 "4-layer RF PCB, 1.6mm, Rogers RO4350B + FR4 hybrid")
    (comment 3 "AUTHORIZED SECURITY RESEARCH USE ONLY")
  )

  (layers
    (0 "F.Cu" signal "Top - RF + Components")
    (1 "In1.Cu" signal "Inner 1 - GND plane")
    (2 "In2.Cu" signal "Inner 2 - Power plane (+3V3)")
    (31 "B.Cu" signal "Bottom - routing + GND")
    (32 "B.Adhes" user "B.Adhesive")
    (33 "F.Adhes" user "F.Adhesive")
    (34 "B.Paste" user "B.Paste")
    (35 "F.Paste" user "F.Paste")
    (36 "B.SilkS" user "B.Silkscreen")
    (37 "F.SilkS" user "F.Silkscreen")
    (38 "B.Mask" user "B.Mask")
    (39 "F.Mask" user "F.Mask")
    (40 "Dwgs.User" user "User.Drawings")
    (41 "Cmts.User" user "User.Comments")
    (42 "Eco1.User" user "User.Eco1")
    (43 "Eco2.User" user "User.Eco2")
    (44 "Edge.Cuts" user "Edge.Cuts")
    (45 "Margin" user "Margin")
    (46 "B.CrtYd" user "B.Courtyard")
    (47 "F.CrtYd" user "F.Courtyard")
    (48 "B.Fab" user "B.Fabrication")
    (49 "F.Fab" user "F.Fabrication")
  )

  (setup
    (stackup
      (layer "F.Cu" (type "copper") (thickness 0.035))
      (layer "dielectric 1" (type "prepreg") (thickness 0.2) (material "Rogers RO4350B"))
      (layer "In1.Cu" (type "copper") (thickness 0.035))
      (layer "dielectric 2" (type "core") (thickness 0.71) (material "FR4"))
      (layer "In2.Cu" (type "copper") (thickness 0.035))
      (layer "dielectric 3" (type "prepreg") (thickness 0.2) (material "Rogers RO4350B"))
      (layer "B.Cu" (type "copper") (thickness 0.035))
      (layer "F.Paste" (type "solderpaste") (thickness 0))
      (layer "F.Mask" (type "mask") (thickness 0.01))
      (layer "B.Mask" (type "mask") (thickness 0.01))
      (layer "F.SilkS" (type "silk") (thickness 0.015))
      (layer "B.SilkS" (type "silk") (thickness 0.015))
      (copper_finish "ENIG")
      (dielectric_constraints no)
    )
    (pad_to_mask_clearance 0.05)
    (pcbplotparams
      (layerselection 0x00010e0_ffffffff)
      (plot_on_all_layers_selection 0x0000000_00000000)
      (disableapertmacros no)
      (usegerberextensions no)
      (usegerberattributes yes)
      (usegerberadvancedattributes yes)
      (creategerberjobfile yes)
      (dashed_line_dash_ratio 12.000000)
      (dashed_line_gap_ratio 3.000000)
      (svgprecision 4)
      (plotframeref no)
      (viasonmask no)
      (mode 1)
      (useauxorigin no)
      (hpglpennumber 1)
      (hpglpenspeed 20)
      (hpglpendiameter 15.000000)
      (dxfpolygonmode yes)
      (dxfimperialunits yes)
      (dxfusepgmpoints no)
      (dxfpolygonmode yes)
      (psnegative no)
      (psa4output yes)
      (plotreference yes)
      (plotvalue yes)
      (plotfabbext no)
      (plotinvisibletext no)
      (padsonsilk no)
      (subtractmaskfromsilk no)
      (outputformat 1)
      (mirror no)
      (auxorigin "0 0")
      (scaling 1 1)
    )
  )

  (net 0 "")
  (net 1 "GND")
  (net 2 "+3V3")
  (net 3 "VBAT")
  (net 4 "+5V_USB")
  (net 5 "VCC_RF")
  (net 10 "SPI2_SCLK")
  (net 11 "SPI2_MOSI")
  (net 12 "SPI2_MISO")
  (net 13 "SI4463_GPS_SEL")
  (net 14 "SI4463_GPS_SDN")
  (net 15 "SI4463_GPS_IRQ")
  (net 16 "SI4463_GLO_SEL")
  (net 17 "SI4463_GLO_SDN")
  (net 18 "SI4463_GLO_IRQ")
  (net 20 "USART2_TX")
  (net 21 "USART2_RX")
  (net 22 "USART3_TX")
  (net 23 "USART3_RX")
  (net 30 "LED_STATUS")
  (net 31 "LED_SPOOF")
  (net 32 "LED_RX")
  (net 33 "LED_PWR")
  (net 40 "TCXO_EN")
  (net 41 "PA_EN")
  (net 42 "TX_RX_SW")
  (net 50 "TCXO_OUT")
  (net 51 "I2C1_SCL")
  (net 52 "I2C1_SDA")
  (net 60 "RF_TX")
  (net 61 "RF_RX")
  (net 70 "BTN_MODE")
  (net 71 "BTN_FIRE")
  (net 72 "BTN_SAFE")
  (net 80 "PPS_OUT")
  (net 90 "BATT_ADC")

  ;; Board outline: 70 x 45 mm
  (gr_line (start 0 0) (end 70 0)
    (stroke (width 0.2) (type solid)) (layer "Edge.Cuts"))
  (gr_line (start 70 0) (end 70 45)
    (stroke (width 0.2) (type solid)) (layer "Edge.Cuts"))
  (gr_line (start 70 45) (end 0 45)
    (stroke (width 0.2) (type solid)) (layer "Edge.Cuts"))
  (gr_line (start 0 45) (end 0 0)
    (stroke (width 0.2) (type solid)) (layer "Edge.Cuts"))

  ;; Dimension markers
  (gr_text "70mm"
    (at 35 -2 0)
    (layer "Cmts.User")
    (effects (font (size 1 1)) (justify center))
  )
  (gr_text "45mm"
    (at -2 22.5 90)
    (layer "Cmts.User")
    (effects (font (size 1 1)) (justify center))
  )
  (gr_text "GNSS-Phantom GPX-1 | jayis1 | v1.0"
    (at 35 43 0)
    (layer "F.SilkS")
    (effects (font (size 0.8 0.8)) (justify center))
  )
  (gr_text "AUTHORIZED USE ONLY"
    (at 35 2 0)
    (layer "F.SilkS")
    (effects (font (size 0.6 0.6) bold) (justify center) (color 255 0 0 1))
  )

  ;; Footprints placed on board
  (footprint "Package_BGA:TFBGA-100_8x8mm_P0.8mm"
    (layer "F.Cu")
    (at 20 15)
    (property "Reference" "U1")
    (property "Value" "STM32H743VIT6")
    (property "Author" "jayis1")
    (pad "A1" smd circle (at -3.6 -3.6 0) (size 0.35 0.35) (layers "F.Cu" "F.Mask") (net 2))
    (pad "A2" smd circle (at -2.8 -3.6 0) (size 0.35 0.35) (layers "F.Cu" "F.Mask") (net 1))
    (model "${KISYS3DMOD}/Package_BGA.3dshapes/TFBGA-100_8x8mm_P0.8mm.wrl"
      (offset (xyz 0 0 0)) (scale (xyz 1 1 1)) (rotate (xyz 0 0 0)))
  )

  (footprint "Package_SO:SSOP-20_4.4x6.5mm_P0.65mm"
    (layer "F.Cu")
    (at 40 12)
    (property "Reference" "U2")
    (property "Value" "Si4463")
    (property "Author" "jayis1")
    (pad "1" smd roundrect (at -2.2 -3.9 0) (size 0.4 0.5) (layers "F.Cu" "F.Paste" "F.Mask") (net 14))
    (pad "4" smd roundrect (at -2.2 -1.95 0) (size 0.4 0.5) (layers "F.Cu" "F.Paste" "F.Mask") (net 2))
    (pad "11" smd roundrect (at -2.2 2.6 0) (size 0.4 0.5) (layers "F.Cu" "F.Paste" "F.Mask") (net 13))
    (pad "12" smd roundrect (at -2.2 3.25 0) (size 0.4 0.5) (layers "F.Cu" "F.Paste" "F.Mask") (net 10))
    (pad "13" smd roundrect (at -2.2 3.9 0) (size 0.4 0.5) (layers "F.Cu" "F.Paste" "F.Mask") (net 11))
    (pad "14" smd roundrect (at 2.2 3.9 0) (size 0.4 0.5) (layers "F.Cu" "F.Paste" "F.Mask") (net 12))
    (pad "20" smd roundrect (at 2.2 -3.9 0) (size 0.4 0.5) (layers "F.Cu" "F.Paste" "F.Mask") (net 60))
  )

  (footprint "Package_SO:SSOP-20_4.4x6.5mm_P0.65mm"
    (layer "F.Cu")
    (at 40 25)
    (property "Reference" "U3")
    (property "Value" "Si4463")
    (property "Author" "jayis1")
    (pad "1" smd roundrect (at -2.2 -3.9 0) (size 0.4 0.5) (layers "F.Cu" "F.Paste" "F.Mask") (net 17))
    (pad "4" smd roundrect (at -2.2 -1.95 0) (size 0.4 0.5) (layers "F.Cu" "F.Paste" "F.Mask") (net 2))
    (pad "11" smd roundrect (at -2.2 2.6 0) (size 0.4 0.5) (layers "F.Cu" "F.Paste" "F.Mask") (net 16))
    (pad "12" smd roundrect (at -2.2 3.25 0) (size 0.4 0.5) (layers "F.Cu" "F.Paste" "F.Mask") (net 10))
    (pad "13" smd roundrect (at -2.2 3.9 0) (size 0.4 0.5) (layers "F.Cu" "F.Paste" "F.Mask") (net 11))
    (pad "14" smd roundrect (at 2.2 3.9 0) (size 0.4 0.5) (layers "F.Cu" "F.Paste" "F.Mask") (net 12))
    (pad "20" smd roundrect (at 2.2 -3.9 0) (size 0.4 0.5) (layers "F.Cu" "F.Paste" "F.Mask") (net 61))
  )

  (footprint "Oscillator:Oscillator_SMD_TCXO_5032_4Pins"
    (layer "F.Cu")
    (at 55 35)
    (property "Reference" "Y1")
    (property "Value" "TG5032CE-26N")
    (property "Author" "jayis1")
    (pad "1" smd roundrect (at -2.3 -1.3 0) (size 1.6 1.2) (layers "F.Cu" "F.Paste" "F.Mask") (net 2))
    (pad "2" smd roundrect (at -2.3 1.3 0) (size 1.6 1.2) (layers "F.Cu" "F.Paste" "F.Mask") (net 1))
    (pad "3" smd roundrect (at 2.3 -1.3 0) (size 1.6 1.2) (layers "F.Cu" "F.Paste" "F.Mask") (net 50))
    (pad "4" smd roundrect (at 2.3 1.3 0) (size 1.6 1.2) (layers "F.Cu" "F.Paste" "F.Mask") (net 1))
  )

  (footprint "RF_Module:Nordic_M.2"
    (layer "F.Cu")
    (at 15 35)
    (property "Reference" "U4")
    (property "Value" "nRF52840-M.2")
    (property "Author" "jayis1")
    (pad "1" smd roundrect (at -5 -3 0) (size 0.8 0.5) (layers "F.Cu" "F.Paste" "F.Mask") (net 2))
    (pad "2" smd roundrect (at -5 -2 0) (size 0.8 0.5) (layers "F.Cu" "F.Paste" "F.Mask") (net 1))
    (pad "3" smd roundrect (at -5 -1 0) (size 0.8 0.5) (layers "F.Cu" "F.Paste" "F.Mask") (net 20))
    (pad "4" smd roundrect (at -5 0 0) (size 0.8 0.5) (layers "F.Cu" "F.Paste" "F.Mask") (net 21))
  )

  (footprint "Connector_Coaxial:SMA_Amphenol_132289_Edge_Mount"
    (layer "F.Cu")
    (at 65 22.5)
    (property "Reference" "J1")
    (property "Value" "SMA")
    (property "Author" "jayis1")
    (pad "1" smd roundrect (at 0 0 0) (size 2 0.5) (layers "F.Cu" "F.Paste" "F.Mask") (net 60))
    (pad "2" smd roundrect (at 0 -2 0) (size 2 1) (layers "F.Cu" "F.Paste" "F.Mask") (net 1))
  )

  (footprint "LED_SMD:LED_0603"
    (layer "F.Cu")
    (at 5 40)
