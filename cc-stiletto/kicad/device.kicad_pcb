; ---- Copper zones ------------------------------------------------------
(zone (net 24) (net_name "GND") (layer "In2.Cu")
  (hatch edge 0.5)
  (connect_pads (clearance 0.2))
  (fill (thermal_gap 0.3) (thermal_bridge_width 0.5))
  (polygon (pts (xy 0.5 0.5) (xy 51.5 0.5) (xy 51.5 17.5) (xy 0.5 17.5))))

(zone (net 1) (net_name "VBUS_SRC") (layer "In1.Cu")
  (hatch edge 0.5)
