(kicad_pcb
 (version 20230121)
 (generator "cc-stiletto pcb generator")
 (generator_version "7.0")
 (general (thickness 1.6) (legacy_technology false))
 (paper "A4")
 (title_block
  (title "CC-Stiletto — USB-C PD Configuration Channel Attack Tool")
  (date "2026-07-17")
  (rev "1.0")
  (company "jayis1")
  (comment 1 "Author: jayis1")
  (comment 2 "Copyright (c) 2026 jayis1 — authorized security research only")
  (comment 3 "4-layer PCB, 1 oz copper, 52x18mm dongle form factor"))

; ---- Layers --------------------------------------------------------------
(layer "F.Cu"     (type copper))
(layer "In1.Cu"   (type copper)  (thickness 0.035))   ; VBUS plane (cut for 48V)
(layer "In2.Cu"   (type copper)  (thickness 0.035))   ; GND plane
(layer "B.Cu"     (type copper))
(layer "F.SilkS"  (type silk))
(layer "B.SilkS"  (type silk))
(layer "F.Mask"   (type mask))
(layer "B.Mask"   (type mask))
(layer "F.Paste"  (type paste))
(layer "B.Paste"  (type paste))
(layer "Edge.Cuts"(type user))
(layer "F.Fab"    (type fab))
(layer "B.Fab"    (type fab))

(setup
  (pad_to_mask_clearance 0.05)
  (pcbplotparams
    (layerselection 0x0000030c_80000001)
    (usegerberextensions false)
    (usegerberattributes true)
    (svgprecision 6)
    (plotframeref false)
    (mode 1)))

; ---- Board outline: 52 mm x 18 mm dongle --------------------------------
(gr_line (start 0   0)   (end 52 0)   (layer "Edge.Cuts") (width 0.2))
(gr_line (start 52  0)   (end 52 18) (layer "Edge.Cuts") (width 0.2))
(gr_line (start 52  18)  (end 0  18) (layer "Edge.Cuts") (width 0.2))
(gr_line (start 0   18)  (end 0  0)  (layer "Edge.Cuts") (width 0.2))

; ---- Net definitions (must match schematic) -----------------------------
(net 0 "")
(net 1  "VBUS_SRC")
(net 2  "VBUS_SNK")
(net 3  "CC1_SRC")
(net 4  "CC2_SRC")
(net 5  "CC1_SNK")
(net 6  "CC2_SNK")
(net 7  "I2C1_SCL")
(net 8  "I2C1_SDA")
(net 9  "I2C2_SCL")
(net 10 "I2C2_SDA")
(net 11 "I2C3_SCL")
(net 12 "I2C3_SDA")
(net 13 "HRTIM_CHA1")
(net 14 "EFUSE_EN")
(net 15 "EFUSE_FLT")
(net 16 "DAC_VBUS_REF")
(net 17 "DAC_ILIM")
(net 18 "INT_SRC")
(net 19 "INT_SNK")
(net 20 "LED_R")
(net 21 "LED_G")
(net 22 "LED_B")
(net 23 "BUTTON")
(net 24 "GND")
(net 25 "ISO_EN")
(net 26 "VDD_3V3")
(net 27 "VDD_5V_ISO")
(net 28 "SHUNT_SRC")
(net 29 "SHUNT_SRC_OUT")
(net 30 "SWDIO")
(net 31 "SWCLK")
(net 32 "NRST")
(net 33 "USB_DM")
(net 34 "USB_DP")

