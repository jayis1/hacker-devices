(kicad_pcb
  (version 20230621)
  (generator "usb-dma-phantom")
  (general
    (thickness 0.8)
    (drawings 12)
    (tracks 256)
    (zones 8)
    (modules 20)
    (nets 64)
  )
  (page "A4")
  (title_block
    (title "USB DMA Phantom")
    (date "2026-06-15")
    (rev "1.0")
    (company "Hacker Devices")
    (comment 1 "Thunderbolt/USB4 DMA Attack Platform")
    (comment 2 "65x30mm stick form factor")
  )

  ;; ========================================
  ;; Layer Stackup
  ;; ========================================
  (stackup
    (layer "F.Cu" (type copper) (thickness 0.035))
    (layer "dielectric 1" (type prepeg) (thickness 0.1) (material "FR4") (epsilon_r 4.2))
    (layer "In1.Cu" (type copper) (thickness 0.035) (name "GND"))
    (layer "core" (type core) (thickness 0.5) (material "FR4") (epsilon_r 4.2))
    (layer "In2.Cu" (type copper) (thickness 0.035) (name "PWR/SIG"))
    (layer "dielectric 2" (type prepeg) (thickness 0.1) (material "FR4") (epsilon_r 4.2))
    (layer "B.Cu" (type copper) (thickness 0.035))
  )

  ;; ========================================
  ;; Design Rules
  ;; ========================================
  (setup
    (stack_up
      (layer "F.Cu" (type copper) (thickness 0.035) (material "copper"))
      (layer "Prepeg" (type dielectric) (thickness 0.1) (material "FR4") (epsilon_r 4.2) (loss_tan 0.02))
      (layer "In1.Cu" (type copper) (thickness 0.035) (material "copper") (name "GND"))
      (layer "Core" (type core) (thickness 0.5) (material "FR4") (epsilon_r 4.2) (loss_tan 0.02))
      (layer "In2.Cu" (type copper) (thickness 0.035) (material "copper") (name "PWR/SIG"))
      (layer "Prepeg" (type dielectric) (thickness 0.1) (material "FR4") (epsilon_r 4.2) (loss_tan 0.02))
      (layer "B.Cu" (type copper) (thickness 0.035) (material "copper"))
    )
    (pad_to_mask_clearance 0.051)
    (solder_mask_min_width 0.1)
    (pad_size 0.6 0.6)
    (pad_drill 0.3)
    (grid_origin 0 0)
    (trace_width 0.2)
    (trace_min_width 0.1)
    (via_size 0.4)
    (via_drill 0.2)
    (via_min_size 0.4)
    (via_min_drill 0.2)
    (uvia_size 0.3)
    (uvia_drill 0.1)
    (diff_pair_width 0.15)
    (diff_pair_gap 0.1)
    (segment_width 0.2)
    (edge_width 0.15)
  )

  ;; ========================================
  ;; Net Classes
  ;; ========================================
  (net_class "Default" ""
    (clearance 0.15)
    (trace_width 0.2)
    (via_dia 0.4)
    (via_drill 0.2)
    (uvia_dia 0.3)
    (uvia_drill 0.1)
    (diff_pair_gap 0.12)
    (diff_pair_width 0.18)
  )
  (net_class "Power" ""
    (clearance 0.2)
    (trace_width 0.5)
    (via_dia 0.6)
    (via_drill 0.3)
    (uvia_dia 0.3)
    (uvia_drill 0.1)
    (diff_pair_gap 0.12)
    (diff_pair_width 0.18)
  )
  (net_class "PCIe Diff" ""
    (clearance 0.15)
    (trace_width 0.15)
    (via_dia 0.4)
    (via_drill 0.2)
    (uvia_dia 0.3)
    (uvia_drill 0.1)
    (diff_pair_gap 0.1)
    (diff_pair_width 0.15)
  )
  (net_class "USB Diff" ""
    (clearance 0.15)
    (trace_width 0.18)
    (via_dia 0.4)
    (via_drill 0.2)
    (uvia_dia 0.3)
    (uvia_drill 0.1)
    (diff_pair_gap 0.12)
    (diff_pair_width 0.18)
  )
  (net_class "High Speed" ""
    (clearance 0.15)
    (trace_width 0.2)
    (via_dia 0.4)
    (via_drill 0.2)
    (uvia_dia 0.3)
    (uvia_drill 0.1)
    (diff_pair_gap 0.12)
    (diff_pair_width 0.18)
  )

  ;; ========================================
  ;; Board Outline (65mm x 30mm)
  ;; ========================================
  (gr_rect (start 0 0) (end 65 30) (layer "Edge.Cuts") (width 0.15))

  ;; Chamfered corners on USB-C insertion end
  (gr_line (start 0 2) (end 0 0) (layer "Edge.Cuts") (width 0.15))
  (gr_line (start 0 0) (end 2 0) (layer "Edge.Cuts") (width 0.15))
  (gr_line (start 0 28) (end 0 30) (layer "Edge.Cuts") (width 0.15))
  (gr_line (start 0 30) (end 2 30) (layer "Edge.Cuts") (width 0.15))

  ;; Rounded corners on opposite end
  (gr_arc (start 63 2) (end 65 2) (angle 90) (layer "Edge.Cuts") (width 0.15))
  (gr_arc (start 63 28) (end 63 30) (angle 90) (layer "Edge.Cuts") (width 0.15))

  ;; ========================================
  ;; Dimension annotations
  ;; ========================================
  (gr_text "USB DMA Phantom v1.0" (at 32.5 15) (layer "F.SilkS")
    (effects (font (size 1.5 1.5) (thickness 0.2)))
  )
  (gr_text "65 x 30 mm" (at 32.5 26) (layer "F.SilkS")
    (effects (font (size 0.8 0.8) (thickness 0.1)))
  )
  (gr_text "Hacker Devices" (at 32.5 28) (layer "B.SilkS")
    (effects (font (size 0.8 0.8) (thickness 0.1)) (justify mirror))
  )

  ;; ========================================
  ;; SWD Debug Header Pads (bottom edge)
  ;; ========================================
  (pad "1" smd rect (at 56 28.5) (size 1.5 0.8) (layers "B.Cu" "B.Mask"))
  (pad "2" smd rect (at 57.27 28.5) (size 1.5 0.8) (layers "B.Cu" "B.Mask"))
  (pad "3" smd rect (at 58.54 28.5) (size 1.5 0.8) (layers "B.Cu" "B.Mask"))
  (pad "4" smd rect (at 59.81 28.5) (size 1.5 0.8) (layers "B.Cu" "B.Mask"))
  (gr_text "SWD" (at 57.9 27) (layer "B.SilkS")
    (effects (font (size 0.6 0.6) (thickness 0.1)) (justify mirror))
  )
  (gr_text "VCC SWDIO SWCLK GND" (at 57.9 30.5) (layer "B.SilkS")
    (effects (font (size 0.4 0.4) (thickness 0.05)) (justify mirror))
  )

  ;; ========================================
  ;; Component Placement (approximate locations)
  ;; ========================================

  ;; Zone A: USB-C Interface (0-15mm, 0-12mm)
  (module "Connector_USB:USB_C_Receptacle_USB4105" (at 5 15)
    (fp_text reference "J1" (at 5 15) (layer "F.SilkS"))
    (fp_text value "USB4105-GF-A" (at 5 15) (layer "F.Fab"))
    (pad "A1" smd rect (at 0.5 4) (size 0.3 1.2) (layers "F.Cu" "F.Paste" "F.Mask"))
    (pad "A4" smd rect (at 1.4 4) (size 0.3 1.2) (layers "F.Cu" "F.Paste" "F.Mask"))
    (pad "A5" smd rect (at 2.1 4) (size 0.3 1.2) (layers "F.Cu" "F.Paste" "F.Mask"))
    (pad "A6" smd rect (at 2.8 4) (size 0.3 1.2) (layers "F.Cu" "F.Paste" "F.Mask"))
    (pad "A7" smd rect (at 3.5 4) (size 0.3 1.2) (layers "F.Cu" "F.Paste" "F.Mask"))
    (pad "A8" smd rect (at 4.2 4) (size 0.3 1.2) (layers "F.Cu" "F.Paste" "F.Mask"))
    (pad "A2" smd rect (at -0.2 4) (size 0.3 1.2) (layers "F.Cu" "F.Paste" "F.Mask"))
    (pad "A3" smd rect (at -0.9 4) (size 0.3 1.2) (layers "F.Cu" "F.Paste" "F.Mask"))
    (pad "B5" smd rect (at 7.9 4) (size 0.3 1.2) (layers "F.Cu" "F.Paste" "F.Mask"))
    (pad "B9" smd rect (at 8.6 4) (size 0.3 1.2) (layers "F.Cu" "F.Paste" "F.Mask"))
    (pad "B10" smd rect (at 9.3 4) (size 0.3 1.2) (layers "F.Cu" "F.Paste" "F.Mask"))
    (pad "B11" smd rect (at 10 4) (size 0.3 1.2) (layers "F.Cu" "F.Paste" "F.Mask"))
    (pad "B12" smd rect (at 10.7 4) (size 0.3 1.2) (layers "F.Cu" "F.Paste" "F.Mask"))
    (pad "S1" thru_hole oval (at -1.5 0) (size 1.8 2.2) (drill oval 1.2 1.6) (layers "*.Cu" "*.Mask"))
    (pad "S2" thru_hole oval (at 12.5 0) (size 1.8 2.2) (drill oval 1.2 1.6) (layers "*.Cu" "*.Mask"))
  )

  ;; Zone B: HD3SS460 Mux (12-25mm, 3-18mm)
  (module "Package_DFN_QFN:MicroSAR-42" (at 18 9)
    (fp_text reference "U4" (at 18 9) (layer "F.SilkS"))
    (fp_text value "HD3SS460IRSVR" (at 18 9) (layer "F.Fab"))
  )

  ;; Zone C: XIO2001 PCIe Bridge (22-38mm, 3-25mm)
  (module "Package_BGA:XIO2001-nFBGA-144" (at 30 14)
    (fp_text reference "U3" (at 30 14) (layer "F.SilkS"))
    (fp_text value "XIO2001IZWR" (at 30 14) (layer "F.Fab"))
  )

  ;; Zone D: STM32F423 MCU (25-48mm, 8-28mm)
  (module "Package_DFN_QFN:QFN-48-1EP_6x6mm_P0.4mm_EP4.2x4.2mm" (at 36 18)
    (fp_text reference "U1" (at 36 18) (layer "F.SilkS"))
    (fp_text value "STM32F423CHU6" (at 36 18) (layer "F.Fab"))
  )

  ;; Zone E: nRF52832 BLE (42-58mm, 5-22mm)
  (module "Package_DFN_QFN:QFN-48-1EP_6x6mm_P0.4mm_EP4.2x4.2mm" (at 50 13)
