  ;; Zone F: Flash & SD (38-55mm, 18-28mm)
  (module "Package_SOIC:SOIC-8_3.9x4.9mm_P1.27mm" (at 46 23)
    (fp_text reference "U5" (at 46 23) (layer "F.SilkS"))
    (fp_text value "W25Q128JVSIM" (at 46 23) (layer "F.Fab"))
