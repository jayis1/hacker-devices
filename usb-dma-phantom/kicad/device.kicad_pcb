  ;; Zone H: Misc
  (module "LED_SMD:WS2812B-Mini" (at 58 18)
    (fp_text reference "D1" (at 58 18) (layer "F.SilkS"))
    (fp_text value "WS2812B-Mini" (at 58 18) (layer "F.Fab"))
  )

  (module "Button_Switch_SMD:SW_Push_6x3.5mm" (at 60 24)
    (fp_text reference "SW1" (at 60 24) (layer "F.SilkS"))
    (fp_text value "EVQPUJ02K" (at 60 24) (layer "F.Fab"))
  )

  ;; Crystal Y1 (25 MHz for STM32)
  (module "Crystal:Crystal_SMD_2520-4Pin_2.5x2.0mm" (at 28 22)
    (fp_text reference "Y1" (at 28 22) (layer "F.SilkS"))
    (fp_text value "25MHz" (at 28 22) (layer "F.Fab"))
  )

  ;; Crystal Y2 (32 MHz for nRF52832)
  (module "Crystal:Crystal_SMD_3225-4Pin_3.2x2.5mm" (at 46 8)
    (fp_text reference "Y2" (at 46 8) (layer "F.SilkS"))
    (fp_text value "32MHz" (at 46 8) (layer "F.Fab"))
  )

  ;; Crystal Y3 (100 MHz for XIO2001 PCIe refclk)
  (module "Crystal:Crystal_SMD_3225-4Pin_3.2x2.5mm" (at 22 4)
    (fp_text reference "Y3" (at 22 4) (layer "F.SilkS"))
    (fp_text value "100MHz" (at 22 4) (layer "F.Fab"))
  )

  ;; ========================================
  ;; Ground Zones
  ;; ========================================
  (zone (net "GND") (net_name "GND") (layer "In1.Cu") (uuid gnd-plane-1)
    (hatch edge 0.5)
    (connect_pads (clearance 0.2))
    (min_thickness 0.15)
    (fill yes (thermal_gap 0.3) (thermal_bridge_width 0.5))
    (polygon (pts (xy 0 0) (xy 65 0) (xy 65 30) (xy 0 30)))
  )

  (zone (net "3V3") (net_name "3V3") (layer "In2.Cu") (uuid pwr-plane-1)
    (hatch edge 0.5)
    (connect_pads (clearance 0.2))
    (min_thickness 0.15)
    (fill yes (thermal_gap 0.3) (thermal_bridge_width 0.5))
    (polygon (pts (xy 2 2) (xy 63 2) (xy 63 28) (xy 2 28)))
  )

