    (in_bom yes) (on_board yes)
    (property "Reference" "Y1" (at 95 55 0)
      (effects (font (size 1.27 1.27)))
    )
    (property "Value" "32.768kHz" (at 95 53 0)
      (effects (font (size 1.27 1.27)))
    )
  )

  ;; ==================== WIRES / NETS ====================

  ;; Host SMBus clock/data from J1 to U3 (level shifter A side)
  (wire (pts (xy 18 93) (xy 28 91)))
  (wire (pts (xy 18 89) (xy 28 87)))
  ;; U3 B side to MCU I2C1 (host)
  (wire (pts (xy 52 87) (xy 63 54)))    ;; SMB_CLK_HOST -> PA6
  (wire (pts (xy 52 91) (xy 63 51)))   ;; SMB_DAT_HOST -> PA7

  ;; Battery SMBus from J2 to U4 (level shifter B side)
  (wire (pts (xy 152 87) (xy 142 91)))
  (wire (pts (xy 152 91) (xy 142 87)))
  ;; U4 A side to MCU I2C2 (battery)
  (wire (pts (xy 108 91) (xy 97 75)))   ;; SMB_CLK_BATT -> PB13
  (wire (pts (xy 108 87) (xy 97 72)))   ;; SMB_DAT_BATT -> PB14

  ;; MCU UART to ESP32-C3
  (wire (pts (xy 63 66) (xy 116 62)))   ;; PA2 TX -> ESP RXD0
  (wire (pts (xy 63 63) (xy 116 58)))   ;; PA3 RX <- ESP TXD0

  ;; Pull-ups to 3V3
  (wire (pts (xy 55 50) (xy 55 40)))    ;; R1 to 3V3
  (wire (pts (xy 60 50) (xy 60 40)))
  (wire (pts (xy 100 50) (xy 100 40)))
  (wire (pts (xy 105 50) (xy 105 40)))

  ;; LED + R5
  (wire (pts (xy 100 110) (xy 100 120)))
  (wire (pts (xy 100 130) (xy 100 135)))  ;; LED to GND

  ;; Crystal to MCU
  (wire (pts (xy 90 60) (xy 80 60)))
  (wire (pts (xy 100 60) (xy 97 60)))

  ;; Power rails
  (wire (pts (xy 10 97) (xy 10 110)))   ;; J1 GND
  (wire (pts (xy 165 97) (xy 165 110))) ;; J2 GND

  ;; ==================== LABELS / NETS ====================
  (global_label "SMB_CLK_HOST" (shape input) (at 55 45 0)
    (effects (font (size 1.27 1.27)))
  )
  (global_label "SMB_DAT_HOST" (shape input) (at 60 45 0)
    (effects (font (size 1.27 1.27)))
  )
  (global_label "SMB_CLK_BATT" (shape input) (at 100 45 0)
    (effects (font (size 1.27 1.27)))
  )
  (global_label "SMB_DAT_BATT" (shape input) (at 105 45 0)
    (effects (font (size 1.27 1.27)))
  )
  (global_label "VBAT+" (shape input) (at 10 97 0)
    (effects (font (size 1.27 1.27)))
  )
  (global_label "3V3" (shape input) (at 115 50 0)
    (effects (font (size 1.27 1.27)))
  )
  (global_label "GND" (shape input) (at 10 112 0)
    (effects (font (size 1.27 1.27)))
  )
  (global_label "SMBALERT#" (shape input) (at 20 97 0)
    (effects (font (size 1.27 1.27)))
  )
  (global_label "BATT_PRSNT#" (shape input) (at 20 93 0)
    (effects (font (size 1.27 1.27)))
  )

  ;; ==================== NET CLASS ASSIGNMENTS ====================
  (net_class "Default" "Default net class"
    (wire_width 0.2)
    (via_dia 0.6) (via_drill 0.3)
  )
  (net_class "SMBus" "SMBus / PMBus I2C signals"
    (wire_width 0.25)
    (via_dia 0.5) (via_drill 0.25)
  )
  (net_class "Power" "Power rails VBAT+ / 3V3 / GND"
    (wire_width 0.5)
    (via_dia 0.8) (via_drill 0.4)
  )

  ;; ==================== SHEET METADATA ====================
  (sheet_instances
    (path "/" (page "1"))
  )
)