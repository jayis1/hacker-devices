(kicad_pcb
  (version 20211014)
  (generator "hermes-agent")
  (general
    (thickness 0.2)
    (legacy_teardrops no)
  )

  (paper "A4")

  (title_block
    (title "Joule-Phantom — Smart-Battery SMBus MITM Implant")
    (date "2026-07-24")
    (rev "1.0")
    (company "jayis1")
    (comment 1 "Author: jayis1")
    (comment 2 "License: CERN-OHL-S v2")
    (comment 3 "Flex interposer 0.2mm, 4-layer")
  )

  (layers
    (0 "F.Cu" signal)
    (1 "In1.Cu" signal "GND")
    (2 "In2.Cu" signal "PWR")
    (31 "B.Cu" signal)
    (32 "B.Adhes" user)
    (33 "F.Adhes" user)
    (34 "B.Paste" user)
    (35 "F.Paste" user)
    (36 "B.SilkS" user)
    (37 "F.SilkS" user)
    (38 "B.Mask" user)
    (39 "F.Mask" user)
    (40 "Dwgs.User" user)
    (41 "Cmts.User" user)
    (42 "Eco1.User" user)
    (43 "Eco2.User" user)
    (44 "Edge.Cuts" user)
    (45 "Margin" user)
    (46 "B.CrtYd" user)
    (47 "F.CrtYd" user)
    (48 "B.Fab" user)
    (49 "F.Fab" user)
  )

  (setup
    (stackup
      (layer "F.Cu" (copper F.Cu) (type copper) (thickness 0.018))
      (layer "F.Paste" (type solderpaste) (thickness 0.01))
      (layer "F.Mask" (type soldermask) (thickness 0.01) (color "blue"))
      (layer "In1.Cu" (copper In1.Cu) (type copper) (thickness 0.018))
      (layer "Core" (type core) (thickness 0.07) (material "polyimide"))
      (layer "In2.Cu" (copper In2.Cu) (type copper) (thickness 0.018))
      (layer "B.Mask" (type soldermask) (thickness 0.01) (color "blue"))
      (layer "B.Paste" (type solderpaste) (thickness 0.01))
      (layer "B.Cu" (copper B.Cu) (type copper) (thickness 0.018))
    )
    (pad_to_mask_clearance 0.05)
    (solder_mask_min_width 0.04)
    (grid_origin 0 0)
    (plotoutline (thickness 0.1))
    (trace_min_width 0.2)
    (via_min_size 0.4)
    (via_min_drill 0.2)
    (uvia_min_size 0.2)
    (uvia_min_drill 0.1)
    (defaults
      (edge_clearance 0.3)
    )
  )

  ;; ==================== NETS ====================
  (net 0 "")
  (net 1 "GND")
  (net 2 "VBAT+")
  (net 3 "3V3")
  (net 4 "SMB_CLK_HOST")
  (net 5 "SMB_DAT_HOST")
  (net 6 "SMB_CLK_BATT")
  (net 7 "SMB_DAT_BATT")
  (net 8 "SMBALERT#")
  (net 9 "BATT_PRSNT#")
  (net 10 "UART_TX")
  (net 11 "UART_RX")
  (net 12 "LED_DRIVE")
  (net 13 "GLITCH_OUT")
  (net 14 "ADC_VBAT")
  (net 15 "ADC_THERM")
  (net 16 "XTAL1")
  (net 17 "XTAL2")

  (net_class "Default" ""
    (clearance 0.2)
    (trace_width 0.25)
    (via_dia 0.6) (via_drill 0.3)
    (uvia_dia 0.2) (uvia_drill 0.1)
  )
  (net_class "SMBus" "SMBus / PMBus I2C signals"
    (clearance 0.15)
    (trace_width 0.2)
    (via_dia 0.5) (via_drill 0.25)
    (uvia_dia 0.2) (uvia_drill 0.1)
    (add_net "SMB_CLK_HOST")
    (add_net "SMB_DAT_HOST")
    (add_net "SMB_CLK_BATT")
    (add_net "SMB_DAT_BATT")
    (add_net "SMBALERT#")
  )
  (net_class "Power" "Power rails"
    (clearance 0.3)
    (trace_width 0.5)
    (via_dia 0.8) (via_drill 0.4)
    (uvia_dia 0.3) (uvia_drill 0.15)
    (add_net "GND")
    (add_net "VBAT+")
    (add_net "3V3")
  )

